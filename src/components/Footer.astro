---
// Component: Footer
// Purpose: Footer with contact, links, and CTA.
// Props: none
// JS: none
---

<footer class="bg-brand-bg-light pt-[60px] relative overflow-hidden">
	<div class="max-w-[1700px] mx-auto px-6 md:px-10">
		<div class="bg-white rounded-section max-w-[1700px] mx-auto px-[60px] py-[60px] pb-10 border border-brand-border relative z-[2] md:px-7 md:py-10">
			<div class="grid grid-cols-1 md:grid-cols-[40%_30%_30%] md:gap-0 gap-8">
				<div class="px-0 md:px-8 md:border-r md:border-brand-border md:pl-0">
					<span class="text-[10px] uppercase tracking-[.12em] text-brand-muted font-semibold mb-[18px] block">Head office</span>
					<p class="text-[14px] text-brand-text leading-relaxed">
						1959 Sycamore Lane,<br />
						Tampa, FL 33602,<br />
						United States
					</p>
					<div class="inline-block border border-primary text-primary rounded-full px-4 py-1.5 mt-[14px] text-[14px] font-medium">
						+1 (813) 555-0142
					</div>
					<div class="text-[14px] mt-2.5 text-brand-text">
						<a href="mailto:hello@diteck.com">hello@diteck.com</a>
					</div>
				</div>

				<div class="px-0 md:px-8 md:border-r md:border-brand-border md:pr-8 md:pl-8 border-b md:border-b-0 border-brand-border pb-6 md:pb-0">
					<span class="text-[10px] uppercase tracking-[.12em] text-brand-muted font-semibold mb-[18px] block">Links</span>
					<div class="grid grid-cols-2 gap-x-6 gap-y-2">
						<a class="text-[15px] text-brand-text hover:text-primary transition-colors py-1 inline-block" href="#">Works</a>
						<a class="text-[15px] text-brand-text hover:text-primary transition-colors py-1 inline-block" href="#">Blog</a>
						<a class="text-[15px] text-brand-text hover:text-primary transition-colors py-1 inline-block" href="#">Expertise</a>
						<a class="text-[15px] text-brand-text hover:text-primary transition-colors py-1 inline-block" href="#">Careers</a>
						<a class="text-[15px] text-brand-text hover:text-primary transition-colors py-1 inline-block" href="#">About</a>
						<a class="text-[15px] text-brand-text hover:text-primary transition-colors py-1 inline-block" href="#">Partnerships</a>
						<a class="text-[15px] text-brand-text hover:text-primary transition-colors py-1 inline-block" href="#">Team</a>
						<a class="text-[15px] text-brand-text hover:text-primary transition-colors py-1 inline-block" href="#">Contact</a>
						<a class="text-[15px] text-brand-text hover:text-primary transition-colors py-1 inline-block" href="#">Awards</a>
					</div>
				</div>

				<div class="px-0 md:px-8 md:pr-0 border-b md:border-b-0 border-brand-border pb-6 md:pb-0">
					<span class="text-[10px] uppercase tracking-[.12em] text-brand-muted font-semibold mb-[18px] block">Follow Us</span>
					<div class="flex flex-col gap-2">
						<a class="text-[15px] text-brand-text inline-flex items-center gap-2 hover:text-primary transition-colors before:content-['→'] before:text-primary before:text-xs" href="#">Facebook</a>
						<a class="text-[15px] text-brand-text inline-flex items-center gap-2 hover:text-primary transition-colors before:content-['→'] before:text-primary before:text-xs" href="#">Instagram</a>
						<a class="text-[15px] text-brand-text inline-flex items-center gap-2 hover:text-primary transition-colors before:content-['→'] before:text-primary before:text-xs" href="#">Youtube</a>
						<a class="text-[15px] text-brand-text inline-flex items-center gap-2 hover:text-primary transition-colors before:content-['→'] before:text-primary before:text-xs" href="#">Twitter</a>
					</div>
				</div>
			</div>

			<div class="border-t border-brand-border mt-10 pt-5 flex justify-between items-center gap-4 flex-wrap text-sm text-brand-muted">
				<div>
					© 2025 <a class="text-primary" href="#">Diteck</a>. All Rights Reserved.
				</div>
				<div class="flex gap-3">
					<a href="#">Cookies</a>
					<a href="#">Privacy</a>
					<a href="#">Terms</a>
				</div>
			</div>
		</div>

		<div class="text-ghost-word text-primary/[0.08] tracking-[-0.04em] text-center select-none pointer-events-none relative z-[1] -mt-8" aria-hidden="true">
			diteck
		</div>

		<a
			href="#"
			class="absolute bottom-[60px] right-[60px] z-[5] w-[140px] h-[140px] rounded-full bg-primary flex items-center justify-center shadow-[0_16px_40px_rgba(99,110,223,.35)] md:w-[104px] md:h-[104px] md:bottom-6 md:right-6"
			aria-label="Contact us"
		>
			<svg class="absolute inset-0 animate-rotate-cta" viewBox="0 0 140 140">
				<defs>
					<path id="circlePath" d="M70,70 m-54,0 a54,54 0 1,1 108,0 a54,54 0 1,1 -108,0" />
				</defs>
				<text fill="#fff" font-size="12" font-weight="600" letter-spacing="3" font-family="Mona Sans, sans-serif">
					<textPath href="#circlePath">Contact · Contact · Contact · Contact · Contact · </textPath>
				</text>
			</svg>
			<svg class="relative text-white" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
				<rect x="3" y="5" width="18" height="14" rx="2" />
				<path d="m3 7 9 6 9-6" />
			</svg>
		</a>
	</div>
</footer>
