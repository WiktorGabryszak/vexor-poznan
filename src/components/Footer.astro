---
// Component: Footer
// Purpose: Footer with contact, links, and CTA.
// Props: none
// JS: none
---

<footer class="bg-brand-bg-light pt-[60px] relative overflow-hidden">
	<div class="bg-white rounded-[40px] relative z-[2]">
		<div class="max-w-[1700px] mx-auto px-5 py-10 md:px-7 md:py-10">
			<div class="grid grid-cols-1 md:grid-cols-[40%_30%_30%] md:gap-0 gap-8">
				<div class="px-0 md:px-8 md:border-r md:border-brand-border md:pl-0">
					<a href="/" class="inline-flex items-center gap-2.5 text-brand-text mb-6" aria-label="Vexor">
						<img src="/favicon.svg" alt="Vexor logo" width="28" height="28" />
						<span class="text-[20px] font-bold tracking-[-0.02em]">Vexor</span>
					</a>
					<span class="text-[10px] uppercase tracking-[.12em] text-brand-muted font-semibold mb-[18px] block">Kontakt</span>
					<p class="text-[14px] text-brand-text leading-relaxed">
						Polska
					</p>
					<div class="inline-block border border-primary text-primary rounded-full px-4 py-1.5 mt-[14px] text-[14px] font-medium">
						<a href="tel:+48601076883">+48 601 076 883</a>
					</div>
					<div class="text-[14px] mt-2.5 text-brand-text">
						<a href="mailto:kontakt@vexordesigns.pl">kontakt@vexordesigns.pl</a>
					</div>
				</div>

				<div class="px-0 md:px-8 md:border-r md:border-brand-border md:pr-8 md:pl-8 border-b md:border-b-0 border-brand-border pb-6 md:pb-0">
					<span class="text-[10px] uppercase tracking-[.12em] text-brand-muted font-semibold mb-[18px] block">Nawigacja</span>
					<div class="grid grid-cols-2 gap-x-6 gap-y-2">
						<a class="text-[15px] text-brand-text hover:text-primary hover:underline transition-colors py-1 inline-block" href="/">Strona główna</a>
						<a class="text-[15px] text-brand-text hover:text-primary hover:underline transition-colors py-1 inline-block" href="/uslugi/">Usługi</a>
						<a class="text-[15px] text-brand-text hover:text-primary hover:underline transition-colors py-1 inline-block" href="/o-nas/">O nas</a>
						<a class="text-[15px] text-brand-text hover:text-primary hover:underline transition-colors py-1 inline-block" href="/projekty/">Projekty</a>
						<a class="text-[15px] text-brand-text hover:text-primary hover:underline transition-colors py-1 inline-block" href="/kontakt/">Kontakt</a>
						<a class="text-[15px] text-brand-text hover:text-primary hover:underline transition-colors py-1 inline-block" href="/uslugi/projektowanie-stron-internetowych/">Strony www</a>
						<a class="text-[15px] text-brand-text hover:text-primary hover:underline transition-colors py-1 inline-block" href="/uslugi/pozycjonowanie-seo/">Pozycjonowanie</a>
						<a class="text-[15px] text-brand-text hover:text-primary hover:underline transition-colors py-1 inline-block" href="/uslugi/tworzenie-sklepow-internetowych/">Sklepy online</a>
					</div>
				</div>

				<div class="px-0 md:px-8 md:pr-0 border-b md:border-b-0 border-brand-border pb-6 md:pb-0">
					<span class="text-[10px] uppercase tracking-[.12em] text-brand-muted font-semibold mb-[18px] block">Social Media</span>
					<div class="flex flex-col gap-2">
						<a class="text-[15px] text-brand-text inline-flex items-center gap-2 hover:text-primary transition-colors before:content-['→'] before:text-primary before:text-xs py-3 px-3" href="https://www.facebook.com/">Facebook</a>
						<a class="text-[15px] text-brand-text inline-flex items-center gap-2 hover:text-primary transition-colors before:content-['→'] before:text-primary before:text-xs py-3 px-3" href="https://www.instagram.com/vexordesigns_official/">Instagram</a>
					</div>
				</div>
			</div>

			<div class="border-t border-brand-border mt-10 pt-5 flex justify-between items-center gap-4 flex-wrap text-sm text-brand-muted">
				<div>
					© 2025 <a class="hover:text-primary transition-colors" style="color: #4A52B8;" href="/">Vexor</a>. Wszelkie prawa zastrzeżone.
				</div>
				<div class="flex gap-3">
					<a href="/polityka-prywatnosci/">Polityka prywatności</a>
				</div>
			</div>
		</div>
	</div>

	<a
		href="/kontakt/"
		class="absolute bottom-[60px] right-[60px] z-[5] w-[140px] h-[140px] rounded-full bg-primary flex items-center justify-center shadow-[0_16px_40px_rgba(99,110,223,.35)] md:w-[104px] md:h-[104px] md:bottom-6 md:right-6"
		aria-label="Skontaktuj się z Vexor"
		style="touch-action: manipulation;"
	>
		<svg class="absolute inset-0 animate-rotate-cta" viewBox="0 0 140 140">
			<defs>
				<path id="circlePath" d="M70,70 m-54,0 a54,54 0 1,1 108,0 a54,54 0 1,1 -108,0" />
			</defs>
			<text fill="#fff" font-size="12" font-weight="600" letter-spacing="3" font-family="Mona Sans, sans-serif">
				<textPath href="#circlePath">Kontakt · Kontakt · Kontakt · Kontakt · Kontakt · </textPath>
			</text>
		</svg>
		<svg class="relative text-white" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
			<rect x="3" y="5" width="18" height="14" rx="2" />
			<path d="m3 7 9 6 9-6" />
		</svg>
	</a>
</footer>
