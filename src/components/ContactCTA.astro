---
import ButtonA from './ui/ButtonA.astro';
import ButtonB from './ui/ButtonB.astro';
import Eyebrow from './ui/Eyebrow.astro';

interface Props {
	eyebrow?: string;
	heading?: string;
	description?: string;
	buttonLabel?: string;
}

const {
	eyebrow = 'Skontaktuj się',
	heading = 'Zbudujmy stronę, która przyciąga klientów',
	description = 'Bezpłatna wycena w 24h. Bez zobowiązań, bez ukrytych kosztów.',
	buttonLabel = 'Bezpłatna wycena',
} = Astro.props;
---

<section class="bg-brand-bg-light">
	<div class="max-w-[1700px] mx-auto px-5 md:px-10">
		<div class="relative rounded-[40px] overflow-hidden min-h-[520px] flex flex-col">

			<!-- Background image -->
			<img src="/h6_bg-1.jpg" alt="" class="absolute inset-0 w-full h-full object-cover" aria-hidden="true" />

			<!-- Gradient overlay -->
			<div class="absolute inset-0" style="background: linear-gradient(to bottom, rgba(0,0,0,0.35) 0%, rgba(0,0,0,0.15) 40%, rgba(0,0,0,0.72) 100%)"></div>

			<!-- Centered content -->
			<div class="relative z-10 flex flex-col items-center justify-center text-center flex-1 px-6 py-20 gap-5">
				<div class="flex justify-center w-full">
					<Eyebrow dark={true} label={eyebrow} />
				</div>
				<h2 class="text-h2 text-white max-w-[600px]">
					{heading}
				</h2>

				<p class="text-white/70 text-xl max-w-[440px] leading-relaxed">
					{description}
				</p>

				<!-- Phone + Email -->
				<div class="flex flex-wrap items-center justify-center gap-6 mt-2">
					<a href="tel:+48601076883" class="flex items-center gap-2.5 text-white/80 hover:text-white transition-colors group">
						<span class="w-9 h-9 rounded-xl bg-white/10 group-hover:bg-primary flex items-center justify-center transition-colors duration-200 flex-shrink-0">
							<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
								<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.78a16 16 0 0 0 6.29 6.29l1.85-1.85a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
							</svg>
						</span>
						<span class="text-[16px] font-medium">+48 601 076 883</span>
					</a>

					<span class="text-white/20 hidden sm:block">|</span>

					<a href="mailto:kontakt@vexordesigns.pl" class="flex items-center gap-2.5 text-white/80 hover:text-white transition-colors group">
						<span class="w-9 h-9 rounded-xl bg-white/10 group-hover:bg-primary flex items-center justify-center transition-colors duration-200 flex-shrink-0">
							<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
								<rect x="2" y="4" width="20" height="16" rx="2"/>
								<path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
							</svg>
						</span>
						<span class="text-[16px] font-medium">kontakt@vexordesigns.pl</span>
					</a>
				</div>

				<!-- Button -->
				<div class="mt-2">
					<ButtonA href="/kontakt/" label={buttonLabel} invert={false} />
				</div>
			</div>


		</div>
	</div>
</section>
