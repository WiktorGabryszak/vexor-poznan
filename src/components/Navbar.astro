---
import ButtonA from './ui/ButtonA.astro';

interface Props {
  dark?: boolean;
}
const { dark = false } = Astro.props;
---

<header
  id="nav"
  class="group fixed top-0 left-0 right-0 z-[100] h-[90px] m-5 md:m-8 py-3 flex items-center"
>
  <div class={`w-full max-w-[1700px] mx-auto px-8 md:pr-2.5 md:pl-8 flex flex-wrap md:flex-nowrap items-center justify-between gap-6 rounded-[30px] py-2.5 pl-[30px] pr-[10px] backdrop-blur-[60px] transition-all duration-150 ease-out border ${dark ? 'border-black/[0.06] bg-white/90' : 'border-white/10'} group-data-[scrolled]:bg-white/90 group-data-[scrolled]:backdrop-blur-2xl group-data-[scrolled]:border-black/[0.06] group-data-[scrolled]:shadow-[0_2px_24px_rgba(0,0,0,0.07)]`}>

    <a href="/" class={`inline-flex items-center gap-2.5 transition-colors duration-150 ease-out group-data-[scrolled]:text-brand-accent ${dark ? 'text-brand-accent' : 'text-white'}`} aria-label="Vexor – tworzenie stron internetowych">
      <svg xmlns="http://www.w3.org/2000/svg" version="1.0" viewBox="0 0 1024 1024" width="28" height="28" fill="currentColor" class="text-primary" aria-hidden="true">
        <g transform="translate(0,1024) scale(0.1,-0.1)">
          <path d="M1717 7460 c-54 -14 -128 -54 -159 -87 -14 -15 -37 -50 -50 -78 l-23 -50 0 -1035 0 -1035 24 -45 c35 -68 98 -127 159 -150 51 -19 79 -20 944 -20 617 0 912 -3 957 -11 81 -14 149 -47 208 -102 57 -52 86 -97 115 -179 l22 -63 3 -945 c3 -1052 0 -996 73 -1088 27 -35 55 -56 101 -78 l64 -29 944 -3 c1063 -3 1000 -7 1089 73 30 27 59 66 73 97 l24 53 5 960 c6 1040 3 984 60 1095 31 61 115 141 180 173 30 14 84 31 120 37 41 6 380 10 911 10 950 0 899 -4 987 75 36 33 53 58 70 106 l22 64 0 1006 c0 1129 3 1073 -72 1155 -22 24 -66 56 -97 71 l-56 28 -935 -1 -935 -1 -52 -22 c-30 -13 -70 -43 -94 -68 -80 -87 -73 -1 -79 -1098 l-5 -980 -28 -69 c-60 -152 -174 -246 -332 -275 -72 -13 -1501 -15 -1648 -2 -198 18 -329 120 -394 308 -15 43 -18 145 -23 1018 l-5 970 -23 50 c-29 64 -74 110 -137 143 l-50 25 -960 3 c-565 2 -975 -1 -998 -6z" />
        </g>
      </svg>
      <span class="text-[20px] font-bold tracking-[-0.02em]">Vexor</span>
    </a>

    <nav class={`hidden md:flex items-center gap-4 text-[18px] font-medium group-data-[scrolled]:text-brand-accent ${dark ? 'text-brand-accent' : 'text-white'}`} aria-label="Główna nawigacja">
      <a class="group/navlink relative inline-block overflow-hidden" href="/">
        <span class="block transition-transform duration-300 ease-out group-hover/navlink:-translate-y-full">Strona Główna</span>
        <span class="absolute inset-0 block translate-y-full transition-transform duration-300 ease-out group-hover/navlink:translate-y-0">Strona Główna</span>
      </a>
      <span class="w-1.5 h-1.5 rounded-sm bg-primary flex-shrink-0" aria-hidden="true"></span>
      <a class="group/navlink relative inline-block overflow-hidden" href="#o-nas">
        <span class="block transition-transform duration-300 ease-out group-hover/navlink:-translate-y-full">O nas</span>
        <span class="absolute inset-0 block translate-y-full transition-transform duration-300 ease-out group-hover/navlink:translate-y-0">O nas</span>
      </a>
      <span class="w-1.5 h-1.5 rounded-sm bg-primary flex-shrink-0" aria-hidden="true"></span>

      <!-- Usługi dropdown -->
      <div class="relative group/dd">
        <a href="#wartosci" class="group/navlink flex items-center gap-1.5" aria-haspopup="true">
          <span class="relative inline-block overflow-hidden">
            <span class="block transition-transform duration-300 ease-out group-hover/navlink:-translate-y-full">Usługi</span>
            <span class="absolute inset-0 block translate-y-full transition-transform duration-300 ease-out group-hover/navlink:translate-y-0">Usługi</span>
          </span>
          <svg class="w-3.5 h-3.5 transition-transform duration-200 group-hover/dd:rotate-180" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="2,4 6,8 10,4"/>
          </svg>
        </a>

        <div class="absolute top-full left-1/2 -translate-x-1/2 pt-5 opacity-0 pointer-events-none group-hover/dd:opacity-100 group-hover/dd:pointer-events-auto transition-all duration-200 translate-y-1 group-hover/dd:translate-y-0">
          <div class="min-w-[300px] rounded-[24px] bg-white shadow-[0_8px_40px_rgba(0,0,0,0.18)] p-3 flex flex-col">
            <a href="https://vexordesigns.pl/uslugi/projektowanie-stron-internetowych/" class="flex items-center gap-3 px-4 py-3.5 rounded-2xl hover:bg-gray-50 transition-colors group/item">
              <svg class="w-[18px] h-[18px] text-primary flex-shrink-0" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="1" y="2" width="14" height="11" rx="2"/>
                <path d="M5 15h6M8 13v2"/>
              </svg>
              <span class="text-[16px] font-medium text-gray-800 group-hover/item:text-gray-900 transition-colors">Strony Internetowe</span>
            </a>
            <a href="https://vexordesigns.pl/uslugi/tworzenie-sklepow-internetowych/" class="flex items-center gap-3 px-4 py-3.5 rounded-2xl hover:bg-gray-50 transition-colors group/item">
              <svg class="w-[18px] h-[18px] text-primary flex-shrink-0" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M2 2h1.5l1 5h7l1-4H4.5"/>
                <circle cx="6.5" cy="13" r="1"/><circle cx="11" cy="13" r="1"/>
              </svg>
              <span class="text-[16px] font-medium text-gray-800 group-hover/item:text-gray-900 transition-colors">Sklepy Internetowe</span>
            </a>
            <a href="https://vexordesigns.pl/uslugi/pozycjonowanie-seo/" class="flex items-center gap-3 px-4 py-3.5 rounded-2xl hover:bg-gray-50 transition-colors group/item">
              <svg class="w-[18px] h-[18px] text-primary flex-shrink-0" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="7" cy="7" r="4.5"/>
                <path d="M10.5 10.5L14 14"/>
                <path d="M5 7h4M7 5v4"/>
              </svg>
              <span class="text-[16px] font-medium text-gray-800 group-hover/item:text-gray-900 transition-colors">Pozycjonowanie SEO</span>
            </a>
            <a href="https://vexordesigns.pl/uslugi/aplikacje-webowe/" class="flex items-center gap-3 px-4 py-3.5 rounded-2xl hover:bg-gray-50 transition-colors group/item">
              <svg class="w-[18px] h-[18px] text-primary flex-shrink-0" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="4,6 1,8 4,10"/>
                <polyline points="12,6 15,8 12,10"/>
                <line x1="9" y1="4" x2="7" y2="12"/>
              </svg>
              <span class="text-[16px] font-medium text-gray-800 group-hover/item:text-gray-900 transition-colors">Aplikacje Webowe</span>
            </a>
          </div>
        </div>
      </div>

      <span class="w-1.5 h-1.5 rounded-sm bg-primary flex-shrink-0" aria-hidden="true"></span>
      <a class="group/navlink relative inline-block overflow-hidden" href="#projekty">
        <span class="block transition-transform duration-300 ease-out group-hover/navlink:-translate-y-full">Projekty</span>
        <span class="absolute inset-0 block translate-y-full transition-transform duration-300 ease-out group-hover/navlink:translate-y-0">Projekty</span>
      </a>
      <span class="w-1.5 h-1.5 rounded-sm bg-primary flex-shrink-0" aria-hidden="true"></span>
      <a class="group/navlink relative inline-block overflow-hidden" href="#kontakt">
        <span class="block transition-transform duration-300 ease-out group-hover/navlink:-translate-y-full">Kontakt</span>
        <span class="absolute inset-0 block translate-y-full transition-transform duration-300 ease-out group-hover/navlink:translate-y-0">Kontakt</span>
      </a>
    </nav>

    <div class="flex items-center gap-3">
      <div class="hidden md:block">
        <ButtonA href="#kontakt" label="Zamów stronę" invert={false} />
      </div>
      <button
        id="hamburger"
        class={`md:hidden inline-flex w-10 h-10 items-center justify-center rounded-lg transition-colors duration-150 ease-out group-data-[scrolled]:text-brand-accent ${dark ? 'text-brand-accent' : 'text-white'}`}
        aria-label="Otwórz menu"
      >
        <span class="flex flex-col gap-[7px]">
          <span class="block w-[22px] h-[2px] bg-current"></span>
          <span class="block w-[22px] h-[2px] bg-current"></span>
          <span class="block w-[22px] h-[2px] bg-current"></span>
        </span>
      </button>
    </div>
  </div>
</header>
