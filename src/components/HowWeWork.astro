---
// Component: HowWeWork
// Purpose: Step-by-step process section.
// Props: none
// JS: none

import Eyebrow from './ui/Eyebrow.astro';

interface Step {
	num: string;
	title: string;
	desc: string;
}

const steps: Step[] = [
	{
		num: '01',
		title: 'Identify and Simplify',
		desc: 'We help you identify ways to accelerate the development cycle and maintain cost-effectiveness.'
	},
	{
		num: '02',
		title: 'Build and Develop',
		desc: 'Once identified, we now carry out all the complex, dynamic, and real-time solutions for your industry.'
	},
	{
		num: '03',
		title: 'Quality Control',
		desc: 'Be it functional, integration, system, and sanity — we meticulously control it all.'
	},
	{
		num: '04',
		title: 'Scale and Deploy',
		desc: 'On-time deployment is our niche; we do this by assessing, and scaling your development needs.'
	}
];
---

<section class="bg-brand-bg-light py-[100px]">
	<div class="max-w-[1700px] mx-auto px-6 md:px-10">
		<div class="grid grid-cols-1 lg:grid-cols-[1fr_1.4fr] gap-6 lg:gap-[60px] items-start mb-[60px]">
			<Eyebrow label="Working process" />
			<div>
				<h2 class="text-h2">How we work</h2>
				<p class="text-[16px] text-brand-text max-w-[520px] mt-[14px]">
					We are committed to supporting visionary entrepreneurs and fueling the growth of transformative businesses.
				</p>
			</div>
		</div>

		<div class="relative mt-[60px]">
			<div class="absolute top-6 left-[8%] right-[8%] h-px bg-brand-border z-0 lg:hidden"></div>
			<div class="grid grid-cols-1 sm:grid-cols-1 lg:grid-cols-2 xl:grid-cols-4 gap-6 relative z-[1]">
				{steps.map((step, index) => (
					<div class="relative reveal" style={`--stagger-i:${index}`}>
						<div class="ghost-number max-sm:hidden" aria-hidden="true">
							{step.num}
						</div>
						<div
							class:list={[
								'absolute right-[-18px] top-6 w-9 h-9 rounded-full bg-primary text-white text-sm flex items-center justify-center z-[2] shadow-[0_6px_16px_rgba(99,110,223,.35)]',
								index === steps.length - 1 ? 'hidden' : 'hidden sm:hidden lg:block lg:even:hidden'
							]}
							aria-hidden="true"
						>
							→
						</div>
						<h5 class="text-[18px] font-bold text-brand-accent mt-[60px] leading-snug max-sm:mt-2">
							{step.title}
						</h5>
						<p class="text-sm text-brand-muted leading-relaxed mt-2">{step.desc}</p>
					</div>
				))}
			</div>
		</div>
	</div>
</section>
