---
// Component: Testimonials
// Purpose: Client testimonials slider with photo panel.
// Props: none
// JS: inline <script>

import ButtonB from './ui/ButtonB.astro';
---

<section class="bg-brand-bg-light pb-[100px] relative">
	<div class="max-w-[1700px] mx-auto px-6 md:px-10">
		<div class="max-w-[900px] mx-auto rounded-section overflow-hidden relative grid grid-cols-1 md:grid-cols-[42%_58%] min-h-[460px] bg-testi-card reveal" style="--stagger-i:0">
			<div class="absolute top-[-20px] right-[-40px] z-[3] w-[80px] h-[120px] bg-shape-4 clip-ribbon animate-float-4"></div>

			<div class="md:col-start-1 md:row-start-1 m-6 md:ml-6 md:mt-6 md:mb-6 md:mr-0 bg-white rounded-2xl p-7 shadow-[0_12px_48px_rgba(0,0,0,.10)] flex flex-col gap-3 relative">
				<span class="absolute top-2 right-5 text-[64px] font-black text-primary opacity-25 leading-none font-serif">”</span>
				<span class="text-sm text-brand-muted">Hear from satisfied clients</span>
				<div class="border-t border-brand-border"></div>
				<div class="flex items-center gap-2.5 flex-wrap">
					<span class="w-8 h-8 rounded-full bg-primary text-white font-bold text-[14px] flex items-center justify-center">C</span>
					<span class="text-[16px] font-bold text-[#333]">4.9/5</span>
					<span class="text-[#FFB800] text-[14px] tracking-[1px]">★★★★★</span>
					<span class="w-full text-[10px] text-brand-muted -mt-1.5">Based on 1,847 reviews</span>
				</div>
				<p class="text-[20px] font-normal leading-[1.5] text-[#333]" id="testiQuote"></p>
				<div class="flex items-center gap-3 mt-auto">
					<div class="w-10 h-10 rounded-full flex-shrink-0" id="testiAvatar"></div>
					<div>
						<div class="text-sm font-bold text-[#333]" id="testiName"></div>
						<div class="text-[13px] text-brand-muted" id="testiRole"></div>
					</div>
				</div>
				<div class="flex gap-1.5 mt-1.5" id="testiDots" role="tablist">
					<button class="dot-btn w-2 h-2 rounded-full bg-brand-border transition-colors duration-200" data-i="0" aria-label="Testimonial 1"></button>
					<button class="dot-btn w-2 h-2 rounded-full bg-brand-border transition-colors duration-200" data-i="1" aria-label="Testimonial 2"></button>
					<button class="dot-btn w-2 h-2 rounded-full bg-brand-border transition-colors duration-200" data-i="2" aria-label="Testimonial 3"></button>
					<button class="dot-btn w-2 h-2 rounded-full bg-brand-border transition-colors duration-200" data-i="3" aria-label="Testimonial 4"></button>
				</div>
			</div>

			<div class="relative bg-[repeating-linear-gradient(45deg,rgba(255,255,255,.04)_0_1px,transparent_1px_16px)] min-h-[200px] md:min-h-0 md:row-start-1 md:col-start-2"></div>

			<div class="absolute bottom-6 right-6 z-[5]">
				<ButtonB dark={true} label="Write your review" />
			</div>
		</div>
	</div>
</section>

<script>
	const TESTIS = [
		{
			quote: "They've not only met our expectations but <strong>exceeded</strong> them in every project. We give a big <strong>thumbs up</strong>!",
			name: 'Ronald Benson',
			role: 'Art Director',
			avatar: 'linear-gradient(135deg,#C0C8E8,#8898C8)'
		},
		{
			quote: 'Their fresh perspective and <strong>innovative strategies</strong> have given our business a much-needed revamp.',
			name: 'Jane Cooper',
			role: 'Co-Founder, Cooper Co.',
			avatar: 'linear-gradient(135deg,#E8C8C0,#C88068)'
		},
		{
			quote: 'Your staff is very <strong>courteous and quick</strong> to respond to any service call we might have. Highly recommended.',
			name: 'Brooklyn Simmons',
			role: 'Lead Supervisor',
			avatar: 'linear-gradient(135deg,#C8E0C8,#688868)'
		},
		{
			quote: 'I am thrilled to express my <strong>satisfaction</strong> with the services. Working with their team has been an absolute <strong>game-changer</strong>.',
			name: 'Jame Smith',
			role: 'Lead Supervisor',
			avatar: 'linear-gradient(135deg,#D8C8E8,#8868A8)'
		}
	];

	function showTestimonial(i) {
		const t = TESTIS[i];
		document.getElementById('testiQuote').innerHTML = t.quote;
		document.getElementById('testiName').textContent = t.name;
		document.getElementById('testiRole').textContent = t.role;
		document.getElementById('testiAvatar').style.background = t.avatar;
		document.querySelectorAll('.dot-btn').forEach((d, j) => {
			d.classList.toggle('bg-primary', i === j);
			d.classList.toggle('bg-brand-border', i !== j);
		});
	}

	document.querySelectorAll('.dot-btn').forEach((b) => {
		b.addEventListener('click', () => showTestimonial(parseInt(b.dataset.i, 10)));
	});
	showTestimonial(0);

	let testiIdx = 0;
	setInterval(() => {
		testiIdx = (testiIdx + 1) % TESTIS.length;
		showTestimonial(testiIdx);
	}, 6500);
</script>
