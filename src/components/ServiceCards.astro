---
// Component: ServiceCards
// Purpose: Glassmorphism service summary cards.
// Props: none
// JS: none


interface ServiceCard {
	icon: string;
	title: string;
	desc: string;
	href: string;
}

const cards: ServiceCard[] = [
	{
		icon:
			'<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 3.3a2.4 2.4 0 0 1 3.4 3.4L7.5 17.4l-4.5 1.1 1.1-4.5z"/><path d="M11.5 6.5l3.4 3.4"/></svg>',
		title: 'Strony Internetowe',
		desc: 'Projektujemy strony zoptymalizowane pod konwersję i Google. Szybkie ładowanie, mobile-first, gotowe do pozycjonowania.',
		href: '/uslugi/projektowanie-stron-internetowych/'
	},
	{
		icon:
			'<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>',
		title: 'Sklepy Internetowe',
		desc: 'Wdrażamy sklepy WooCommerce z integracją płatności. Bezpieczne, szybkie, gotowe na sprzedaż online.',
		href: '/uslugi/tworzenie-sklepow-internetowych/'
	},
	{
		icon:
			'<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 20V8m6 12V4m6 16v-9m6 9V12"/></svg>',
		title: 'Pozycjonowanie SEO',
		desc: 'Analiza słów kluczowych, optymalizacja on-page i budowanie widoczności w Google. Mierzymy wyniki.',
		href: '/uslugi/pozycjonowanie-seo/'
	},
	{
		icon:
			'<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M8 4l-6 8 6 8M16 4l6 8-6 8"/></svg>',
		title: 'Aplikacje Webowe',
		desc: 'Tworzymy dla firm dedykowane aplikacje webowe: od MVP po zaawansowane systemy i portale.',
		href: '/uslugi/aplikacje-internetowe/'
	}
];
---

<div class="max-w-[1700px] mx-auto px-5 md:px-10">
	<div class="grid grid-cols-1 lg:grid-cols-2 xl:grid-cols-4 gap-6">
		{cards.map((card, index) => (
			<article
				class="reveal bg-[#00000005] border-0 backdrop-blur-[30px] rounded-card p-8 flex flex-col text-white transition-colors duration-300 ease-out hover:bg-white/[0.18] gap-3" style={`--stagger-i:${index}; box-shadow: 0px 0px 0px 1px rgba(255,255,255,0.1);`}
			>
				<div class="w-16 h-16 rounded-xl bg-white/[0.15] flex items-center justify-center" set:html={card.icon} />
				<h2 class="text-h5 font-500 text-white mtnt">{card.title}</h2>
				<p class="text-[16px] text-white font-400 leading-relaxed5">{card.desc}</p>
				<div class="mt-auto pt-6">
					<a
						class="group inline-flex items-center h-12 rounded-2xl pr-6 pl-2 text-white text-[16px] font-semibold leading-[1.625] relative overflow-hidden"
						href={card.href}
						aria-label={`Zobacz usługę: ${card.title}`}
					>
						<span class="absolute left-0 top-0 bottom-0 w-12 rounded-2xl bg-[#636EC8] transition-all duration-300 ease-[ease] group-hover:w-full"></span>
						<span class="relative z-10 inline-flex w-12 h-12 items-center justify-center pr-4">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 32 32" fill="currentColor" aria-hidden="true">
								<path d="M15.52 4.953c-.47.155-.904.523-1.125.956-.109.213-.128.327-.128.758 0 .43.019.546.131.773.101.206.87 1.009 3.384 3.533l3.253 3.266-7.438.014-7.437.014-.267.141a2.097 2.097 0 0 0-.831.834c-.109.213-.129.328-.129.758 0 .431.02.544.129.759.165.323.523.68.845.845l.253.129 7.437.014 7.438.014-3.253 3.266c-2.514 2.524-3.283 3.327-3.384 3.533-.112.227-.131.343-.131.773 0 .594.104.858.489 1.244.386.386.65.49 1.244.49.429 0 .547-.02.773-.131.391-.191 9.972-9.772 10.163-10.163.111-.226.131-.344.131-.773 0-.429-.02-.547-.131-.773-.103-.211-1.155-1.293-4.986-5.129-5.414-5.42-5.101-5.143-5.87-5.172-.235-.009-.487.003-.56.027" />
								<path d="M15.52 4.953c-.47.155-.904.523-1.125.956-.109.213-.128.327-.128.758 0 .43.019.546.131.773.101.206.87 1.009 3.384 3.533l3.253 3.266-7.438.014-7.437.014-.267.141a2.097 2.097 0 0 0-.831.834c-.109.213-.129.328-.129.758 0 .431.02.544.129.759.165.323.523.68.845.845l.253.129 7.437.014 7.438.014-3.253 3.266c-2.514 2.524-3.283 3.327-3.384 3.533-.112.227-.131.343-.131.773 0 .594.104.858.489 1.244.386.386.65.49 1.244.49.429 0 .547-.02.773-.131.391-.191 9.972-9.772 10.163-10.163.111-.226.131-.344.131-.773 0-.429-.02-.547-.131-.773-.103-.211-1.155-1.293-4.986-5.129-5.414-5.42-5.101-5.143-5.87-5.172-.235-.009-.487.003-.56.027" />
							</svg>
						</span>
						<span class="relative z-10">Zobacz usługę</span>
					</a>
				</div>
			</article>
		))}
	</div>
</div>
