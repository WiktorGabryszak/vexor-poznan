---
// Component: CoreValues
// Purpose: Accordion list with supporting image and description.
// Props: none
// JS: inline <script>

import Eyebrow from './ui/Eyebrow.astro';

interface AccordionItem {
	icon: string;
	label: string;
	desc: string;
}

const items: AccordionItem[] = [
	{
		icon:
			'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="8" r="3.2"/><circle cx="17" cy="9" r="2.4"/><path d="M3 19c0-3 2.5-5 6-5s6 2 6 5"/><path d="M14.5 19c0-2 1.5-3.5 4-3.5 1.6 0 2.5.7 2.5.7"/></svg>',
		label: 'Experienced team',
		desc: "A senior multidisciplinary team with deep cross-industry expertise — designers, engineers, strategists who've shipped at scale."
	},
	{
		icon:
			'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a8 8 0 1 1-3-6.2L21 5v4h-4"/><path d="M8 12h.01M12 12h.01M16 12h.01"/></svg>',
		label: 'Responsibility',
		desc: 'We own outcomes, not just deliverables. Clear communication, weekly check-ins, no surprises at launch.'
	},
	{
		icon:
			'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l8 3v6c0 5-3.5 8-8 9-4.5-1-8-4-8-9V6z"/><path d="m8.5 12 2.4 2.4L16 9.5"/></svg>',
		label: 'Guaranteed quality',
		desc: 'Code reviews, design reviews, accessibility audits and performance budgets — quality is a process, not a hope.'
	},
	{
		icon:
			'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M4 13a8 8 0 0 1 16 0"/><rect x="3" y="13" width="4" height="6" rx="1.5"/><rect x="17" y="13" width="4" height="6" rx="1.5"/><path d="M19 19v1a2 2 0 0 1-2 2h-3"/></svg>',
		label: 'Quick support',
		desc: 'Async response within hours, not days. Slack, email or call — pick the channel that fits your team.'
	},
	{
		icon:
			'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21s-7-4.5-7-10a4.5 4.5 0 0 1 8.5-2A4.5 4.5 0 0 1 19 11c0 5.5-7 10-7 10z"/></svg>',
		label: 'Client satisfaction',
		desc: '9 out of 10 of our clients renew. We measure satisfaction quarterly and act on what we hear.'
	}
];
---

<section class="bg-brand-bg-light overflow-hidden relative py-[100px]">
	<div class="absolute left-[-60px] top-1/2 w-[120px] h-[120px] bg-shape-3 clip-triangle animate-float-3 pointer-events-none hidden sm:block"></div>
	<div class="max-w-[1700px] mx-auto px-6 md:px-10">
		<div class="grid grid-cols-1 lg:grid-cols-[3fr_2fr] gap-[60px] items-start">
			
			<div class="flex flex-col gap-6">
				<div class="reveal" style="--stagger-i:0">
					<Eyebrow label="Core Values" />
				</div>
				<h2 class="text-h2 reveal" style="--stagger-i:1">
					We are here for your development
				</h2>
				<div class="reveal cv-accordion" style="--stagger-i:2">
					{items.map((item, index) => (
						<details class="group border-b border-brand-border py-4" open={index === 0}>
							<summary class="flex items-center gap-4 cursor-pointer list-none">
								<span class="w-16 h-16 rounded-2xl flex items-center justify-center bg-white transition-colors duration-200 group-open:bg-primary/[0.12]">
									<span
										class="w-8 h-8 text-primary transition-colors duration-200"
										set:html={item.icon}
									/>
								</span>
								<h3 class="text-3xl font-medium text-brand-muted transition-colors duration-200 group-open:text-brand-accent">
									{item.label}
								</h3>
							</summary>
							<p class="mt-3 pl-[80px] text-xl text-brand-muted leading-relaxed">
								{item.desc}
							</p>
						</details>
					))}
				</div>
			</div>
			<div
				class="reveal aspect-[4/5] rounded-card overflow-hidden bg-placeholder-img"
				style="--stagger-i:0"
				aria-hidden="true"
			></div>
		</div>
	</div>
</section>

<script>
	const accordionItems = document.querySelectorAll('.cv-accordion details');

	accordionItems.forEach((item) => {
		item.addEventListener('toggle', () => {
			if (!item.open) return;
			accordionItems.forEach((other) => {
				if (other !== item) other.open = false;
			});
		});
	});
</script>

<style>
	.cv-accordion summary {
		list-style: none;
	}
	.cv-accordion summary::-webkit-details-marker {
		display: none;
	}
</style>
