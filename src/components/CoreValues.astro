---
import Eyebrow from './ui/Eyebrow.astro';
import { Image } from 'astro:assets';
import vexor2 from '../assets/images/vexor-2.jpg';

interface AccordionItem {
	icon: string;
	label: string;
	desc: string;
}

const items: AccordionItem[] = [
	{
		icon:
			'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="8" r="3.2"/><circle cx="17" cy="9" r="2.4"/><path d="M3 19c0-3 2.5-5 6-5s6 2 6 5"/><path d="M14.5 19c0-2 1.5-3.5 4-3.5 1.6 0 2.5.7 2.5.7"/></svg>',
		label: 'Doświadczony zespół',
		desc: 'Projektanci, developerzy i specjaliści SEO z wieloletnim doświadczeniem w tworzeniu stron dla firm z Polski.'
	},
	{
		icon:
			'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a8 8 0 1 1-3-6.2L21 5v4h-4"/><path d="M8 12h.01M12 12h.01M16 12h.01"/></svg>',
		label: 'Odpowiedzialność',
		desc: 'Jesteśmy w kontakcie na każdym etapie realizacji. Jasna komunikacja, regularne aktualizacje, żadnych niespodzianek przy wdrożeniu.'
	},
	{
		icon:
			'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l8 3v6c0 5-3.5 8-8 9-4.5-1-8-4-8-9V6z"/><path d="m8.5 12 2.4 2.4L16 9.5"/></svg>',
		label: 'Gwarantowana jakość',
		desc: 'Każda strona przechodzi testy na różnych urządzeniach, audyt szybkości i optymalizację Core Web Vitals przed oddaniem.'
	},
	{
		icon:
			'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M4 13a8 8 0 0 1 16 0"/><rect x="3" y="13" width="4" height="6" rx="1.5"/><rect x="17" y="13" width="4" height="6" rx="1.5"/><path d="M19 19v1a2 2 0 0 1-2 2h-3"/></svg>',
		label: 'Szybkie wsparcie',
		desc: 'Odpowiadamy tego samego dnia roboczego, mailowo lub telefonicznie. Opieka techniczna i aktualizacje dostępne w pakiecie.'
	},
	{
		icon:
			'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21s-7-4.5-7-10a4.5 4.5 0 0 1 8.5-2A4.5 4.5 0 0 1 19 11c0 5.5-7 10-7 10z"/></svg>',
		label: 'Zadowolenie klientów',
		desc: 'Ponad 90% klientów wraca do nas po kolejne projekty. Budujemy długoterminowe relacje, nie jednorazowe transakcje.'
	}
];
---

<section class="bg-brand-bg-light overflow-hidden relative py-8 md:py-[100px]">
	<div class="absolute left-[-60px] top-1/2 w-[350px] h-[350px] bg-shape-3 shape-gem bg-contain bg-no-repeat animate-float-3 pointer-events-none drop-shadow-[0_24px_50px_rgba(128,64,255,0.45)] hidden lg:absolute"></div>
	<div class="max-w-[1700px] mx-auto px-5 md:px-10">
		<div class="grid grid-cols-1 lg:grid-cols-[3fr_2fr] gap-[60px] items-center">

			<Image
				src={vexor2}
				alt="Zespół Vexor przy pracy"
				class="reveal  aspect-video lg:aspect-[4/5] rounded-card object-cover w-full"
				style="--stagger-i:0"
				loading="lazy"
			/>
			<div class="flex flex-col gap-6 order-last lg:order-first">
				<div class="reveal" style="--stagger-i:0">
					<Eyebrow label="Dlaczego Vexor" />
				</div>
				<h2 class="text-h2 reveal" style="--stagger-i:1">
					Tworzymy strony, które generują klientów
				</h2>
				<div class="reveal cv-accordion" style="--stagger-i:2">
					{items.map((item, index) => (
						<div class="cv-item border-b border-brand-border" data-open={index === 0 ? "true" : undefined}>
							<button class="cv-summary flex items-center gap-4 w-full text-left py-4 cursor-pointer">
								<span class="cv-icon w-16 h-16 rounded-2xl flex items-center justify-center bg-white transition-colors duration-300 flex-shrink-0">
									<span
										class="w-8 h-8 text-primary transition-colors duration-300"
										set:html={item.icon}
									/>
								</span>
								<h3 class="cv-label text-h5 font-medium text-brand-muted transition-colors duration-300 flex-1">
									{item.label}
								</h3>
								<span class="cv-indicator w-8 h-8 flex items-center justify-center flex-shrink-0 transition-transform duration-300 text-black">
									<svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
										<line x1="7" y1="2" x2="7" y2="12"/>
										<line x1="2" y1="7" x2="12" y2="7"/>
									</svg>
								</span>
							</button>
							<div class="cv-body">
								<div class="cv-inner">
									<p class="pl-[80px] pb-4 text-xl text-brand-muted leading-relaxed">
										{item.desc}
									</p>
								</div>
							</div>
						</div>
					))}
				</div>
			</div>
		</div>
	</div>
</section>

<script>
	const items = document.querySelectorAll<HTMLElement>('.cv-accordion .cv-item');

	function openItem(item: HTMLElement) {
		item.dataset.open = 'true';
		const body = item.querySelector<HTMLElement>('.cv-body')!;
		body.style.gridTemplateRows = '1fr';
		const icon = item.querySelector<HTMLElement>('.cv-icon')!;
		const label = item.querySelector<HTMLElement>('.cv-label')!;
		const indicator = item.querySelector<HTMLElement>('.cv-indicator')!;
		icon.style.backgroundColor = 'rgba(110,118,255,0.12)';
		label.style.color = 'var(--color-brand-accent, #1a1a2e)';
		indicator.style.transform = 'rotate(45deg)';
	}

	function closeItem(item: HTMLElement) {
		delete item.dataset.open;
		const body = item.querySelector<HTMLElement>('.cv-body')!;
		body.style.gridTemplateRows = '0fr';
		const icon = item.querySelector<HTMLElement>('.cv-icon')!;
		const label = item.querySelector<HTMLElement>('.cv-label')!;
		const indicator = item.querySelector<HTMLElement>('.cv-indicator')!;
		icon.style.backgroundColor = '';
		label.style.color = '';
		indicator.style.transform = '';
	}

	items.forEach((item) => {
		const isInitiallyOpen = item.dataset.open === 'true';
		const body = item.querySelector<HTMLElement>('.cv-body')!;

		if (isInitiallyOpen) {
			body.style.gridTemplateRows = '1fr';
			const icon = item.querySelector<HTMLElement>('.cv-icon')!;
			const label = item.querySelector<HTMLElement>('.cv-label')!;
			const indicator = item.querySelector<HTMLElement>('.cv-indicator')!;
			icon.style.backgroundColor = 'rgba(110,118,255,0.12)';
			label.style.color = 'var(--color-brand-accent, #1a1a2e)';
			indicator.style.transform = 'rotate(45deg)';
		} else {
			body.style.gridTemplateRows = '0fr';
		}

		item.querySelector('.cv-summary')!.addEventListener('click', () => {
			const isOpen = item.dataset.open === 'true';
			items.forEach((other) => {
				if (other !== item && other.dataset.open === 'true') closeItem(other);
			});
			if (isOpen) {
				closeItem(item);
			} else {
				openItem(item);
			}
		});
	});
</script>

<style>
	.cv-body {
		display: grid;
		grid-template-rows: 0fr;
		transition: grid-template-rows 0.38s cubic-bezier(0.16, 1, 0.3, 1);
	}
	.cv-inner {
		overflow: hidden;
	}
	.cv-summary {
		background: none;
		border: none;
		padding-top: 1rem;
		padding-bottom: 1rem;
	}
</style>
