---
// Component: ArrowCircle
// Purpose: Reusable arrow circle icon.
// Props: size, dark
// JS: none

const { size = 36, dark = false } = Astro.props;

const sizeClass =
  size === 28 ? 'w-7 h-7 text-[12px]' : size === 32 ? 'w-8 h-8 text-[13px]' : 'w-9 h-9 text-[14px]';
---

<div
  class:list={[
    'inline-flex items-center justify-center rounded-full font-semibold transition-colors duration-200',
    sizeClass,
    dark ? 'bg-white text-primary' : 'bg-primary text-white'
  ]}
  aria-hidden="true"
>
  →
</div>
