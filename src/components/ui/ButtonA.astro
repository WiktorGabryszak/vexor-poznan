---
// Component: ButtonA
// Purpose: Filled pill CTA with left arrow circle.
// Props: href, label, invert
// JS: none

const { href = '#', label, invert = false, ariaLabel } = Astro.props;
---

<div class:list={['mt-auto rounded-[20px] p-1.5', invert ? 'bg-white' : 'bg-[#636EC8]']}>
	<a
		class:list={[
			'group/btn inline-flex items-center h-12 rounded-2xl pr-6 pl-2 text-[16px] font-semibold leading-[1.625] relative overflow-hidden',
			invert ? 'text-brand-accent' : 'text-white'
		]}
		href={href}
		aria-label={ariaLabel}
	>
		<span class:list={[
			'absolute left-0 top-0 bottom-0 w-12 rounded-2xl transition-all duration-300 ease-[ease] group-hover/btn:w-full',
			invert ? 'bg-primary' : 'bg-white'
		]}></span>
		<span class="relative z-10 inline-flex w-12 h-12 items-center justify-center pr-4">
			<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 32 32" fill="currentColor"
				class:list={[invert ? 'text-white' : 'text-black']}
				aria-hidden="true">
				<path d="M15.52 4.953c-.47.155-.904.523-1.125.956-.109.213-.128.327-.128.758 0 .43.019.546.131.773.101.206.87 1.009 3.384 3.533l3.253 3.266-7.438.014-7.437.014-.267.141a2.097 2.097 0 0 0-.831.834c-.109.213-.129.328-.129.758 0 .431.02.544.129.759.165.323.523.68.845.845l.253.129 7.437.014 7.438.014-3.253 3.266c-2.514 2.524-3.283 3.327-3.384 3.533-.112.227-.131.343-.131.773 0 .594.104.858.489 1.244.386.386.65.49 1.244.49.429 0 .547-.02.773-.131.391-.191 9.972-9.772 10.163-10.163.111-.226.131-.344.131-.773 0-.429-.02-.547-.131-.773-.103-.211-1.155-1.293-4.986-5.129-5.414-5.42-5.101-5.143-5.87-5.172-.235-.009-.487.003-.56.027" />
			</svg>
		</span>
		<span class:list={[
			'relative z-10 capitalize',
			invert ? 'group-hover/btn:text-white' : 'group-hover/btn:text-black'
		]}>{label}</span>
	</a>
</div>
