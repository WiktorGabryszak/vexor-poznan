---
// Component: TeamBanner
// Purpose: Highlight team card with stats and CTA.
// Props: none
// JS: none

import Eyebrow from './ui/Eyebrow.astro';
import ButtonB from './ui/ButtonB.astro';

const stats = [
	{ value: 25, label: 'years experience working' },
	{ value: 890, label: 'projects completed in total' },
	{ value: 92, label: 'success rate in market' }
];
---

<section class="bg-brand-bg-light pb-[100px]">
	<div class="max-w-[900px] mx-auto rounded-section overflow-hidden relative min-h-[420px] bg-team-card">
		<div class="absolute top-[40px] left-[40px] max-w-[380px] z-[2] flex flex-col gap-[18px] md:static md:pt-8 md:px-7">
			<Eyebrow dark={true} label="Who we are" />
			<h2 class="text-h2 text-white">We are a team of creatives</h2>
			<p class="text-white/70">
				We're a team of expert designers, web developers and marketers who've been delivering digital success for more than a decade.
			</p>
		</div>

		<div class="absolute bottom-0 left-0 right-0 bg-black/35 backdrop-blur-sm team-stats flex justify-around items-center gap-6 px-10 py-7 md:static md:mt-8 md:flex-wrap md:justify-start md:px-7 md:pb-7">
			{stats.map((stat) => (
				<div class="flex flex-col items-start gap-1">
					<span class="text-stat text-white inline-flex items-start">
						<span data-count={stat.value}>{stat.value}</span>
						<sup class="text-primary text-[60%] font-extrabold ml-1">+</sup>
					</span>
					<span class="text-[13px] text-white/60">{stat.label}</span>
				</div>
			))}
		</div>
	</div>

	<div class="flex justify-center mt-8">
		<ButtonB label="Meet Our Team" />
	</div>
</section>
