---
// Component: Portfolio
// Purpose: Showcase selected project cards.
// Props: none
// JS: none

import Eyebrow from './ui/Eyebrow.astro';
import ButtonA from './ui/ButtonA.astro';
import { Image } from 'astro:assets';

import imgFabullate   from '../assets/images/projekty-home/Fabullate.png';
import imgFitBox      from '../assets/images/projekty-home/FitBox.png';
import imgGreenwich   from '../assets/images/projekty-home/Greenwich.png';
import imgJennings    from '../assets/images/projekty-home/Jennings Storage.png';
import imgMateo       from '../assets/images/projekty-home/PW Mateo.png';
import imgPadel       from '../assets/images/projekty-home/Padel King.png';

import type { ImageMetadata } from 'astro';

interface Project {
	bg: string;
	img: ImageMetadata;
	logo: string;
	title: string;
	category: string;
	staggerIndex: number;
	link: string;
}

const projects: Project[] = [
	{
		bg: '#12343e',
		img: imgFabullate,
		logo: 'Fabullate',
		title: 'Fabulatte',
		category: 'Web Design & Development',
		staggerIndex: 0,
		link: "/projekty/fabulatte/"
	},
	{
		bg: '#D58E24',
		img: imgFitBox,
		logo: 'FitBox',
		title: 'FitBox',
		category: 'Web Design & Development',
		staggerIndex: 1,
		link: "/projekty/fitbox/"
	},
	{
		bg: '#F30094',
		img: imgGreenwich,
		logo: 'Greenwich',
		title: 'Just Golf Greenwich',
		category: 'Web Design & Development',
		staggerIndex: 2,
		link: "/projekty/greenwich/"
	},
	{
		bg: '#00A68B',
		img: imgJennings,
		logo: 'Jennings',
		title: 'Jennings Storage',
		category: 'Website Redesign',
		staggerIndex: 3,
		link: "/projekty/jennings-storage/"
	},
	{
		bg: '#E4362A',
		img: imgMateo,
		logo: 'PW Mateo',
		title: 'P.W. Mateo',
		category: 'Website Design & Development',
		staggerIndex: 4,
		link: "/projekty/pw-mateo/"
	},
	{
		bg: '#142129',
		img: imgPadel,
		logo: 'Padel King',
		title: 'Padel King',
		category: 'Website Design & Development',
		staggerIndex: 5,
		link: "/projekty/padel-king/"
	}
];
---

<section class="bg-brand-bg-light py-8 md:py-[100px]">
	<div class="max-w-[1700px] mx-auto p-5 md:p-16 rounded-[40px] bg-white relative overflow-hidden">
		<div class="absolute inset-0 bg-portfolio-image bg-cover bg-top opacity-40" aria-hidden="true"></div>
		<div class="relative z-10">
		<div class="grid grid-cols-1 lg:grid-cols-[1fr_auto] gap-6 items-start mb-10">
			<div class="flex flex-col">
				<Eyebrow label="Nasze projekty" />
				<h2 class="text-h2 mt-[14px]">Wybrane projekty</h2>
				<p class="text-xl text-brand-text mt-4 max-w-[720px]">
					Zobacz jak pomagamy firmom zaistnieć w internecie i zdobywać nowych klientów.
				</p>
			</div>
			<div class="justify-self-start lg:justify-self-end">
				<ButtonA href="/projekty/" label="Zobacz wszystkie projekty" invert={false} />
			</div>
		</div>

		<div class="grid grid-cols-1 sm:grid-cols-1 lg:grid-cols-2 xl:grid-cols-3 gap-8">
			{projects.map((project) => (
				<article
					class="group rounded-[20px] overflow-hidden relative cursor-pointer flex flex-col reveal"
					style={`--stagger-i:${project.staggerIndex}; background:${project.bg};`}
				>
					<!-- Image area -->
					<div class="overflow-hidden rounded-b-[20px]">
						<Image
							src={project.img}
							alt={project.title}
							class="w-full object-cover object-top transition-transform duration-500 ease-out group-hover:scale-[1.04]"
							style="height: clamp(250px, 22vw, 300px);"
							loading="lazy"
						/>
					</div>

					<!-- Info area -->
					<div class="px-10 pb-10 pt-5 flex flex-col items-start" style={`background:${project.bg};`}>
						<h5 class="text-white text-h5">{project.title}</h5>
						<p class="text-white/70 text-base font-400 mt-1">{project.category}</p>
						<div class="mt-auto pt-6">
							<a
								class="group/btn inline-flex items-center h-12 rounded-2xl pr-6 pl-2 text-white text-[16px] font-semibold leading-[1.625] relative overflow-hidden"
								href={project.link}
							>
								<span class="absolute left-0 top-0 bottom-0 w-12 rounded-2xl bg-white transition-all duration-300 ease-[ease] group-hover/btn:w-full"></span>
								<span class="relative z-10 inline-flex w-12 h-12 items-center justify-center pr-4">
									<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 32 32" fill="#000000" aria-hidden="true">
										<path d="M15.52 4.953c-.47.155-.904.523-1.125.956-.109.213-.128.327-.128.758 0 .43.019.546.131.773.101.206.87 1.009 3.384 3.533l3.253 3.266-7.438.014-7.437.014-.267.141a2.097 2.097 0 0 0-.831.834c-.109.213-.129.328-.129.758 0 .431.02.544.129.759.165.323.523.68.845.845l.253.129 7.437.014 7.438.014-3.253 3.266c-2.514 2.524-3.283 3.327-3.384 3.533-.112.227-.131.343-.131.773 0 .594.104.858.489 1.244.386.386.65.49 1.244.49.429 0 .547-.02.773-.131.391-.191 9.972-9.772 10.163-10.163.111-.226.131-.344.131-.773 0-.429-.02-.547-.131-.773-.103-.211-1.155-1.293-4.986-5.129-5.414-5.42-5.101-5.143-5.87-5.172-.235-.009-.487.003-.56.027" />
									</svg>
								</span>
								<span class="relative z-10 group-hover/btn:text-black">Zobacz projekt</span>
							</a>
						</div>
					</div>
				</article>
			))}
		</div>

			<div class="mt-10"></div>
		</div>
	</div>
</section>
