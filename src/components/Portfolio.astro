---
// Component: Portfolio
// Purpose: Showcase selected project cards.
// Props: none
// JS: none

import Eyebrow from './ui/Eyebrow.astro';
import ButtonA from './ui/ButtonA.astro';

interface Project {
	bg: string;
	gradient: string;
	logo: string;
	title: string;
	category: string;
	staggerIndex: number;
	link: string;
}

const projects: Project[] = [
	{
		bg: '#12343e',
		gradient: 'linear-gradient(135deg,#1a4a5a,#0d2a35)',
		logo: 'Galileo',
		title: 'UI/UX Design Platform',
		category: 'Development',
		staggerIndex: 0,
		link: "/projekty/ui-ux-design-platform/"
	},
	{
		bg: '#3E122F',
		gradient: 'linear-gradient(135deg,#5a1a45,#2a0a1f)',
		logo: 'Interlock',
		title: 'Social Media Campaigns',
		category: 'Design',
		staggerIndex: 1,
		link: "/projekty/social-media-campaigns/"
	},
	{
		bg: '#526648',
		gradient: 'linear-gradient(135deg,#6a8060,#3a5030)',
		logo: 'Segment',
		title: 'Content Marketing Suite',
		category: 'Development',
		staggerIndex: 2,
		link: "/projekty/content-marketing-suite/"
	},
	{
		bg: '#423b2f',
		gradient: 'linear-gradient(135deg,#5a5040,#2a2018)',
		logo: 'Alt+Shift',
		title: 'SEO & Marketing Tools',
		category: 'Advanced Analytics',
		staggerIndex: 3,
		link: "/projekty/seo-marketing-tools/"
	},
	{
		bg: '#2d2736',
		gradient: 'linear-gradient(135deg,#3d3548,#1d1525)',
		logo: 'Boltshift',
		title: 'Creative Branding Agency',
		category: 'Marketing Strategy',
		staggerIndex: 4,
		link: "/projekty/creative-branding-agency/"
	},
	{
		bg: '#4a0e0f',
		gradient: 'linear-gradient(135deg,#6a1e20,#2a0808)',
		logo: 'Lightbox',
		title: 'Video Production Hub',
		category: 'Technology',
		staggerIndex: 5,
		link: "/projekty/video-production-hub/"
	}
];
---

<section class="bg-brand-bg-light py-[100px]">
	<div class="max-w-[1700px] mx-auto p-16 rounded-[40px] bg-white relative overflow-hidden">
		<div class="absolute inset-0 bg-portfolio-image bg-cover bg-top opacity-40" aria-hidden="true"></div>
		<div class="relative z-10">
		<div class="grid grid-cols-1 lg:grid-cols-[1fr_auto] gap-6 items-start mb-10">
			<div class="flex flex-col">
				<Eyebrow label="Nasze projekty" />
				<h2 class="text-h2 mt-[14px]">Wybrane projekty</h2>
				<p class="text-xl text-brand-text mt-4 max-w-[720px]">
					Zobacz jak pomagamy firmom zaistnieć w internecie i zdobywać nowych klientów.
				</p>
			</div>
			<div class="lg:justify-self-end">
				<ButtonA href="/projekty/" label="Zobacz wszystkie projekty" invert={false} />
			</div>
		</div>

		<div class="grid grid-cols-1 sm:grid-cols-1 lg:grid-cols-2 xl:grid-cols-3 gap-8">
			{projects.map((project) => (
				<article
					class="group rounded-[20px] overflow-hidden min-h-[400px] relative cursor-pointer flex flex-col reveal"
					style={`--stagger-i:${project.staggerIndex}; --project-bg:${project.bg}; --project-gradient:${project.gradient}; background:${project.bg};`}
				>
					<div
						class="relative overflow-hidden min-h-[300px] transition-transform duration-300 ease-out group-hover:scale-[1.04] rounded-b-[20px]"
						style={`background:${project.gradient};`}
					>
						<div class="absolute inset-0 bg-[repeating-linear-gradient(135deg,rgba(255,255,255,.03)_0_1px,transparent_1px_12px)]"></div>
						<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[52px] h-[52px] rounded-full bg-white text-[#333] text-[10px] font-bold flex items-center justify-center shadow-lg z-[2]">
							{project.logo}
						</div>
					</div>
					<div class="px-10 pb-10 pt-5 min-h-[100px] flex flex-col items-start" style={`background:${project.bg};`}>
						<h5 class="text-white text-h5">{project.title}</h5>
						<p class="text-white text-base font-400 mt-1">{project.category}</p>
						<div class="mt-auto pt-6">
					<a
						class="group inline-flex items-center h-12 rounded-2xl pr-6 pl-2 text-white text-[16px] font-semibold leading-[1.625] relative overflow-hidden group"
						href="#"
					>
						<span class="absolute left-0 top-0 bottom-0 w-12 rounded-2xl bg-white transition-all duration-300 ease-[ease] group-hover:w-full"></span>
						<span class="relative z-10 inline-flex w-12 h-12 items-center justify-center pr-4">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 32 32" fill="#000000" aria-hidden="true">
								<path d="M15.52 4.953c-.47.155-.904.523-1.125.956-.109.213-.128.327-.128.758 0 .43.019.546.131.773.101.206.87 1.009 3.384 3.533l3.253 3.266-7.438.014-7.437.014-.267.141a2.097 2.097 0 0 0-.831.834c-.109.213-.129.328-.129.758 0 .431.02.544.129.759.165.323.523.68.845.845l.253.129 7.437.014 7.438.014-3.253 3.266c-2.514 2.524-3.283 3.327-3.384 3.533-.112.227-.131.343-.131.773 0 .594.104.858.489 1.244.386.386.65.49 1.244.49.429 0 .547-.02.773-.131.391-.191 9.972-9.772 10.163-10.163.111-.226.131-.344.131-.773 0-.429-.02-.547-.131-.773-.103-.211-1.155-1.293-4.986-5.129-5.414-5.42-5.101-5.143-5.87-5.172-.235-.009-.487.003-.56.027" />
								<path d="M15.52 4.953c-.47.155-.904.523-1.125.956-.109.213-.128.327-.128.758 0 .43.019.546.131.773.101.206.87 1.009 3.384 3.533l3.253 3.266-7.438.014-7.437.014-.267.141a2.097 2.097 0 0 0-.831.834c-.109.213-.129.328-.129.758 0 .431.02.544.129.759.165.323.523.68.845.845l.253.129 7.437.014 7.438.014-3.253 3.266c-2.514 2.524-3.283 3.327-3.384 3.533-.112.227-.131.343-.131.773 0 .594.104.858.489 1.244.386.386.65.49 1.244.49.429 0 .547-.02.773-.131.391-.191 9.972-9.772 10.163-10.163.111-.226.131-.344.131-.773 0-.429-.02-.547-.131-.773-.103-.211-1.155-1.293-4.986-5.129-5.414-5.42-5.101-5.143-5.87-5.172-.235-.009-.487.003-.56.027" />
							</svg>
						</span>
						<span class="relative z-10 group-hover:text-black">Zobacz projekt</span>
					</a>
				</div>
					</div>
				</article>
			))}
		</div>

			<div class="mt-10"></div>
		</div>
	</div>
</section>
