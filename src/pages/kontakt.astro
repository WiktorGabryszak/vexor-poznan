---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import MobileMenu from '../components/MobileMenu.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Kontakt – Wycena Strony Internetowej | Vexor"
  description="Skontaktuj się z nami i opisz swój projekt. Oddzwonimy lub odpiszemy tego samego dnia roboczego. Bezpłatna wycena strony internetowej w 24h."
  canonicalURL="https://vexordesigns.pl/kontakt/"
  ogImage="https://vexordesigns.pl/og-image.jpg"
>
  <Navbar />
  <MobileMenu />
  <main>

    <!-- Hero -->
    
    <section class="min-h-[50vh] relative flex flex-col justify-center items-center bg-hero-image bg-cover bg-no-repeat text-white">
      <div class="relative z-10 max-w-[1700px] mx-auto px-5 md:px-[47px] py-16 mt-[110px] flex flex-col justify-center items-center gap-5">
        <nav aria-label="Breadcrumb">
          <ol class="inline-flex items-center gap-2 px-4 py-2 rounded-xl  backdrop-blur-md border border-white/10 text-sm text-white/70">
            <li><a href="/" class="hover:text-white transition-colors duration-150">Strona główna</a></li>
            <li aria-hidden="true">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-50"><path d="M9 18l6-6-6-6"/></svg>
            </li>
            <li class="text-white font-medium" aria-current="page">Kontakt</li>
          </ol>
        </nav>
        <h1 class="text-heroSub text-white text-balance reveal" style="--stagger-i:0">
          Porozmawiajmy o Twoim projekcie
        </h1>
        <p class="text-[21px] text-white/80 max-w-[560px] text-pretty reveal font-medium text-center" style="--stagger-i:1">
          Opisz czego potrzebujesz, a my odezwiemy się z wyceną. Zazwyczaj odpowiadamy tego samego dnia roboczego.
        </p>
      </div>
    </section>

    <!-- Contact section -->
    <section class="bg-brand-bg-light py-[80px] md:py-[100px] relative">
      <!-- <div class="absolute inset-0 bg-portfolio-image bg-cover opacity-40" aria-hidden="true"></div> -->
      <div class="max-w-[1700px] mx-auto px-5 md:px-10">
        <div class="grid grid-cols-1 lg:grid-cols-[2fr_3fr] gap-10 lg:gap-[60px] items-start">

          <!-- Left: contact info -->
          <div class="flex flex-col gap-6 reveal" style="--stagger-i:0">
            <div>
              <h2 class="text-h2 font-medium text-brand-accent">Dane kontaktowe</h2>
              <p class="text-brand-text mt-3 text-lg leading-relaxed">
                Nie wiesz czego potrzebujesz? To normalne, napisz krótko o swojej firmie, a my zaproponujemy rozwiązanie i wycenę.
              </p>
            </div>

            <div class="flex flex-col">

              <a href="mailto:kontakt@vexordesigns.pl"
                class="group border-b border-brand-border py-5 flex flex-col gap-3 hover:opacity-80 transition-opacity duration-150">
                <div class="flex items-center gap-4">
                  <span class="w-16 h-16 rounded-2xl bg-primary/10 flex items-center justify-center flex-shrink-0 text-primary">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                      <rect x="2" y="4" width="20" height="16" rx="2"/>
                      <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
                    </svg>
                  </span>
                  <h3 class="text-h5 font-medium text-brand-accent flex-1">Email</h3>
                </div>
                <p class="pl-[80px] text-xl text-brand-muted leading-relaxed">kontakt@vexordesigns.pl</p>
              </a>

              <a href="tel:+48601076883"
                class="group border-b border-brand-border py-5 flex flex-col gap-3 hover:opacity-80 transition-opacity duration-150">
                <div class="flex items-center gap-4">
                  <span class="w-16 h-16 rounded-2xl bg-primary/10 flex items-center justify-center flex-shrink-0 text-primary">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.27h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.91a16 16 0 0 0 6 6l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
                    </svg>
                  </span>
                  <h3 class="text-h5 font-medium text-brand-accent flex-1">Telefon</h3>
                </div>
                <p class="pl-[80px] text-xl text-brand-muted leading-relaxed">+48 601 076 883</p>
              </a>

              <a href="https://www.instagram.com/vexordesigns_official/" target="_blank" rel="noopener noreferrer"
                class="group py-5 flex flex-col gap-3 hover:opacity-80 transition-opacity duration-150">
                <div class="flex items-center gap-4">
                  <span class="w-16 h-16 rounded-2xl bg-primary/10 flex items-center justify-center flex-shrink-0 text-primary">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                      <rect x="2" y="2" width="20" height="20" rx="5"/>
                      <circle cx="12" cy="12" r="4"/>
                      <circle cx="17.5" cy="6.5" r="0.8" fill="currentColor" stroke="none"/>
                    </svg>
                  </span>
                  <h3 class="text-h5 font-medium text-brand-accent flex-1">Instagram</h3>
                </div>
                <p class="pl-[80px] text-xl text-brand-muted leading-relaxed">@vexordesigns_official</p>
              </a>

            

            </div>
          </div>

          <!-- Right: form -->
          <div class="rounded-[32px] overflow-hidden reveal bg-white" style="--stagger-i:1">
            <!-- Gradient header -->
            <div class="px-8 md:px-12 pt-10 pb-8" >
              <h2 class="text-h2 font-500 text-brand-accent leading-[1.1] tracking-[-0.02em]">
                Wyślij wiadomość
              </h2>
            </div>

            <!-- Form body -->
            <div class="px-8 md:px-12 py-8 bg-white" >
              <form
                name="kontakt"
                method="POST"
                action="/kontakt/sukces/"
                class="flex flex-col gap-4"
              >
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                  <input
                    type="text"
                    name="name"
                    placeholder="Imię i nazwisko"
                    required
                    autocomplete="name"
                    class="h-14 px-5 rounded-2xl bg-white border border-gray-200 text-brand-accent placeholder:text-gray-400 text-base focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-all duration-150"
                  />
                  <input
                    type="email"
                    name="email"
                    placeholder="Adres email"
                    required
                    autocomplete="email"
                    class="h-14 px-5 rounded-2xl bg-white border border-gray-200 text-brand-accent placeholder:text-gray-400 text-base focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-all duration-150"
                  />
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                  <input
                  type="tel"
                  name="phone"
                  placeholder="Telefon"
                  required
                  autocomplete="tel"
                  class="h-14 px-5 rounded-2xl bg-white border border-gray-200 text-brand-accent placeholder:text-gray-400 text-base focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-all duration-150"
                />
                <input
                  type="text"
                  name="business"
                  placeholder="Nazwa Firmy"
                  required
                  autocomplete="business"
                  class="h-14 px-5 rounded-2xl bg-white border border-gray-200 text-brand-accent placeholder:text-gray-400 text-base focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-all duration-150"
                />
              </div>

                

                <textarea
                  name="message"
                  rows="5"
                  placeholder="Opisz czego potrzebujesz. Np. jaki typ strony, ile podstron, czy masz już logo i treści..."
                  required
                  class="px-5 py-4 rounded-2xl bg-white border border-gray-200 text-brand-accent placeholder:text-gray-400 text-base focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-all duration-150 resize-none leading-relaxed"
                ></textarea>

                <button
                  type="submit"
                  class="h-14 w-full rounded-2xl bg-primary hover:bg-primary-hover text-white font-semibold text-base transition-colors duration-150 mt-1"
                >
                  Wyślij wiadomość
                </button>

                <p class="text-xs text-brand-muted leading-relaxed text-center">
                  Wysyłając formularz wyrażasz zgodę na przetwarzanie danych osobowych w celu odpowiedzi na Twoje zapytanie.
                </p>
              </form>
            </div>
          </div>

        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>
