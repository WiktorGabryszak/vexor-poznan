---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import MobileMenu from '../../components/MobileMenu.astro';
import Footer from '../../components/Footer.astro';
import ContactCTA from '../../components/ContactCTA.astro';
import Eyebrow from '../../components/ui/Eyebrow.astro';
import ButtonA from '../../components/ui/ButtonA.astro';
import { Image } from 'astro:assets';
import imgAplikacje1 from '../../assets/images/uslugi-aplikacje-1.jpg';
import imgAplikacje2 from '../../assets/images/uslugi-aplikacje-2.jpg';
---

<Layout
  title="Tworzenie Aplikacji Webowych dla Firm | Vexor Designs"
  description="Budujemy dedykowane aplikacje webowe – od MVP po zaawansowane systemy. Integracje API, panele administracyjne, portale klientów."
  canonicalURL="https://stronyinternetowe.net/uslugi/aplikacje-webowe/"
  ogImage="https://stronyinternetowe.net/og-image.jpg"
>
  <Navbar />
  <MobileMenu />
  <main class="bg-brand-bg-light">

    <!-- Hero -->
    <section class="min-h-[50vh] relative flex flex-col justify-center items-center bg-hero-image bg-cover bg-no-repeat text-white">
      <div class="relative z-10 max-w-[1700px] mx-auto px-5 md:px-[47px] py-16 mt-[110px] flex flex-col justify-center items-center gap-5">
        <nav aria-label="Breadcrumb">
          <ol class="inline-flex items-center gap-2 px-4 py-2 rounded-xl backdrop-blur-md border border-white/10 text-sm text-white/70">
            <li><a href="/" class="hover:text-white transition-colors duration-150">Strona główna</a></li>
            <li aria-hidden="true">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-50"><path d="M9 18l6-6-6-6"/></svg>
            </li>
            <li><a href="/uslugi/" class="hover:text-white transition-colors duration-150">Usługi</a></li>
            <li aria-hidden="true">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-50"><path d="M9 18l6-6-6-6"/></svg>
            </li>
            <li class="text-white font-medium" aria-current="page">Aplikacje webowe</li>
          </ol>
        </nav>
        <h1 class="text-heroSub text-white text-balance reveal text-center" style="--stagger-i:0">
          Tworzenie aplikacji webowych dla firm
        </h1>
        <p class="text-[21px] text-white/80 max-w-[600px] text-pretty reveal font-medium text-center" style="--stagger-i:1">
          Budujemy aplikacje dopasowane do procesów w Twojej firmie. Od prostego MVP po rozbudowany system z integracjami API i panelem administracyjnym.
        </p>
        <div class="reveal mt-2" style="--stagger-i:2">
          <ButtonA href="/kontakt/" label="Opisz swój projekt" invert={true} />
        </div>
      </div>
    </section>

    <!-- Kiedy potrzebujesz dedykowanej aplikacji -->
    <section class="bg-white py-[80px] md:py-[100px]">
      <div class="max-w-[1700px] mx-auto px-5 md:px-10">
        <div class="grid grid-cols-1 lg:grid-cols-[3fr_2fr] gap-[60px] items-center">
          <div class="flex flex-col gap-6 reveal order-2 lg:order-1" style="--stagger-i:0">
            <Eyebrow label="Kiedy warto" light={true} />
            <h2 class="text-h2 text-brand-accent">
              Kiedy WordPress i gotowe rozwiązania przestają wystarczać
            </h2>
            <p class="text-brand-text text-lg leading-relaxed">
              Strona internetowa i sklep rozwiązują konkretne potrzeby. Ale jeśli Twoja firma ma specyficzne procesy, zarządza danymi klientów, obsługuje zamówienia w niestandardowy sposób albo potrzebuje panelu dla pracowników lub klientów, gotowe rozwiązania zaczynają być barierą zamiast pomocą.
            </p>
            <p class="text-brand-text text-lg leading-relaxed">
              Portale klientów, systemy do zarządzania zamówieniami, platformy rezerwacyjne i MVP startupów to przykłady projektów, które wymagają dedykowanej aplikacji. Budujesz dokładnie to czego potrzebujesz, z interfejsem dopasowanym do sposobu pracy Twojego zespołu.
            </p>
            <p class="text-brand-text text-lg leading-relaxed">
              Pracujemy w React, Next.js i Node.js. Każdą aplikację projektujemy z myślą o przyszłym rozwoju, żeby dodanie nowej funkcji nie wymagało przepisywania całego systemu.
            </p>
            <div class="self-start"><ButtonA href="/kontakt/" label="Opisz swój projekt" invert={false} /></div>
          </div>
          <Image
            src={imgAplikacje1}
            alt="Tworzenie aplikacji webowych dla firm – Vexor Designs"
            width={744}
            height={497}
            format="webp"
            quality={82}
            loading="lazy"
            decoding="async"
            class="reveal rounded-card lg:aspect-[4/5] object-cover w-full order-1 lg:order-2"
            style="--stagger-i:1"
          />
        </div>
      </div>
    </section>

    <!-- Typy aplikacji -->
    <section class="bg-brand-bg-light py-[80px] md:py-[100px]">
      <div class="max-w-[1700px] mx-auto px-5 md:px-10">
        <div class="text-center mb-14 reveal" style="--stagger-i:0">
          <Eyebrow label="Co budujemy" />
          <h2 class="text-h2 text-brand-accent mt-4">Typy aplikacji webowych, które tworzymy</h2>
          <p class="text-brand-text text-lg mt-4 max-w-[560px] mx-auto leading-relaxed">
            Każdy projekt jest inny, ale większość naszych realizacji mieści się w jednej z poniższych kategorii.
          </p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {[
            {
              icon: `<path fill-rule="evenodd" clip-rule="evenodd" d="M8.25 6.75a3.75 3.75 0 1 1 7.5 0 3.75 3.75 0 0 1-7.5 0ZM15.75 9.75a3 3 0 1 1 6 0 3 3 0 0 1-6 0ZM2.25 9.75a3 3 0 1 1 6 0 3 3 0 0 1-6 0ZM6.31 15.117A6.745 6.745 0 0 1 12 12a6.745 6.745 0 0 1 6.709 7.498.75.75 0 0 1-.372.568A12.696 12.696 0 0 1 12 21.75c-2.305 0-4.47-.612-6.337-1.684a.75.75 0 0 1-.372-.568 6.787 6.787 0 0 1 1.019-4.38Z"/><path d="M5.082 14.254a8.287 8.287 0 0 0-1.308 5.135 9.687 9.687 0 0 1-1.764-.44l-.115-.04a.563.563 0 0 1-.373-.487l-.01-.121a3.75 3.75 0 0 1 3.57-4.047ZM20.226 19.389a8.287 8.287 0 0 0-1.308-5.135 3.75 3.75 0 0 1 3.57 4.047l-.01.121a.563.563 0 0 1-.373.486l-.115.04c-.567.2-1.156.349-1.764.441Z"/>`,
              title: 'Portale klientów',
              desc: 'Panel, w którym Twoi klienci mogą logować się, przeglądać zamówienia, dokumenty, faktury lub status realizacji usługi. Zastępuje ręczną komunikację mailową i oszczędza czas obsługi.'
            },
            {
              icon: `<path fill-rule="evenodd" clip-rule="evenodd" d="M1.5 7.125c0-1.036.84-1.875 1.875-1.875h6c1.036 0 1.875.84 1.875 1.875v3.75c0 1.036-.84 1.875-1.875 1.875h-6A1.875 1.875 0 0 1 1.5 10.875v-3.75Zm12 1.5c0-1.036.84-1.875 1.875-1.875h5.25c1.035 0 1.875.84 1.875 1.875v8.25c0 1.035-.84 1.875-1.875 1.875h-5.25a1.875 1.875 0 0 1-1.875-1.875v-8.25ZM3 16.125c0-1.036.84-1.875 1.875-1.875h5.25c1.036 0 1.875.84 1.875 1.875v2.25c0 1.035-.84 1.875-1.875 1.875h-5.25A1.875 1.875 0 0 1 3 18.375v-2.25Z"/>`,
              title: 'Systemy CRM i panele',
              desc: 'Dedykowane narzędzia do zarządzania klientami, leadami, projektami lub procesami sprzedaży. Zbudowane pod Twój workflow, nie na odwrót. Łatwe do rozbudowy o nowe moduły.'
            },
            {
              icon: `<path d="M9.315 7.584C12.195 3.883 16.695 1.5 21.75 1.5a.75.75 0 0 1 .75.75c0 5.056-2.383 9.555-6.084 12.436A6.75 6.75 0 0 1 9.75 22.5a.75.75 0 0 1-.75-.75v-4.131A15.838 15.838 0 0 1 6.382 15H2.25a.75.75 0 0 1-.75-.75 6.75 6.75 0 0 1 7.815-6.666ZM15 6.75a2.25 2.25 0 1 0 0 4.5 2.25 2.25 0 0 0 0-4.5Z"/><path d="M5.26 17.242a.75.75 0 1 0-.897-1.203 5.243 5.243 0 0 0-2.05 5.022.75.75 0 0 0 .625.627 5.243 5.243 0 0 0 5.022-2.051.75.75 0 1 0-1.202-.897 3.744 3.744 0 0 1-3.008 1.51c0-1.23.592-2.323 1.51-3.008Z"/>`,
              title: 'MVP startupów',
              desc: 'Minimalna wersja produktu do walidacji pomysłu z prawdziwymi użytkownikami. Budujemy szybko, z myślą o łatwym dodawaniu funkcji po zebraniu pierwszego feedbacku. Pomagamy też zaplanować architekturę pod skalowanie.'
            },
            {
              icon: `<path fill-rule="evenodd" clip-rule="evenodd" d="M11.078 2.25c-.917 0-1.699.663-1.85 1.567L9.05 4.889c-.02.12-.115.26-.297.348a7.493 7.493 0 0 0-.986.57c-.166.115-.334.126-.45.083L6.3 5.508a1.875 1.875 0 0 0-2.282.819l-.922 1.597a1.875 1.875 0 0 0 .432 2.385l.84.692c.095.078.17.229.154.43a7.598 7.598 0 0 0 0 1.139c.015.2-.059.352-.153.43l-.841.692a1.875 1.875 0 0 0-.432 2.385l.922 1.597a1.875 1.875 0 0 0 2.282.818l1.019-.382c.115-.043.283-.031.45.082.312.214.641.405.985.57.182.088.277.228.297.35l.178 1.071c.151.904.933 1.567 1.85 1.567h1.844c.916 0 1.699-.663 1.85-1.567l.178-1.072c.02-.12.114-.26.297-.349.344-.165.673-.356.985-.57.167-.114.335-.125.45-.082l1.02.382a1.875 1.875 0 0 0 2.28-.819l.923-1.597a1.875 1.875 0 0 0-.432-2.385l-.84-.692c-.095-.078-.17-.229-.154-.43a7.614 7.614 0 0 0 0-1.139c-.016-.2.059-.352.153-.43l.84-.692c.708-.582.891-1.59.433-2.385l-.922-1.597a1.875 1.875 0 0 0-2.282-.818l-1.02.382c-.114.043-.282.031-.449-.083a7.49 7.49 0 0 0-.985-.57c-.183-.087-.277-.227-.297-.348l-.179-1.072a1.875 1.875 0 0 0-1.85-1.567h-1.843ZM12 15.75a3.75 3.75 0 1 0 0-7.5 3.75 3.75 0 0 0 0 7.5Z"/>`,
              title: 'Integracje API i automatyzacje',
              desc: 'Łączymy różne systemy w jeden spójny ekosystem. Integracje z ERP, systemami magazynowymi, bramkami płatności i zewnętrznymi API. Eliminujemy ręczne przepisywanie danych między systemami.'
            },
          ].map((feat, i) => (
            <div class="bg-white rounded-[24px] p-7 flex flex-col min-h-[300px] reveal gap-16" style={`--stagger-i:${i}`}>
              <span class="w-16 h-16 rounded-2xl flex items-center justify-center bg-brand-bg-light flex-shrink-0">
                <svg class="w-8 h-8 text-primary" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg" set:html={feat.icon}></svg>
              </span>
              <div class="flex-1"></div>
              <div class="flex flex-col gap-2 mt-6">
                <h3 class="text-h5 font-semibold text-brand-accent leading-snug">{feat.title}</h3>
                <p class="text-brand-text leading-relaxed text-sm">{feat.desc}</p>
              </div>
            </div>
          ))}

          <!-- CTA card -->
          <div class="lg:col-span-4 rounded-[24px] p-8 flex flex-col sm:flex-row sm:items-end justify-between gap-6 min-h-[200px] relative overflow-hidden reveal" style="--stagger-i:4; background: linear-gradient(135deg, #1a1a3e 0%, #2d2d6b 60%, #3d3d8f 100%);">
            <div class="flex flex-col gap-4">
              <span class="inline-flex items-center gap-2 text-white text-sm font-medium">
                <span class="w-1.5 h-1.5 rounded-sm bg-primary flex-shrink-0"></span>
                Dlaczego Vexor
              </span>
              <h3 class="text-h2 text-white max-w-[500px]">
                Masz pomysł na aplikację? Opisz nam projekt
              </h3>
            </div>
            <div class="flex-shrink-0"><ButtonA href="/kontakt/" label="Opisz projekt" invert={true} /></div>
          </div>
        </div>
      </div>
    </section>

    <!-- Proces 4 etapy -->
    <section class="bg-brand-bg-light py-8 md:py-[100px]">
      <div class="max-w-[1700px] mx-auto px-5 md:px-10">
        <div class="flex flex-col justify-center items-center gap-6 lg:gap-[60px] mb-[60px]">
          <div class="flex justify-center w-full">
            <Eyebrow label="Jak pracujemy" />
          </div>
          <div>
            <h2 class="text-h2 text-brand-accent text-center">4 etapy tworzenia aplikacji webowej</h2>
            <p class="text-xl text-brand-text max-w-[520px] mt-[14px] text-center mx-auto">
              Każdy projekt zaczyna się od zrozumienia Twojego problemu, a kończy na gotowej aplikacji z dokumentacją i przekazaniem dostępów.
            </p>
          </div>
        </div>

        <div class="relative mt-[60px] border-t border-brand-border">
          <div class="hidden lg:flex absolute top-1/2 left-1/4 -translate-x-1/2 -translate-y-1/2 w-[52px] h-[52px] bg-white rounded-2xl shadow-sm items-center justify-center z-10" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 32 32" fill="currentColor"><path d="M15.52 4.953c-.47.155-.904.523-1.125.956-.109.213-.128.327-.128.758 0 .43.019.546.131.773.101.206.87 1.009 3.384 3.533l3.253 3.266-7.438.014-7.437.014-.267.141a2.097 2.097 0 0 0-.831.834c-.109.213-.129.328-.129.758 0 .431.02.544.129.759.165.323.523.68.845.845l.253.129 7.437.014 7.438.014-3.253 3.266c-2.514 2.524-3.283 3.327-3.384 3.533-.112.227-.131.343-.131.773 0 .594.104.858.489 1.244.386.386.65.49 1.244.49.429 0 .547-.02.773-.131.391-.191 9.972-9.772 10.163-10.163.111-.226.131-.344.131-.773 0-.429-.02-.547-.131-.773-.103-.211-1.155-1.293-4.986-5.129-5.414-5.42-5.101-5.143-5.87-5.172-.235-.009-.487.003-.56.027" /></svg>
          </div>
          <div class="hidden lg:flex absolute top-1/2 left-2/4 -translate-x-1/2 -translate-y-1/2 w-[52px] h-[52px] bg-white rounded-2xl shadow-sm items-center justify-center z-10" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 32 32" fill="currentColor"><path d="M15.52 4.953c-.47.155-.904.523-1.125.956-.109.213-.128.327-.128.758 0 .43.019.546.131.773.101.206.87 1.009 3.384 3.533l3.253 3.266-7.438.014-7.437.014-.267.141a2.097 2.097 0 0 0-.831.834c-.109.213-.129.328-.129.758 0 .431.02.544.129.759.165.323.523.68.845.845l.253.129 7.437.014 7.438.014-3.253 3.266c-2.514 2.524-3.283 3.327-3.384 3.533-.112.227-.131.343-.131.773 0 .594.104.858.489 1.244.386.386.65.49 1.244.49.429 0 .547-.02.773-.131.391-.191 9.972-9.772 10.163-10.163.111-.226.131-.344.131-.773 0-.429-.02-.547-.131-.773-.103-.211-1.155-1.293-4.986-5.129-5.414-5.42-5.101-5.143-5.87-5.172-.235-.009-.487.003-.56.027" /></svg>
          </div>
          <div class="hidden lg:flex absolute top-1/2 left-3/4 -translate-x-1/2 -translate-y-1/2 w-[52px] h-[52px] bg-white rounded-2xl shadow-sm items-center justify-center z-10" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 32 32" fill="currentColor"><path d="M15.52 4.953c-.47.155-.904.523-1.125.956-.109.213-.128.327-.128.758 0 .43.019.546.131.773.101.206.87 1.009 3.384 3.533l3.253 3.266-7.438.014-7.437.014-.267.141a2.097 2.097 0 0 0-.831.834c-.109.213-.129.328-.129.758 0 .431.02.544.129.759.165.323.523.68.845.845l.253.129 7.437.014 7.438.014-3.253 3.266c-2.514 2.524-3.283 3.327-3.384 3.533-.112.227-.131.343-.131.773 0 .594.104.858.489 1.244.386.386.65.49 1.244.49.429 0 .547-.02.773-.131.391-.191 9.972-9.772 10.163-10.163.111-.226.131-.344.131-.773 0-.429-.02-.547-.131-.773-.103-.211-1.155-1.293-4.986-5.129-5.414-5.42-5.101-5.143-5.87-5.172-.235-.009-.487.003-.56.027" /></svg>
          </div>

          <div class="grid grid-cols-1 lg:grid-cols-4">
            {[
              {
                num: '01',
                title: 'Discovery',
                desc: 'Rozmawiamy o Twoich celach, procesach biznesowych i użytkownikach. Mapujemy wymagania funkcjonalne i techniczne. Efektem jest specyfikacja projektu i wycena z harmonogramem.'
              },
              {
                num: '02',
                title: 'Projekt UX',
                desc: 'Tworzymy makiety i prototypy interfejsu. Zanim napiszemy jedną linię kodu, upewniamy się, że architektura informacji i przepływ użytkownika są logiczne i zgodne z Twoimi oczekiwaniami.'
              },
              {
                num: '03',
                title: 'Budowa',
                desc: 'Kodujemy aplikację w iteracjach. Po każdym etapie dostajesz dostęp do środowiska testowego, żeby śledzić postęp i dawać feedback na bieżąco, zanim skończymy cały projekt.'
              },
              {
                num: '04',
                title: 'Wdrożenie',
                desc: 'Uruchamiamy aplikację na produkcji, konfigurujemy monitorowanie i przekazujemy dokumentację. Przez pierwsze 60 dni jesteśmy do dyspozycji bez dodatkowych opłat za zgłoszone błędy.'
              },
            ].map((step, index) => (
              <div class:list={[
                'group relative px-8 pt-[100px] pb-16 text-center overflow-hidden',
                index < 3 ? 'border-b lg:border-b-0 lg:border-r border-brand-border' : ''
              ]}>
                <div class="absolute top-6 left-0 right-0 select-none pointer-events-none text-center z-[2]" aria-hidden="true">
                  <span class="relative block text-[150px] font-black leading-[0.75em]">
                    <span class="absolute inset-0 flex justify-center bg-gradient-to-b from-primary via-primary/40 to-transparent bg-clip-text text-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 border-none">{step.num}</span>
                    <span class="group-hover:opacity-0 transition-opacity duration-300" style="background: -webkit-linear-gradient(90deg, rgba(0,0,0,0) 20%, #DFDEE5 100%); -webkit-background-clip: text; -webkit-text-stroke: 4px transparent; color: transparent;">{step.num}</span>
                  </span>
                </div>
                <h3 class="relative z-[50] text-h5 text-brand-accent mb-4 leading-snug">{step.title}</h3>
                <p class="relative z-[1] text-base text-brand-muted leading-relaxed max-w-[240px] mx-auto">{step.desc}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Jak wyceniamy -->
    <section class="py-[80px] md:py-[100px] mx-3 rounded-[40px] relative overflow-hidden" style="background-image: url('/h7_bg2.jpg'); background-size: cover; background-position: center;">
      <div class="absolute inset-0 bg-black/55" aria-hidden="true"></div>
      <div class="relative z-10 max-w-[1700px] mx-auto px-5 md:px-10">
        <div class="grid grid-cols-1 lg:grid-cols-[2fr_3fr] gap-[60px] items-center">

          <Image
            src={imgAplikacje2}
            alt="Wycena aplikacji webowej – Vexor Designs"
            width={744}
            height={418}
            format="webp"
            quality={82}
            loading="lazy"
            decoding="async"
            class="reveal rounded-[28px] aspect-video lg:aspect-[4/5] object-cover w-full"
            style="--stagger-i:0"
          />

          <div class="flex flex-col gap-6 reveal" style="--stagger-i:1">
            <Eyebrow dark={true} label="Dlaczego Vexor" />

            <h2 class="text-h2 text-white">
              Wycena aplikacji po opisaniu projektu
            </h2>

            <p class="text-white/70 text-lg leading-relaxed">
              Każdy projekt jest inny, dlatego nie stosujemy sztywnych pakietów cenowych. Wycena zależy od zakresu funkcjonalności, liczby integracji i złożoności interfejsu.
            </p>

            <div class="flex flex-col gap-5 mt-2">
              <div class="flex items-center gap-4">
                <span class="w-16 h-16 rounded-2xl flex items-center justify-center flex-shrink-0" style="background: rgba(255,255,255,0.12)">
                  <svg class="w-8 h-8 text-white" viewBox="0 0 24 24" fill="currentColor">
                    <path fill-rule="evenodd" d="M12 1.5a5.25 5.25 0 0 0-5.25 5.25v3a3 3 0 0 0-3 3v6.75a3 3 0 0 0 3 3h10.5a3 3 0 0 0 3-3v-6.75a3 3 0 0 0-3-3v-3c0-2.9-2.35-5.25-5.25-5.25Zm3.75 8.25v-3a3.75 3.75 0 1 0-7.5 0v3h7.5Z" clip-rule="evenodd"/>
                  </svg>
                </span>
                <div>
                  <h3 class="text-white font-semibold text-[18px] leading-snug">Bez ukrytych kosztów</h3>
