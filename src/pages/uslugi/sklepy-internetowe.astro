---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import MobileMenu from '../../components/MobileMenu.astro';
import Footer from '../../components/Footer.astro';
import ContactCTA from '../../components/ContactCTA.astro';
import Eyebrow from '../../components/ui/Eyebrow.astro';
import ButtonA from '../../components/ui/ButtonA.astro';
import { Image } from 'astro:assets';
import imgSklepy1 from '../../assets/images/uslugi-sklepy-1.jpg';
import imgSklepy2 from '../../assets/images/uslugi-sklepy-2.jpg';
---

<Layout
  title="Tworzenie Sklepów Internetowych WooCommerce | Vexor Designs"
  description="Wdrażamy sklepy WooCommerce z integracją płatności, zarządzaniem produktami i pełnym wsparciem technicznym. Bezpłatna wycena w 24 godziny."
  canonicalURL="https://stronyinternetowe.net/uslugi/sklepy-internetowe/"
  ogImage="https://stronyinternetowe.net/og-image.jpg"
>
  <Navbar />
  <MobileMenu />
  <main class="bg-brand-bg-light">

    <!-- Hero -->
    <section class="min-h-[50vh] relative flex flex-col justify-center items-center bg-hero-image bg-cover bg-no-repeat text-white">
      <div class="relative z-10 max-w-[1700px] mx-auto px-5 md:px-[47px] py-16 mt-[110px] flex flex-col justify-center items-center gap-5">
        <nav aria-label="Breadcrumb">
          <ol class="inline-flex items-center gap-2 px-4 py-2 rounded-xl backdrop-blur-md border border-white/10 text-sm text-white/70">
            <li><a href="/" class="hover:text-white transition-colors duration-150">Strona główna</a></li>
            <li aria-hidden="true">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-50"><path d="M9 18l6-6-6-6"/></svg>
            </li>
            <li><a href="/uslugi/" class="hover:text-white transition-colors duration-150">Usługi</a></li>
            <li aria-hidden="true">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-50"><path d="M9 18l6-6-6-6"/></svg>
            </li>
            <li class="text-white font-medium" aria-current="page">Sklepy internetowe</li>
          </ol>
        </nav>
        <h1 class="text-heroSub text-white text-balance reveal text-center" style="--stagger-i:0">
          Tworzenie sklepów internetowych WooCommerce
        </h1>
        <p class="text-[21px] text-white/80 max-w-[600px] text-pretty reveal font-medium text-center" style="--stagger-i:1">
          Wdrażamy sklepy z integracją Przelewy24 i Stripe, zarządzaniem produktami i pełnym certyfikatem SSL.
        </p>
        <div class="reveal mt-2" style="--stagger-i:2">
          <ButtonA href="/kontakt/" label="Bezpłatna wycena sklepu" invert={true} />
        </div>
      </div>
    </section>

    <!-- Sklep, który sprzedaje -->
    <section class="bg-white py-[80px] md:py-[100px]">
      <div class="max-w-[1700px] mx-auto px-5 md:px-10">
        <div class="grid grid-cols-1 lg:grid-cols-[3fr_2fr] gap-[60px] items-center">
          <div class="flex flex-col gap-6 reveal order-2 lg:order-1" style="--stagger-i:0">
            <Eyebrow label="Sklep, który sprzedaje" light={true} />
            <h2 class="text-h2 text-brand-accent">
              Sklep internetowy to inwestycja, która pracuje na Twój zysk
            </h2>
            <p class="text-brand-text text-lg leading-relaxed">
              Sklep internetowy pozwala sprzedawać bez pośredników, całą dobę, do klientów z całego kraju. To inwestycja, która zwraca się każdego dnia. Kluczem jest sklep który działa szybko, wygląda profesjonalnie i nie sprawia klientom kłopotów przy składaniu zamówienia.
            </p>
            <p class="text-brand-text text-lg leading-relaxed">
              WooCommerce daje pełną kontrolę nad produktami, zamówieniami i wyglądem sklepu bez stałych opłat za licencję. Integracja z Przelewy24 i Stripe to standard w każdym wdrożeniu. Możesz zarządzać sklepem samodzielnie bez wiedzy technicznej od pierwszego dnia po uruchomieniu.
            </p>
            <p class="text-brand-text text-lg leading-relaxed">
              Wdrażamy sklepy dla firm z Polski sprzedających zarówno lokalnie, jak i na eksport. Niezależnie od tego czy masz 10 produktów czy tysiące, dobieramy architekturę która działa szybko i jest łatwa w codziennym zarządzaniu.
            </p>
            <div class="self-start"><ButtonA href="/kontakt/" label="Zapytaj o wycenę" invert={false} /></div>
          </div>
          <Image
            src={imgSklepy1}
            alt="Tworzenie sklepów internetowych WooCommerce – Vexor Designs"
            width={744}
            height={496}
            format="webp"
            quality={82}
            loading="lazy"
            decoding="async"
            class="reveal rounded-card lg:aspect-[4/5] object-cover w-full order-1 lg:order-2"
            style="--stagger-i:1"
          />
        </div>
      </div>
    </section>

    <!-- Funkcje sklepu -->
    <section class="bg-brand-bg-light py-[80px] md:py-[100px]">
      <div class="max-w-[1700px] mx-auto px-5 md:px-10">
        <div class="text-center mb-14 reveal" style="--stagger-i:0">
          <Eyebrow label="Funkcjonalności" />
          <h2 class="text-h2 text-brand-accent mt-4">Co zawiera każdy sklep od Vexor</h2>
          <p class="text-brand-text text-lg mt-4 max-w-[560px] mx-auto leading-relaxed">
            Poniższe funkcje są standardem w każdym sklepie, który wdrażamy. Nie doliczamy za integracje płatności ani certyfikat SSL.
          </p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {[
            {
              icon: `<path d="M4.5 3.75a3 3 0 0 0-3 3v.75h21v-.75a3 3 0 0 0-3-3h-15Z"/><path fill-rule="evenodd" d="M22.5 9.75h-21v7.5a3 3 0 0 0 3 3h15a3 3 0 0 0 3-3v-7.5Zm-18 3.75a.75.75 0 0 1 .75-.75h6a.75.75 0 0 1 0 1.5h-6a.75.75 0 0 1-.75-.75Zm.75 2.25a.75.75 0 0 0 0 1.5h3a.75.75 0 0 0 0-1.5h-3Z" clip-rule="evenodd"/>`,
              title: 'Przelewy24 i Stripe',
              desc: 'Konfigurujemy obie bramki płatności, żeby Twoi klienci mogli płacić kartą, BLIK-iem, szybkim przelewem i Apple Pay. Pełna obsługa płatności od razu po wdrożeniu.'
            },
            {
              icon: `<path fill-rule="evenodd" clip-rule="evenodd" d="M7.5 6v.75H5.513c-.96 0-1.764.724-1.865 1.679l-1.263 12A1.875 1.875 0 0 0 4.25 22.5h15.5a1.875 1.875 0 0 0 1.865-2.071l-1.263-12a1.875 1.875 0 0 0-1.865-1.679H16.5V6a4.5 4.5 0 1 0-9 0ZM12 3a3 3 0 0 0-3 3v.75h6V6a3 3 0 0 0-3-3Zm-3 8.25a3 3 0 1 0 6 0 3 3 0 0 0-6 0Z"/>`,
              title: 'Zarządzanie produktami',
              desc: 'Intuicyjny panel do dodawania produktów, wariantów (rozmiar, kolor), zdjęć, opisów i stanów magazynowych. Możesz zarządzać katalogiem samodzielnie bez wiedzy technicznej.'
            },
            {
              icon: `<path d="M2.25 2.25a.75.75 0 0 0 0 1.5h1.386c.17 0 .318.114.362.278l2.558 9.592a3.752 3.752 0 0 0-2.806 3.63c0 .414.336.75.75.75h15.75a.75.75 0 0 0 0-1.5H5.378A2.25 2.25 0 0 1 7.5 15h11.218a.75.75 0 0 0 .674-.421 60.358 60.358 0 0 0 2.96-7.228.75.75 0 0 0-.525-.965A60.864 60.864 0 0 0 5.68 4.509l-.232-.867A1.875 1.875 0 0 0 3.636 2.25H2.25ZM3.75 20.25a1.5 1.5 0 1 1 3 0 1.5 1.5 0 0 1-3 0ZM16.5 20.25a1.5 1.5 0 1 1 3 0 1.5 1.5 0 0 1-3 0Z"/>`,
              title: 'Koszyk i zakupowy',
              desc: 'Zaprojektowany pod konwersję koszyk i uproszczony checkout. Klient może złożyć zamówienie w 3 krokach, bez zakładania konta, co zmniejsza liczbę porzuconych koszyków.'
            },
            {
              icon: `<path fill-rule="evenodd" clip-rule="evenodd" d="M5.625 1.5c-1.036 0-1.875.84-1.875 1.875v17.25c0 1.035.84 1.875 1.875 1.875h12.75c1.035 0 1.875-.84 1.875-1.875V12.75A3.75 3.75 0 0 0 16.5 9h-1.875a1.875 1.875 0 0 1-1.875-1.875V5.25A3.75 3.75 0 0 0 9 1.5H5.625ZM7.5 15a.75.75 0 0 1 .75-.75h7.5a.75.75 0 0 1 0 1.5h-7.5A.75.75 0 0 1 7.5 15Zm.75-6.75a.75.75 0 0 0 0 1.5H12a.75.75 0 0 0 0-1.5H8.25Z"/><path d="M12.971 1.816A5.23 5.23 0 0 1 14.25 5.25v1.875c0 .207.168.375.375.375H16.5a5.23 5.23 0 0 1 3.434 1.279 9.768 9.768 0 0 0-6.963-6.963Z"/>`,
              title: 'Zarządzanie zamówieniami',
              desc: 'Przejrzysty panel zamówień z możliwością zmiany statusów, wystawiania faktur i automatycznych powiadomień e-mail do klientów po każdym etapie realizacji.'
            },
            {
              icon: `<path fill-rule="evenodd" clip-rule="evenodd" d="M12 1.5a5.25 5.25 0 0 0-5.25 5.25v3a3 3 0 0 0-3 3v6.75a3 3 0 0 0 3 3h10.5a3 3 0 0 0 3-3v-6.75a3 3 0 0 0-3-3v-3c0-2.9-2.35-5.25-5.25-5.25Zm3.75 8.25v-3a3.75 3.75 0 1 0-7.5 0v3h7.5Z"/>`,
              title: 'Certyfikat SSL',
              desc: 'SSL jest obowiązkowy w sklepie internetowym. Szyfruje dane klientów, zwiększa zaufanie i jest wymagany przez bramki płatności. Instalujemy i odnawiamy go za Ciebie.'
            },
            {
              icon: `<path fill-rule="evenodd" clip-rule="evenodd" d="M10.5 3.75a6.75 6.75 0 1 0 0 13.5 6.75 6.75 0 0 0 0-13.5ZM2.25 10.5a8.25 8.25 0 1 1 14.59 5.28l4.69 4.69a.75.75 0 1 1-1.06 1.06l-4.69-4.69A8.25 8.25 0 0 1 2.25 10.5Z"/>`,
              title: 'SEO dla sklepu',
              desc: 'Konfigurujemy SEO na poziomie kategorii i produktów: przyjazne adresy URL, meta tagi, dane strukturalne produktów (rich snippets) i mapy witryny. Twoje produkty są widoczne w Google Shopping.'
            },
          ].map((feat, i) => (
            <div class="bg-white rounded-[24px] p-7 flex flex-col min-h-[300px] reveal gap-16" style={`--stagger-i:${i}`}>
              <span class="w-16 h-16 rounded-2xl flex items-center justify-center bg-brand-bg-light flex-shrink-0">
                <svg class="w-8 h-8 text-primary" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg" set:html={feat.icon}></svg>
              </span>
              <div class="flex-1"></div>
              <div class="flex flex-col gap-2 mt-6">
                <h3 class="text-h5 font-semibold text-brand-accent leading-snug">{feat.title}</h3>
                <p class="text-brand-text leading-relaxed text-sm">{feat.desc}</p>
              </div>
            </div>
          ))}

          <!-- CTA card -->
          <div class="lg:col-span-2 rounded-[24px] p-8 flex flex-col justify-between min-h-[300px] relative overflow-hidden reveal" style="--stagger-i:6; background: linear-gradient(135deg, #1a1a3e 0%, #2d2d6b 60%, #3d3d8f 100%);">
            <span class="inline-flex items-center gap-2 text-white text-sm font-medium">
              <span class="w-1.5 h-1.5 rounded-sm bg-primary flex-shrink-0"></span>
              Dlaczego Vexor
            </span>
            <div class="flex flex-col gap-6">
              <h3 class="text-h2 text-white">
                Sklep internetowy dopasowany do Twojej firmy
              </h3>
              <div class="self-start"><ButtonA href="/kontakt/" label="Zamów sklep" invert={true} /></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Proces wdrożenia -->
    <section class="bg-brand-bg-light py-8 md:py-[100px]">
      <div class="max-w-[1700px] mx-auto px-5 md:px-10">
        <div class="flex flex-col justify-center items-center gap-6 lg:gap-[60px] mb-[60px]">
          <div class="flex justify-center w-full">
            <Eyebrow label="Jak pracujemy" />
          </div>
          <div>
            <h2 class="text-h2 text-brand-accent text-center">4 etapy wdrożenia sklepu internetowego</h2>
            <p class="text-xl text-brand-text max-w-[520px] mt-[14px] text-center mx-auto">
              Przejrzysty proces od pierwszego briefu do gotowego sklepu. Oto jak przebiega każde wdrożenie.
            </p>
          </div>
        </div>

        <div class="relative mt-[60px] border-t border-brand-border">
          <div class="hidden lg:flex absolute top-1/2 left-1/4 -translate-x-1/2 -translate-y-1/2 w-[52px] h-[52px] bg-white rounded-2xl shadow-sm items-center justify-center z-10" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 32 32" fill="currentColor"><path d="M15.52 4.953c-.47.155-.904.523-1.125.956-.109.213-.128.327-.128.758 0 .43.019.546.131.773.101.206.87 1.009 3.384 3.533l3.253 3.266-7.438.014-7.437.014-.267.141a2.097 2.097 0 0 0-.831.834c-.109.213-.129.328-.129.758 0 .431.02.544.129.759.165.323.523.68.845.845l.253.129 7.437.014 7.438.014-3.253 3.266c-2.514 2.524-3.283 3.327-3.384 3.533-.112.227-.131.343-.131.773 0 .594.104.858.489 1.244.386.386.65.49 1.244.49.429 0 .547-.02.773-.131.391-.191 9.972-9.772 10.163-10.163.111-.226.131-.344.131-.773 0-.429-.02-.547-.131-.773-.103-.211-1.155-1.293-4.986-5.129-5.414-5.42-5.101-5.143-5.87-5.172-.235-.009-.487.003-.56.027" /></svg>
          </div>
          <div class="hidden lg:flex absolute top-1/2 left-2/4 -translate-x-1/2 -translate-y-1/2 w-[52px] h-[52px] bg-white rounded-2xl shadow-sm items-center justify-center z-10" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 32 32" fill="currentColor"><path d="M15.52 4.953c-.47.155-.904.523-1.125.956-.109.213-.128.327-.128.758 0 .43.019.546.131.773.101.206.87 1.009 3.384 3.533l3.253 3.266-7.438.014-7.437.014-.267.141a2.097 2.097 0 0 0-.831.834c-.109.213-.129.328-.129.758 0 .431.02.544.129.759.165.323.523.68.845.845l.253.129 7.437.014 7.438.014-3.253 3.266c-2.514 2.524-3.283 3.327-3.384 3.533-.112.227-.131.343-.131.773 0 .594.104.858.489 1.244.386.386.65.49 1.244.49.429 0 .547-.02.773-.131.391-.191 9.972-9.772 10.163-10.163.111-.226.131-.344.131-.773 0-.429-.02-.547-.131-.773-.103-.211-1.155-1.293-4.986-5.129-5.414-5.42-5.101-5.143-5.87-5.172-.235-.009-.487.003-.56.027" /></svg>
          </div>
          <div class="hidden lg:flex absolute top-1/2 left-3/4 -translate-x-1/2 -translate-y-1/2 w-[52px] h-[52px] bg-white rounded-2xl shadow-sm items-center justify-center z-10" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 32 32" fill="currentColor"><path d="M15.52 4.953c-.47.155-.904.523-1.125.956-.109.213-.128.327-.128.758 0 .43.019.546.131.773.101.206.87 1.009 3.384 3.533l3.253 3.266-7.438.014-7.437.014-.267.141a2.097 2.097 0 0 0-.831.834c-.109.213-.129.328-.129.758 0 .431.02.544.129.759.165.323.523.68.845.845l.253.129 7.437.014 7.438.014-3.253 3.266c-2.514 2.524-3.283 3.327-3.384 3.533-.112.227-.131.343-.131.773 0 .594.104.858.489 1.244.386.386.65.49 1.244.49.429 0 .547-.02.773-.131.391-.191 9.972-9.772 10.163-10.163.111-.226.131-.344.131-.773 0-.429-.02-.547-.131-.773-.103-.211-1.155-1.293-4.986-5.129-5.414-5.42-5.101-5.143-5.87-5.172-.235-.009-.487.003-.56.027" /></svg>
          </div>

          <div class="grid grid-cols-1 lg:grid-cols-4">
            {[
              {
                num: '01',
                title: 'Brief i wycena',
                desc: 'Rozmawiamy o Twoich produktach, grupie docelowej i wymaganiach technicznych. W ciągu 24 godzin dostajesz szczegółową wycenę i harmonogram.'
              },
              {
                num: '02',
                title: 'Projekt graficzny',
                desc: 'Tworzymy makiety i projekt wizualny sklepu. Omawiamy go razem, nanosisz poprawki, a my robimy ostateczną wersję zanim zaczniemy kodować.'
              },
              {
                num: '03',
                title: 'Wdrożenie i konfiguracja',
                desc: 'Kodujemy sklep, konfigurujemy WooCommerce, integrujemy płatności, ustawiamy metody dostawy i wgrywamy pierwsze produkty. Testujemy każdy element.'
              },
              {
                num: '04',
                title: 'Szkolenie i launch',
                desc: 'Pokazujemy jak zarządzać sklepem, produktami i zamówieniami. Przekazujemy sklep na domenę produkcyjną i jesteśmy do dyspozycji przez pierwsze 30 dni po wdrożeniu.'
              },
            ].map((step, index) => (
              <div class:list={[
                'group relative px-8 pt-[100px] pb-16 text-center overflow-hidden',
                index < 3 ? 'border-b lg:border-b-0 lg:border-r border-brand-border' : ''
              ]}>
                <div class="absolute top-6 left-0 right-0 select-none pointer-events-none text-center z-[2]" aria-hidden="true">
                  <span class="relative block text-[150px] font-black leading-[0.75em]">
                    <span class="absolute inset-0 flex justify-center bg-gradient-to-b from-primary via-primary/40 to-transparent bg-clip-text text-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 border-none">{step.num}</span>
                    <span class="group-hover:opacity-0 transition-opacity duration-300" style="background: -webkit-linear-gradient(90deg, rgba(0,0,0,0) 20%, #DFDEE5 100%); -webkit-background-clip: text; -webkit-text-stroke: 4px transparent; color: transparent;">{step.num}</span>
                  </span>
                </div>
                <h3 class="relative z-[50] text-h5 text-brand-accent mb-4 leading-snug">{step.title}</h3>
                <p class="relative z-[1] text-base text-brand-muted leading-relaxed max-w-[240px] mx-auto">{step.desc}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Jak wyceniamy projekt -->
    <section class="py-[80px] md:py-[100px] mx-3 rounded-[40px] relative overflow-hidden" style="background-image: url('/h7_bg2.jpg'); background-size: cover; background-position: center;">
      <div class="absolute inset-0 bg-black/55" aria-hidden="true"></div>
      <div class="relative z-10 max-w-[1700px] mx-auto px-5 md:px-10">
        <div class="grid grid-cols-1 lg:grid-cols-[2fr_3fr] gap-[60px] items-center">

          <Image
            src={imgSklepy2}
            alt="Wycena sklepu internetowego – Vexor Designs"
            width={744}
            height={1116}
            format="webp"
            quality={82}
            loading="lazy"
            decoding="async"
            class="reveal rounded-[28px] aspect-video lg:aspect-[4/5] object-cover w-full"
            style="--stagger-i:0"
          />

          <div class="flex flex-col gap-6 reveal" style="--stagger-i:1">
            <Eyebrow dark={true} label="Dlaczego Vexor" />

            <h2 class="text-h2 text-white">
              Wycena sklepu dopasowana do Twoich potrzeb
            </h2>

            <p class="text-white/70 text-lg leading-relaxed">
              Każdy projekt jest inny, dlatego nie stosujemy sztywnych pakietów cenowych. Wycena zależy od liczby produktów, wymaganych integracji, projektu graficznego i czasu realizacji.
            </p>

            <div class="flex flex-col gap-5 mt-2">
              <div class="flex items-center gap-4">
                <span class="w-16 h-16 rounded-2xl flex items-center justify-center flex-shrink-0" style="background: rgba(255,255,255,0.12)">
                  <svg class="w-8 h-8 text-white" viewBox="0 0 24 24" fill="currentColor">
                    <path fill-rule="evenodd" d="M12 1.5a5.25 5.25 0 0 0-5.25 5.25v3a3 3 0 0 0-3 3v6.75a3 3 0 0 0 3 3h10.5a3 3 0 0 0 3-3v-6.75a3 3 0 0 0-3-3v-3c0-2.9-2.35-5.25-5.25-5.25Zm3.75 8.25v-3a3.75 3.75 0 1 0-7.5 0v3h7.5Z" clip-rule="evenodd"/>
                  </svg>
                </span>
                <div>
                  <h3 class="text-white font-semibold text-[18px] leading-snug">Bez ukrytych kosztów</h3>
                  <p class="text-white/60 text-[15px] leading-relaxed mt-1">Wycena obejmuje wszystko co uzgodniliśmy. Żadnych niespodzianek przy fakturze końcowej.</p>
                </div>
              </div>
              <div class="flex items-center gap-4">
                <span class="w-16 h-16 rounded-2xl flex items-center justify-center flex-shrink-0" style="background: rgba(255,255,255,0.12)">
                  <svg class="w-8 h-8 text-white" viewBox="0 0 24 24" fill="currentColor">
