---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import MobileMenu from '../components/MobileMenu.astro';
import { Image } from 'astro:assets';
import imgPadel from '../assets/images/projekty-home/Padel King.png';
import imgFabullate from '../assets/images/projekty-home/Fabullate.png';
import imgFitBox from '../assets/images/projekty-home/FitBox.png';

const localBusinessSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Vexor Designs",
  "url": "https://stronypoznan.com/",
  "telephone": "+48601076883",
  "email": "kontakt@vexordesigns.pl",
  "areaServed": "Poznań",
  "serviceType": ["Tworzenie stron internetowych", "Sklepy WooCommerce", "Pozycjonowanie SEO"]
});
---

<Layout
  title="Strony internetowe Poznań – Vexor Designs"
  description="Profesjonalne strony www dla firm z Poznania. Szybka realizacja, wycena w 24h. Zadzwoń lub napisz."
  canonicalURL="https://stronypoznan.com/"
>
  <script slot="head" type="application/ld+json" set:html={localBusinessSchema} />

  <Navbar />
  <MobileMenu />

  <main>

    <!-- Hero -->
    <section
      class="min-h-[75vh] relative flex flex-col justify-center items-center text-white pt-[130px] pb-20 px-5"
      style="background: linear-gradient(135deg, #1a1a3e 0%, #2d2d6b 60%, #3d3d8f 100%);"
      id="hero"
    >
      <div class="absolute inset-0 hero-dot-grid opacity-[0.35] [background-size:32px_32px]" aria-hidden="true"></div>
      <div class="relative z-10 flex flex-col items-center text-center max-w-[900px] mx-auto gap-6">
        <h1 class="text-hero text-white text-balance reveal" style="--stagger-i:0">
          Strony internetowe dla firm z Poznania
        </h1>
        <p class="text-[22px] md:text-[24px] text-white/85 max-w-[640px] text-pretty font-medium leading-relaxed reveal" style="--stagger-i:1">
          Poznańskie firmy tracą klientów na strony konkurencji. Twoja strona albo wygrywa ten wyścig, albo przegrywa. Nie ma remisów na pierwszej stronie Google.
        </p>
        <div class="flex flex-wrap justify-center gap-4 mt-2 reveal" style="--stagger-i:2">
          <a
            href="https://vexordesigns.pl/kontakt/"
            class="inline-flex items-center h-14 px-8 rounded-2xl bg-primary hover:bg-primary-hover text-white font-semibold text-[17px] transition-colors duration-150 shadow-lg"
          >
            Zapytaj o wycenę
          </a>
          <a
            href="https://vexordesigns.pl/projekty/"
            class="inline-flex items-center h-14 px-8 rounded-2xl border border-white/30 text-white font-semibold text-[17px] hover:bg-white/10 transition-colors duration-150"
          >
            Zobacz nasze projekty
          </a>
        </div>
      </div>
    </section>

    <!-- O nas -->
    <section id="o-nas" class="bg-brand-bg-light py-[80px] md:py-[100px]">
      <div class="max-w-[1700px] mx-auto px-5 md:px-10">
        <div class="max-w-[800px] mx-auto flex flex-col gap-5 reveal" style="--stagger-i:0">
          <span class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-xl text-[18px] font-medium tracking-[0.02em] w-fit border border-brand-border text-brand-text bg-white">
            <span class="w-1.5 h-1.5 rounded-sm bg-primary" aria-hidden="true"></span>
            O nas
          </span>
          <h2 class="text-h2">Studio tworzenia stron internetowych</h2>
          <p class="text-xl text-brand-text leading-relaxed">
            Vexor Designs to studio tworzenia stron internetowych działające dla firm z całej Polski. Specjalizujemy się w stronach które rankują w Google i zamieniają odwiedziny w zapytania. Obsługujemy firmy z Poznania i Wielkopolski priorytetowo.
          </p>
          <a
            href="https://vexordesigns.pl/o-nas/"
            class="inline-flex items-center gap-2 text-primary font-semibold text-[17px] hover:gap-3 transition-all duration-150 w-fit"
          >
            Dowiedz się więcej o Vexor Designs
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- Nasze wartości -->
    <section id="wartosci" class="bg-white py-[80px] md:py-[100px]">
      <div class="max-w-[1700px] mx-auto px-5 md:px-10">
        <div class="flex flex-col items-center gap-4 mb-[60px] text-center">
          <span class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-xl text-[18px] font-medium tracking-[0.02em] w-fit border border-brand-border text-brand-text bg-brand-bg-light">
            <span class="w-1.5 h-1.5 rounded-sm bg-primary" aria-hidden="true"></span>
            Nasze wartości
          </span>
          <h2 class="text-h2">Dlaczego warto z nami pracować</h2>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">

          <article class="bg-brand-bg-light rounded-[24px] p-8 flex flex-col gap-4 reveal" style="--stagger-i:0">
            <div class="w-14 h-14 rounded-2xl bg-primary/10 flex items-center justify-center text-primary flex-shrink-0">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
              </svg>
            </div>
            <h3 class="text-h5 font-medium text-brand-accent">Szybka realizacja</h3>
            <p class="text-brand-text text-base leading-relaxed">Pierwsze makiety w kilka dni roboczych. Wdrożenie w 2–4 tygodnie.</p>
          </article>

          <article class="bg-brand-bg-light rounded-[24px] p-8 flex flex-col gap-4 reveal" style="--stagger-i:1">
            <div class="w-14 h-14 rounded-2xl bg-primary/10 flex items-center justify-center text-primary flex-shrink-0">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="11" cy="11" r="8"/>
                <path d="m21 21-4.35-4.35"/>
                <path d="M8 11h6M11 8v6"/>
              </svg>
            </div>
            <h3 class="text-h5 font-medium text-brand-accent">Widoczność w Google</h3>
            <p class="text-brand-text text-base leading-relaxed">Każda strona zoptymalizowana pod lokalne frazy SEO od pierwszego dnia.</p>
          </article>

          <article class="bg-brand-bg-light rounded-[24px] p-8 flex flex-col gap-4 reveal" style="--stagger-i:2">
            <div class="w-14 h-14 rounded-2xl bg-primary/10 flex items-center justify-center text-primary flex-shrink-0">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.27h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.91a16 16 0 0 0 6 6l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
              </svg>
            </div>
            <h3 class="text-h5 font-medium text-brand-accent">Bezpośredni kontakt</h3>
            <p class="text-brand-text text-base leading-relaxed">Rozmawiasz z osobą która faktycznie robi Twoją stronę, nie z project managerem.</p>
          </article>

          <article class="bg-brand-bg-light rounded-[24px] p-8 flex flex-col gap-4 reveal" style="--stagger-i:3">
            <div class="w-14 h-14 rounded-2xl bg-primary/10 flex items-center justify-center text-primary flex-shrink-0">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="12" y1="1" x2="12" y2="23"/>
                <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
              </svg>
            </div>
            <h3 class="text-h5 font-medium text-brand-accent">Uczciwa wycena</h3>
            <p class="text-brand-text text-base leading-relaxed">Konkretna kwota w 24 godziny. Bez ukrytych kosztów.</p>
          </article>

        </div>

        <div class="mt-10 flex justify-center reveal" style="--stagger-i:4">
          <a
            href="https://vexordesigns.pl/o-nas/"
            class="inline-flex items-center gap-2 text-primary font-semibold text-[17px] hover:gap-3 transition-all duration-150"
          >
            Jak pracujemy
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- Projekty -->
    <section id="projekty" class="bg-brand-bg-light py-[80px] md:py-[100px]">
      <div class="max-w-[1700px] mx-auto p-5 md:p-16 rounded-[40px] bg-white relative overflow-hidden">
        <div class="absolute inset-0 bg-portfolio-image bg-cover bg-top opacity-40" aria-hidden="true"></div>
        <div class="relative z-10">
          <div class="grid grid-cols-1 lg:grid-cols-[1fr_auto] gap-6 items-start mb-10">
            <div class="flex flex-col">
              <span class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-xl text-[18px] font-medium tracking-[0.02em] w-fit bg-white/40 backdrop-blur-md border border-brand-border text-brand-text">
                <span class="w-1.5 h-1.5 rounded-sm bg-primary" aria-hidden="true"></span>
                Nasze projekty
              </span>
              <h2 class="text-h2 mt-[14px]">Wybrane realizacje</h2>
              <p class="text-xl text-brand-text mt-4 max-w-[520px]">Pełne portfolio znajdziesz na vexordesigns.pl</p>
            </div>
            <div class="justify-self-start lg:justify-self-end self-end">
              <a
                href="https://vexordesigns.pl/projekty/"
                class="inline-flex items-center h-14 px-7 rounded-2xl bg-primary hover:bg-primary-hover text-white font-semibold text-[16px] transition-colors duration-150"
              >
                Wszystkie projekty
              </a>
            </div>
          </div>

          <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

            <a
              href="https://vexordesigns.pl/projekty/"
              aria-label="Zobacz projekt Padel King"
              class="group rounded-[20px] overflow-hidden relative cursor-pointer flex flex-col reveal"
              style="--stagger-i:0; background:#142129;"
            >
              <div class="overflow-hidden rounded-b-[20px]">
                <Image
                  src={imgPadel}
                  alt="Padel King – strona dla centrum padla"
                  class="w-full object-cover object-top transition-transform duration-500 ease-out group-hover:scale-[1.04]"
                  style="height: clamp(250px, 22vw, 300px);"
                  loading="lazy"
                />
              </div>
              <div class="px-10 pb-10 pt-5 flex flex-col items-start" style="background:#142129;">
                <h3 class="text-white text-h5">Padel King</h3>
                <p class="text-white/85 text-base font-400 mt-1">Strona dla centrum padla</p>
                <div class="mt-auto pt-6">
                  <span class="group/btn inline-flex items-center h-12 rounded-2xl pr-6 pl-2 text-white text-[16px] font-semibold leading-[1.625] relative overflow-hidden">
                    <span class="absolute left-0 top-0 bottom-0 w-12 rounded-2xl bg-white transition-all duration-300 ease-[ease] group-hover/btn:w-full"></span>
                    <span class="relative z-10 inline-flex w-12 h-12 items-center justify-center pr-4">
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 32 32" fill="#000000" aria-hidden="true"><path d="M15.52 4.953c-.47.155-.904.523-1.125.956-.109.213-.128.327-.128.758 0 .43.019.546.131.773.101.206.87 1.009 3.384 3.533l3.253 3.266-7.438.014-7.437.014-.267.141a2.097 2.097 0 0 0-.831.834c-.109.213-.129.328-.129.758 0 .431.02.544.129.759.165.323.523.68.845.845l.253.129 7.437.014 7.438.014-3.253 3.266c-2.514 2.524-3.283 3.327-3.384 3.533-.112.227-.131.343-.131.773 0 .594.104.858.489 1.244.386.386.65.49 1.244.49.429 0 .547-.02.773-.131.391-.191 9.972-9.772 10.163-10.163.111-.226.131-.344.131-.773 0-.429-.02-.547-.131-.773-.103-.211-1.155-1.293-4.986-5.129-5.414-5.42-5.101-5.143-5.87-5.172-.235-.009-.487.003-.56.027" /></svg>
                    </span>
                    <span class="relative z-10 group-hover/btn:text-black">Zobacz projekt</span>
                  </span>
                </div>
              </div>
            </a>

            <a
              href="https://vexordesigns.pl/projekty/"
              aria-label="Zobacz projekt Fabulatte"
              class="group rounded-[20px] overflow-hidden relative cursor-pointer flex flex-col reveal"
              style="--stagger-i:1; background:#12343e;"
            >
              <div class="overflow-hidden rounded-b-[20px]">
                <Image
                  src={imgFabullate}
                  alt="Fabulatte – strona dla kawiarni"
                  class="w-full object-cover object-top transition-transform duration-500 ease-out group-hover:scale-[1.04]"
                  style="height: clamp(250px, 22vw, 300px);"
                  loading="lazy"
                />
              </div>
              <div class="px-10 pb-10 pt-5 flex flex-col items-start" style="background:#12343e;">
                <h3 class="text-white text-h5">Fabulatte</h3>
                <p class="text-white/85 text-base font-400 mt-1">Strona dla kawiarni</p>
                <div class="mt-auto pt-6">
                  <span class="group/btn inline-flex items-center h-12 rounded-2xl pr-6 pl-2 text-white text-[16px] font-semibold leading-[1.625] relative overflow-hidden">
                    <span class="absolute left-0 top-0 bottom-0 w-12 rounded-2xl bg-white transition-all duration-300 ease-[ease] group-hover/btn:w-full"></span>
                    <span class="relative z-10 inline-flex w-12 h-12 items-center justify-center pr-4">
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 32 32" fill="#000000" aria-hidden="true"><path d="M15.52 4.953c-.47.155-.904.523-1.125.956-.109.213-.128.327-.128.758 0 .43.019.546.131.773.101.206.87 1.009 3.384 3.533l3.253 3.266-7.438.014-7.437.014-.267.141a2.097 2.097 0 0 0-.831.834c-.109.213-.129.328-.129.758 0 .431.02.544.129.759.165.323.523.68.845.845l.253.129 7.437.014 7.438.014-3.253 3.266c-2.514 2.524-3.283 3.327-3.384 3.533-.112.227-.131.343-.131.773 0 .594.104.858.489 1.244.386.386.65.49 1.244.49.429 0 .547-.02.773-.131.391-.191 9.972-9.772 10.163-10.163.111-.226.131-.344.131-.773 0-.429-.02-.547-.131-.773-.103-.211-1.155-1.293-4.986-5.129-5.414-5.42-5.101-5.143-5.87-5.172-.235-.009-.487.003-.56.027" /></svg>
                    </span>
                    <span class="relative z-10 group-hover/btn:text-black">Zobacz projekt</span>
                  </span>
                </div>
              </div>
            </a>

            <a
              href="https://vexordesigns.pl/projekty/"
              aria-label="Zobacz projekt FitBox"
              class="group rounded-[20px] overflow-hidden relative cursor-pointer flex flex-col reveal"
              style="--stagger-i:2; background:#D58E24;"
            >
              <div class="overflow-hidden rounded-b-[20px]">
                <Image
                  src={imgFitBox}
                  alt="FitBox – landing page dla klubu fitness"
                  class="w-full object-cover object-top transition-transform duration-500 ease-out group-hover:scale-[1.04]"
                  style="height: clamp(250px, 22vw, 300px);"
                  loading="lazy"
                />
              </div>
              <div class="px-10 pb-10 pt-5 flex flex-col items-start" style="background:#D58E24;">
                <h3 class="text-white text-h5">FitBox</h3>
                <p class="text-white/85 text-base font-400 mt-1">Landing page dla klubu fitness</p>
                <div class="mt-auto pt-6">
                  <span class="group/btn inline-flex items-center h-12 rounded-2xl pr-6 pl-2 text-white text-[16px] font-semibold leading-[1.625] relative overflow-hidden">
                    <span class="absolute left-0 top-0 bottom-0 w-12 rounded-2xl bg-white transition-all duration-300 ease-[ease] group-hover/btn:w-full"></span>
                    <span class="relative z-10 inline-flex w-12 h-12 items-center justify-center pr-4">
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 32 32" fill="#000000" aria-hidden="true"><path d="M15.52 4.953c-.47.155-.904.523-1.125.956-.109.213-.128.327-.128.758 0 .43.019.546.131.773.101.206.87 1.009 3.384 3.533l3.253 3.266-7.438.014-7.437.014-.267.141a2.097 2.097 0 0 0-.831.834c-.109.213-.129.328-.129.758 0 .431.02.544.129.759.165.323.523.68.845.845l.253.129 7.437.014 7.438.014-3.253 3.266c-2.514 2.524-3.283 3.327-3.384 3.533-.112.227-.131.343-.131.773 0 .594.104.858.489 1.244.386.386.65.49 1.244.49.429 0 .547-.02.773-.131.391-.191 9.972-9.772 10.163-10.163.111-.226.131-.344.131-.773 0-.429-.02-.547-.131-.773-.103-.211-1.155-1.293-4.986-5.129-5.414-5.42-5.101-5.143-5.87-5.172-.235-.009-.487.003-.56.027" /></svg>
                    </span>
                    <span class="relative z-10 group-hover/btn:text-black">Zobacz projekt</span>
                  </span>
                </div>
              </div>
            </a>

          </div>

          <div class="mt-10 flex justify-center reveal" style="--stagger-i:3">
            <a
              href="https://vexordesigns.pl/projekty/"
              class="inline-flex items-center gap-2 text-primary font-semibold text-[17px] hover:gap-3 transition-all duration-150"
            >
              Wszystkie projekty
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Jak działamy -->
    <section id="jak-dzialamy" class="bg-brand-bg-light py-[80px] md:py-[100px]">
      <div class="max-w-[1700px] mx-auto px-5 md:px-10">
        <div class="flex flex-col justify-center items-center gap-6 mb-[60px]">
          <span class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-xl text-[18px] font-medium tracking-[0.02em] w-fit border border-brand-border text-brand-text bg-white">
            <span class="w-1.5 h-1.5 rounded-sm bg-primary" aria-hidden="true"></span>
            Jak działamy
          </span>
          <div class="text-center">
            <h2 class="text-h2">Nasz proces pracy</h2>
            <p class="text-xl text-brand-text max-w-[520px] mt-[14px]">
              Od briefu po wdrożenie — przejrzyście, terminowo, bez niespodzianek.
            </p>
          </div>
        </div>

        <div class="relative border-t border-brand-border">
          <!-- Separator arrows (desktop only) -->
          <div class="hidden lg:flex absolute top-1/2 left-1/4 -translate-x-1/2 -translate-y-1/2 w-[52px] h-[52px] bg-white rounded-2xl shadow-sm items-center justify-center z-10" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 32 32" fill="currentColor"><path d="M15.52 4.953c-.47.155-.904.523-1.125.956-.109.213-.128.327-.128.758 0 .43.019.546.131.773.101.206.87 1.009 3.384 3.533l3.253 3.266-7.438.014-7.437.014-.267.141a2.097 2.097 0 0 0-.831.834c-.109.213-.129.328-.129.758 0 .431.02.544.129.759.165.323.523.68.845.845l.253.129 7.437.014 7.438.014-3.253 3.266c-2.514 2.524-3.283 3.327-3.384 3.533-.112.227-.131.343-.131.773 0 .594.104.858.489 1.244.386.386.65.49 1.244.49.429 0 .547-.02.773-.131.391-.191 9.972-9.772 10.163-10.163.111-.226.131-.344.131-.773 0-.429-.02-.547-.131-.773-.103-.211-1.155-1.293-4.986-5.129-5.414-5.42-5.101-5.143-5.87-5.172-.235-.009-.487.003-.56.027" /></svg>
          </div>
          <div class="hidden lg:flex absolute top-1/2 left-2/4 -translate-x-1/2 -translate-y-1/2 w-[52px] h-[52px] bg-white rounded-2xl shadow-sm items-center justify-center z-10" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 32 32" fill="currentColor"><path d="M15.52 4.953c-.47.155-.904.523-1.125.956-.109.213-.128.327-.128.758 0 .43.019.546.131.773.101.206.87 1.009 3.384 3.533l3.253 3.266-7.438.014-7.437.014-.267.141a2.097 2.097 0 0 0-.831.834c-.109.213-.129.328-.129.758 0 .431.02.544.129.759.165.323.523.68.845.845l.253.129 7.437.014 7.438.014-3.253 3.266c-2.514 2.524-3.283 3.327-3.384 3.533-.112.227-.131.343-.131.773 0 .594.104.858.489 1.244.386.386.65.49 1.244.49.429 0 .547-.02.773-.131.391-.191 9.972-9.772 10.163-10.163.111-.226.131-.344.131-.773 0-.429-.02-.547-.131-.773-.103-.211-1.155-1.293-4.986-5.129-5.414-5.42-5.101-5.143-5.87-5.172-.235-.009-.487.003-.56.027" /></svg>
