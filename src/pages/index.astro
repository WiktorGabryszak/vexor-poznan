---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import MobileMenu from '../components/MobileMenu.astro';
import Eyebrow from '../components/ui/Eyebrow.astro';
import ServiceCards from '../components/ServiceCards.astro';
import { Image } from 'astro:assets';
import imgPadel from '../assets/images/projekty-home/Padel King.png';
import imgFabullate from '../assets/images/projekty-home/Fabullate.png';
import imgFitBox from '../assets/images/projekty-home/FitBox.png';
import imgCtaBg from '../assets/images/h6_bg-1.jpg';
import imgSeo2 from '../assets/images/uslugi-seo-2.jpg';
import imgAplikacje2 from '../assets/images/uslugi-aplikacje-2.jpg';
import vexor2 from '../assets/images/vexor-2.jpg';
import deco2 from '../assets/images/h6_deco-2.png';
import deco1 from '../assets/images/h6_deco-1.webp';
import ButtonA from '../components/ui/ButtonA.astro';

const localBusinessSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Vexor Designs",
  "url": "https://stronypoznan.com/",
  "telephone": "+48601076883",
  "email": "kontakt@stronyinternetowe.net",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Poznań",
    "addressRegion": "Wielkopolska",
    "addressCountry": "PL"
  },
  "areaServed": [
    { "@type": "City", "name": "Poznań" },
    { "@type": "State", "name": "Wielkopolska" }
  ],
  "serviceType": [
    "Tworzenie stron internetowych Poznań",
    "Sklepy WooCommerce Poznań",
    "Pozycjonowanie SEO Poznań"
  ],
  "priceRange": "PLN"
});
---

<Layout
  title="Tworzenie stron internetowych Poznań | Vexor Designs"
  description="Tworzymy strony internetowe dla firm z Poznania. Szybka realizacja, SEO od pierwszego dnia, wycena w 24h. Sprawdź nasze realizacje."
  canonicalURL="https://stronypoznan.com/"
>
  <script slot="head" is:inline async defer src="https://web3forms.com/client/script.js"></script>
  <script slot="head" type="application/ld+json" set:html={localBusinessSchema} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Ile kosztuje strona internetowa w Poznaniu?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Cena zależy od zakresu projektu — liczby podstron, funkcji i wybranej technologii. Każdą realizację wyceniamy indywidualnie. Wycenę przygotowujemy bezpłatnie w ciągu 24 godzin od kontaktu."
        }
      },
      {
        "@type": "Question",
        "name": "Jak długo trwa wykonanie strony www?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Czas realizacji strony internetowej to do 4–6 tygodni roboczych, a sklepu internetowego do 5–8 tygodni. Pierwsze makiety graficzne dostajesz w kilka dni od akceptacji briefu."
        }
      },
      {
        "@type": "Question",
        "name": "Czy strona będzie widoczna w Google?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Każda strona, którą tworzymy, jest zoptymalizowana pod lokalne SEO od pierwszego dnia — poprawna struktura nagłówków, meta tagi, szybkość ładowania i schema markup. Dla firm z Poznania dbamy też o frazy lokalne."
        }
      },
      {
        "@type": "Question",
        "name": "Czy działacie tylko w Poznaniu?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Firmy z Poznania i Wielkopolski obsługujemy priorytetowo, ale pracujemy zdalnie z klientami z całej Polski i Wielkiej Brytanii."
        }
      },
      {
        "@type": "Question",
        "name": "Czy mogę zobaczyć projekt przed opłaceniem?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Tak. Pracujemy etapami: najpierw makiety graficzne, dopiero potem wdrożenie. Płatność w dwóch ratach — zaliczka na start, reszta po akceptacji gotowej strony."
        }
      },
      {
        "@type": "Question",
        "name": "Czy będę mógł samodzielnie edytować stronę?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Tak. Strony WordPress z Elementorem mają intuicyjny panel — większość zmian możesz wprowadzać samodzielnie bez wiedzy technicznej. Po wdrożeniu przeprowadzamy krótkie szkolenie z obsługi."
        }
      }
    ]
  })} />

  <Navbar />
  <MobileMenu />

  <main class="bg-brand-bg-light pb-5">

    <!-- Hero -->
    <section class="min-h-[65vh] relative flex flex-col bg-hero-image bg-cover bg-no-repeat text-white" id="hero">
      <div class="absolute inset-0 hero-dot-grid opacity-[0.35] [background-size:32px_32px]" aria-hidden="true"></div>

      <div class="relative z-10 flex flex-col items-center text-center bg-hero-dots max-w-[1000px] mx-auto pt-[180px] px-6">
        <h1 class="text-hero text-white mt-5 text-balance reveal" style="--stagger-i:1">
          Tworzenie stron internetowych w Poznaniu
        </h1>
        <p class="text-[24px] text-white/100 max-w-[560px] mt-[22px] text-pretty reveal font-medium" style="--stagger-i:2">
          Projektujemy strony internetowe dla firm z Poznania i Wielkopolski. Szybkie, skuteczne, gotowe do rankowania — wycena w 24 godziny.
        </p>
        <div class="flex flex-wrap justify-center gap-4 mt-5 reveal" style="--stagger-i:3">
          <ButtonA href="#kontakt" label="Zapytaj o wycenę" invert={true} />
          <a
            href="https://stronyinternetowe.net/projekty/"
            class="inline-flex items-center h-14 px-8 rounded-2xl border border-white/30 text-white font-semibold text-[17px] hover:bg-white/10 transition-colors duration-150"
          >
            Zobacz nasze projekty
          </a>
        </div>
      </div>

      <div class="relative z-50 mt-16 -mb-8">
        <ServiceCards />
      </div>

      <Image
        src={deco2}
        alt=""
        aria-hidden="true"
        role="presentation"
        fetchpriority="low"
        loading="lazy"
        width={250}
        height={250}
        style="display:none"
        class="absolute left-[8%] top-[25%] w-[250px] h-[250px] shape-gem object-contain animate-float pointer-events-none drop-shadow-[0_20px_40px_rgba(160,96,255,0.4)]"
      />

      <Image
        src={deco1}
        alt=""
        aria-hidden="true"
        role="presentation"
        fetchpriority="low"
        loading="lazy"
        width={350}
        height={350}
        style="display:none"
        class="absolute right-[5%] top-[35%] w-[350px] h-[350px] shape-gem object-contain animate-float-2 pointer-events-none drop-shadow-[0_24px_50px_rgba(128,64,255,0.45)]"
      />
    </section>

    <!-- O nas -->
    <section id="o-nas" class="bg-brand-bg-light pt-[100px] pb-[100px] sm:py-[100px] -z-[50]">
      <div class="max-w-[1700px] mx-auto px-5 md:px-10">
        <div class="grid grid-cols-1 lg:grid-cols-[2fr_3fr] gap-[60px] items-center">
          <Image
            src={imgAplikacje2}
            alt="Tworzenie stron internetowych – warsztat Vexor"
            class="reveal lg:aspect-[4/5] rounded-card object-cover object-right w-full"
            style="--stagger-i:0"
            loading="eager"
            fetchpriority="high"
            width={800}
            height={1000}
          />
          <div class="flex flex-col gap-[18px] min-w-0">
            <div class="reveal" style="--stagger-i:0">
              <Eyebrow label="O nas" />
            </div>
            <h2 class="text-h2 reveal" style="--stagger-i:1">
              Agencja tworzenia stron internetowych z Poznania
            </h2>
            <p class="text-xl text-brand-text max-w-[620px] reveal font-400" style="--stagger-i:2">
              Vexor Designs to studio tworzenia stron internetowych dla firm z Poznania i Wielkopolski. Tworzymy strony www, które pojawiają się wysoko w Google i zamieniają odwiedziny w zapytania o wycenę. Poznań i okolice obsługujemy priorytetowo — realizacje w 4–6 tygodni.
            </p>
            <a
              href="https://stronyinternetowe.net/o-nas/"
              class="inline-flex items-center gap-2 text-primary font-semibold text-[17px] hover:gap-3 transition-all duration-150 w-fit"
            >
              Dowiedz się więcej o Vexor Designs
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Nasze wartości -->
    <section id="wartosci" class="bg-brand-bg-light overflow-hidden relative py-8 md:py-[100px]">
      <!-- <div class="absolute left-[-60px] top-1/2 w-[350px] h-[350px] bg-shape-3 shape-gem bg-contain bg-no-repeat animate-float-3 pointer-events-none drop-shadow-[0_24px_50px_rgba(128,64,255,0.45)] hidden"></div> -->
      <div class="max-w-[1700px] mx-auto px-5 md:px-10">
        <div class="grid grid-cols-1 lg:grid-cols-[3fr_2fr] gap-[60px] items-center">
          <Image
            src={vexor2}
            alt="Zespół Vexor przy pracy"
            class="reveal aspect-video lg:aspect-[4/5] rounded-card object-cover w-full"
            style="--stagger-i:0"
            loading="lazy"
          />
          <div class="flex flex-col gap-6 order-last lg:order-first">
            <div class="reveal" style="--stagger-i:0">
              <Eyebrow label="Nasze wartości" />
            </div>
            <h2 class="text-h2 reveal" style="--stagger-i:1">
              Dlaczego warto z nami pracować
            </h2>
            <div class="reveal cv-accordion" style="--stagger-i:2">
              <div class="cv-item border-b border-brand-border" data-open="true">
                <button class="cv-summary flex items-center gap-4 w-full text-left py-4 cursor-pointer">
                  <span class="cv-icon w-16 h-16 rounded-2xl flex items-center justify-center bg-white transition-colors duration-300 flex-shrink-0">
                    <span
                      class="w-8 h-8 text-primary transition-colors duration-300"
                      set:html={'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="8" r="3.2"/><circle cx="17" cy="9" r="2.4"/><path d="M3 19c0-3 2.5-5 6-5s6 2 6 5"/><path d="M14.5 19c0-2 1.5-3.5 4-3.5 1.6 0 2.5.7 2.5.7"/></svg>'}
                    />
                  </span>
                  <h3 class="cv-label text-h5 font-medium text-brand-muted transition-colors duration-300 flex-1">
                    Szybka realizacja
                  </h3>
                  <span class="cv-indicator w-8 h-8 flex items-center justify-center flex-shrink-0 transition-transform duration-300 text-black">
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                      <line x1="7" y1="2" x2="7" y2="12"/>
                      <line x1="2" y1="7" x2="12" y2="7"/>
                    </svg>
                  </span>
                </button>
                <div class="cv-body">
                  <div class="cv-inner">
                    <p class="pl-[80px] pb-4 text-xl text-brand-muted leading-relaxed">
                      Pierwsze makiety w kilka dni roboczych. Wdrożenie w 4–6 tygodni.
                    </p>
                  </div>
                </div>
              </div>
              <div class="cv-item border-b border-brand-border">
                <button class="cv-summary flex items-center gap-4 w-full text-left py-4 cursor-pointer">
                  <span class="cv-icon w-16 h-16 rounded-2xl flex items-center justify-center bg-white transition-colors duration-300 flex-shrink-0">
                    <span
                      class="w-8 h-8 text-primary transition-colors duration-300"
                      set:html={'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a8 8 0 1 1-3-6.2L21 5v4h-4"/><path d="M8 12h.01M12 12h.01M16 12h.01"/></svg>'}
                    />
                  </span>
                  <h3 class="cv-label text-h5 font-medium text-brand-muted transition-colors duration-300 flex-1">
                    Widoczność w Google
                  </h3>
                  <span class="cv-indicator w-8 h-8 flex items-center justify-center flex-shrink-0 transition-transform duration-300 text-black">
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                      <line x1="7" y1="2" x2="7" y2="12"/>
                      <line x1="2" y1="7" x2="12" y2="7"/>
                    </svg>
                  </span>
                </button>
                <div class="cv-body">
                  <div class="cv-inner">
                    <p class="pl-[80px] pb-4 text-xl text-brand-muted leading-relaxed">
                      Każda strona zoptymalizowana pod lokalne frazy SEO od pierwszego dnia.
                    </p>
                  </div>
                </div>
              </div>
              <div class="cv-item border-b border-brand-border">
                <button class="cv-summary flex items-center gap-4 w-full text-left py-4 cursor-pointer">
                  <span class="cv-icon w-16 h-16 rounded-2xl flex items-center justify-center bg-white transition-colors duration-300 flex-shrink-0">
                    <span
                      class="w-8 h-8 text-primary transition-colors duration-300"
                      set:html={'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l8 3v6c0 5-3.5 8-8 9-4.5-1-8-4-8-9V6z"/><path d="m8.5 12 2.4 2.4L16 9.5"/></svg>'}
                    />
                  </span>
                  <h3 class="cv-label text-h5 font-medium text-brand-muted transition-colors duration-300 flex-1">
                    Bezpośredni kontakt
                  </h3>
                  <span class="cv-indicator w-8 h-8 flex items-center justify-center flex-shrink-0 transition-transform duration-300 text-black">
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                      <line x1="7" y1="2" x2="7" y2="12"/>
                      <line x1="2" y1="7" x2="12" y2="7"/>
                    </svg>
                  </span>
                </button>
                <div class="cv-body">
                  <div class="cv-inner">
                    <p class="pl-[80px] pb-4 text-xl text-brand-muted leading-relaxed">
                      Rozmawiasz z osobą która faktycznie robi Twoją stronę, nie z project managerem.
                    </p>
                  </div>
                </div>
              </div>
              <div class="cv-item border-b border-brand-border">
                <button class="cv-summary flex items-center gap-4 w-full text-left py-4 cursor-pointer">
                  <span class="cv-icon w-16 h-16 rounded-2xl flex items-center justify-center bg-white transition-colors duration-300 flex-shrink-0">
                    <span
                      class="w-8 h-8 text-primary transition-colors duration-300"
                      set:html={'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M4 13a8 8 0 0 1 16 0"/><rect x="3" y="13" width="4" height="6" rx="1.5"/><rect x="17" y="13" width="4" height="6" rx="1.5"/><path d="M19 19v1a2 2 0 0 1-2 2h-3"/></svg>'}
                    />
                  </span>
                  <h3 class="cv-label text-h5 font-medium text-brand-muted transition-colors duration-300 flex-1">
                    Uczciwa wycena
                  </h3>
                  <span class="cv-indicator w-8 h-8 flex items-center justify-center flex-shrink-0 transition-transform duration-300 text-black">
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                      <line x1="7" y1="2" x2="7" y2="12"/>
                      <line x1="2" y1="7" x2="12" y2="7"/>
                    </svg>
                  </span>
                </button>
                <div class="cv-body">
                  <div class="cv-inner">
                    <p class="pl-[80px] pb-4 text-xl text-brand-muted leading-relaxed">
                      Konkretna kwota w 24 godziny. Bez ukrytych kosztów.
                    </p>
                  </div>
                </div>
              </div>
            </div>
            <div class="mt-6 flex justify-start reveal" style="--stagger-i:3">
              <a
                href="https://stronyinternetowe.net/o-nas/"
                class="inline-flex items-center gap-2 text-primary font-semibold text-[17px] hover:gap-3 transition-all duration-150"
              >
                Jak pracujemy
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Projekty -->
    <section id="projekty" class="bg-brand-bg-light py-[80px] md:py-[100px]">
      <div class="max-w-[1700px] mx-auto p-5 md:p-16 rounded-[40px] bg-white relative overflow-hidden">
        <div class="absolute inset-0 bg-portfolio-image bg-cover bg-top opacity-40" aria-hidden="true"></div>
        <div class="relative z-10">
          <div class="grid grid-cols-1 lg:grid-cols-[1fr_auto] gap-6 items-start mb-10">
            <div class="flex flex-col">
              <span class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-xl text-[18px] font-medium tracking-[0.02em] w-fit bg-white/40 backdrop-blur-md border border-brand-border text-brand-text">
                <span class="w-1.5 h-1.5 rounded-sm bg-primary" aria-hidden="true"></span>
                Nasze projekty
              </span>
              <h2 class="text-h2 mt-[14px]">Wybrane realizacje</h2>
              <p class="text-xl text-brand-text mt-4 max-w-[520px]">Od stron wizytówkowych po sklepy WooCommerce — realizacje dla firm z Polski i Wielkiej Brytanii. Pełne portfolio na stronyinternetowe.net.</p>
            </div>
            <div class="justify-self-start self-start">
              <ButtonA href="https://stronyinternetowe.net/projekty/" label="Wszystkie projekty" invert={false} />
            </div>
          </div>

          <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

            <a
              href="https://stronyinternetowe.net/projekty/"
              aria-label="Zobacz projekt Padel King"
              class="group rounded-[20px] overflow-hidden relative cursor-pointer flex flex-col reveal"
              style="--stagger-i:0; background:#142129;"
            >
              <div class="overflow-hidden rounded-b-[20px]">
                <Image
                  src={imgPadel}
                  alt="Padel King – strona dla centrum padla"
                  class="w-full object-cover object-top transition-transform duration-500 ease-out group-hover:scale-[1.04]"
                  style="height: clamp(250px, 22vw, 300px);"
                  loading="lazy"
                />
              </div>
              <div class="px-10 pb-10 pt-5 flex flex-col items-start" style="background:#142129;">
                <h3 class="text-white text-h5">Padel King</h3>
                <p class="text-white/85 text-base font-400 mt-1">Strona dla centrum padla</p>
                <div class="mt-auto pt-6">
                  <span class="group/btn inline-flex items-center h-12 rounded-2xl pr-6 pl-2 text-white text-[16px] font-semibold leading-[1.625] relative overflow-hidden">
                    <span class="absolute left-0 top-0 bottom-0 w-12 rounded-2xl bg-white transition-all duration-300 ease-[ease] group-hover/btn:w-full"></span>
                    <span class="relative z-10 inline-flex w-12 h-12 items-center justify-center pr-4">
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 32 32" fill="#000000" aria-hidden="true"><path d="M15.52 4.953c-.47.155-.904.523-1.125.956-.109.213-.128.327-.128.758 0 .43.019.546.131.773.101.206.87 1.009 3.384 3.533l3.253 3.266-7.438.014-7.437.014-.267.141a2.097 2.097 0 0 0-.831.834c-.109.213-.129.328-.129.758 0 .431.02.544.129.759.165.323.523.68.845.845l.253.129 7.437.014 7.438.014-3.253 3.266c-2.514 2.524-3.283 3.327-3.384 3.533-.112.227-.131.343-.131.773 0 .594.104.858.489 1.244.386.386.65.49 1.244.49.429 0 .547-.02.773-.131.391-.191 9.972-9.772 10.163-10.163.111-.226.131-.344.131-.773 0-.429-.02-.547-.131-.773-.103-.211-1.155-1.293-4.986-5.129-5.414-5.42-5.101-5.143-5.87-5.172-.235-.009-.487.003-.56.027" /></svg>
                    </span>
                    <span class="relative z-10 group-hover/btn:text-black">Zobacz projekt</span>
                  </span>
                </div>
              </div>
            </a>

            <a
              href="https://stronyinternetowe.net/projekty/"
              aria-label="Zobacz projekt Fabulatte"
              class="group rounded-[20px] overflow-hidden relative cursor-pointer flex flex-col reveal"
              style="--stagger-i:1; background:#12343e;"
            >
              <div class="overflow-hidden rounded-b-[20px]">
                <Image
                  src={imgFabullate}
                  alt="Fabulatte – strona dla kawiarni"
                  class="w-full object-cover object-top transition-transform duration-500 ease-out group-hover:scale-[1.04]"
                  style="height: clamp(250px, 22vw, 300px);"
                  loading="lazy"
                />
              </div>
              <div class="px-10 pb-10 pt-5 flex flex-col items-start" style="background:#12343e;">
                <h3 class="text-white text-h5">Fabulatte</h3>
                <p class="text-white/85 text-base font-400 mt-1">Strona dla firmy marketingowej</p>
                <div class="mt-auto pt-6">
                  <span class="group/btn inline-flex items-center h-12 rounded-2xl pr-6 pl-2 text-white text-[16px] font-semibold leading-[1.625] relative overflow-hidden">
                    <span class="absolute left-0 top-0 bottom-0 w-12 rounded-2xl bg-white transition-all duration-300 ease-[ease] group-hover/btn:w-full"></span>
                    <span class="relative z-10 inline-flex w-12 h-12 items-center justify-center pr-4">
