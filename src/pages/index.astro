  <script>
    const sidebar = document.getElementById('sticky-cta');
    const hero = document.getElementById('hero');
    const kontakt = document.getElementById('kontakt');

    if (sidebar && hero && kontakt) {
      let heroVisible = true;
      let kontaktVisible = false;

      const updateVisibility = () => {
        if (heroVisible || kontaktVisible) {
          sidebar.style.opacity = '0';
          sidebar.style.pointerEvents = 'none';
          sidebar.setAttribute('aria-hidden', 'true');
        } else {
          sidebar.style.opacity = '1';
          sidebar.style.pointerEvents = 'auto';
          sidebar.setAttribute('aria-hidden', 'false');
        }
      };

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.target === hero) heroVisible = entry.isIntersecting;
          if (entry.target === kontakt) kontaktVisible = entry.isIntersecting;
          updateVisibility();
        });
      }, { threshold: 0.1 });

      observer.observe(hero);
      observer.observe(kontakt);

      sidebar.querySelector('a')?.addEventListener('click', (e) => {
        e.preventDefault();
        kontakt.scrollIntoView({ behavior: 'smooth' });
      });
    }
  </script>

  <script is:inline>
    const cvItems = document.querySelectorAll('.cv-accordion .cv-item');

    function openCvItem(item) {
      item.dataset.open = 'true';
      const body = item.querySelector('.cv-body');
      body.style.gridTemplateRows = '1fr';
      const icon = item.querySelector('.cv-icon');
      const label = item.querySelector('.cv-label');
      const indicator = item.querySelector('.cv-indicator');
      icon.style.backgroundColor = 'rgba(110,118,255,0.12)';
      label.style.color = 'var(--color-brand-accent, #1a1a2e)';
      indicator.style.transform = 'rotate(45deg)';
    }

    function closeCvItem(item) {
      delete item.dataset.open;
      const body = item.querySelector('.cv-body');
      body.style.gridTemplateRows = '0fr';
      const icon = item.querySelector('.cv-icon');
      const label = item.querySelector('.cv-label');
      const indicator = item.querySelector('.cv-indicator');
      icon.style.backgroundColor = '';
      label.style.color = '';
      indicator.style.transform = '';
    }

    cvItems.forEach((item) => {
      const isInitiallyOpen = item.dataset.open === 'true';
      const body = item.querySelector('.cv-body');

      if (isInitiallyOpen) {
        body.style.gridTemplateRows = '1fr';
        const icon = item.querySelector('.cv-icon');
        const label = item.querySelector('.cv-label');
        const indicator = item.querySelector('.cv-indicator');
        icon.style.backgroundColor = 'rgba(110,118,255,0.12)';
        label.style.color = 'var(--color-brand-accent, #1a1a2e)';
        indicator.style.transform = 'rotate(45deg)';
      } else {
        body.style.gridTemplateRows = '0fr';
      }

      item.querySelector('.cv-summary').addEventListener('click', () => {
        const isOpen = item.dataset.open === 'true';
        cvItems.forEach((other) => {
          if (other !== item && other.dataset.open === 'true') closeCvItem(other);
        });
        if (isOpen) {
          closeCvItem(item);
        } else {
          openCvItem(item);
        }
      });
    });
  </script>

