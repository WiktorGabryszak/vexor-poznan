    <script is:inline>
      (function () {
        const cats     = document.querySelectorAll('.faq-cat-btn');
        const items    = document.querySelectorAll('.faq-item');
        const triggers = document.querySelectorAll('.faq-trigger');
        const mobileLabel = document.getElementById('faq-mobile-cat');

        function openAnswer(trigger) {
          const answer  = trigger.nextElementSibling;
          const chevron = trigger.querySelector('.faq-chevron');
          trigger.setAttribute('aria-expanded', 'true');
          answer.style.transition = 'max-height 0.4s cubic-bezier(0.4,0,0.2,1)';
          answer.style.maxHeight  = answer.scrollHeight + 'px';
          if (chevron) chevron.style.transform = 'rotate(180deg)';
        }

        function closeAnswer(trigger) {
          const answer  = trigger.nextElementSibling;
          const chevron = trigger.querySelector('.faq-chevron');
          trigger.setAttribute('aria-expanded', 'false');
          answer.style.transition = 'max-height 0.4s cubic-bezier(0.4,0,0.2,1)';
          answer.style.maxHeight  = '0';
          if (chevron) chevron.style.transform = 'rotate(0deg)';
        }

        function activateCat(cat) {
          cats.forEach(btn => {
            const active = btn.dataset.cat === cat;
            btn.classList.toggle('text-brand-accent', active);
            btn.classList.toggle('font-bold', active);
            btn.style.color = active ? '' : '#5C5C5C';
            if (active && mobileLabel) mobileLabel.textContent = btn.textContent.trim();
          });
          items.forEach(item => {
            const show = cat === 'all' || item.dataset.cat === cat;
            item.style.display = show ? '' : 'none';
            // zamknij ukryte pytania
            if (!show) {
              const t = item.querySelector('.faq-trigger');
              if (t && t.getAttribute('aria-expanded') === 'true') closeAnswer(t);
            }
          });
        }

        cats.forEach(btn => {
          btn.addEventListener('click', () => activateCat(btn.dataset.cat));
        });

        triggers.forEach(trigger => {
          trigger.addEventListener('click', () => {
            const isOpen = trigger.getAttribute('aria-expanded') === 'true';
            isOpen ? closeAnswer(trigger) : openAnswer(trigger);
          });
        });

        // Otwórz pierwsze pytanie domyślnie
        if (triggers.length) openAnswer(triggers[0]);
        activateCat('all');
      })();
    </script>

