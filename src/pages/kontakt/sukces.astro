---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import MobileMenu from '../../components/MobileMenu.astro';
import Footer from '../../components/Footer.astro';
---

<Layout
  title="Wiadomość wysłana – Vexor"
  description="Dziękujemy za kontakt. Odezwiemy się tego samego dnia roboczego."
  canonicalURL="https://stronyinternetowe.net/kontakt/sukces/"
  ogImage="https://stronyinternetowe.net/og-image.jpg"
>
  <Navbar />
  <MobileMenu />
  <main>
    <section class="min-h-[80vh] flex flex-col justify-center items-center bg-brand-bg-light px-5">
      <div class="max-w-[560px] w-full text-center flex flex-col items-center gap-6">
        <div class="w-20 h-20 rounded-full bg-primary/10 flex items-center justify-center text-primary">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 6 9 17l-5-5"/>
          </svg>
        </div>
        <h1 class="text-h2 font-medium text-brand-accent">Wiadomość wysłana!</h1>
        <p class="text-lg text-brand-muted leading-relaxed">
          Dziękujemy za kontakt. Odezwiemy się zazwyczaj tego samego dnia roboczego.
        </p>
        <a
          href="/"
          class="h-14 px-8 rounded-2xl bg-primary hover:bg-primary-hover text-white font-semibold text-base transition-colors duration-150 flex items-center"
        >
          Wróć na stronę główną
        </a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
