            height={558}
            format="webp"
            quality={82}
            loading="lazy"
            decoding="async"
            class="reveal rounded-[28px] aspect-video lg:aspect-[4/5] object-cover w-full"
            style="--stagger-i:0"
          />

          <div class="flex flex-col gap-6 reveal" style="--stagger-i:1">
            <Eyebrow dark={true} label={`Działamy w ${city.nameMiejscownik}`} />

            <h2 class="text-h2 text-white">
              Strony internetowe dla firm z {city.nameDopelniacz}
            </h2>

            <p class="text-white/70 text-lg leading-relaxed">
              {city.localContext}
            </p>
            <p class="text-white/70 text-lg leading-relaxed mt-4">
              {city.localContext2}
            </p>

            <div class="flex flex-col gap-5 mt-2">
              <div class="flex items-center gap-4">
                <span class="w-16 h-16 rounded-2xl flex items-center justify-center flex-shrink-0" style="background: rgba(255,255,255,0.12)">
                  <svg class="w-8 h-8 text-white" viewBox="0 0 24 24" fill="currentColor">
                    <path fill-rule="evenodd" d="M12 2.25c-5.385 0-9.75 4.365-9.75 9.75s4.365 9.75 9.75 9.75 9.75-4.365 9.75-9.75S17.385 2.25 12 2.25ZM12.75 6a.75.75 0 0 0-1.5 0v6c0 .414.336.75.75.75h4.5a.75.75 0 0 0 0-1.5h-3.75V6Z" clip-rule="evenodd"/>
                  </svg>
                </span>
                <div>
                  <h3 class="text-white font-semibold text-[18px] leading-snug">Wycena w 24 godziny</h3>
                  <p class="text-white/60 text-[15px] leading-relaxed mt-1">Opisz projekt, a wrócimy z bezpłatną wyceną następnego dnia roboczego. Bez zobowiązań.</p>
                </div>
              </div>
              <div class="flex items-center gap-4">
                <span class="w-16 h-16 rounded-2xl flex items-center justify-center flex-shrink-0" style="background: rgba(255,255,255,0.12)">
                  <svg class="w-8 h-8 text-white" viewBox="0 0 24 24" fill="currentColor">
                    <path fill-rule="evenodd" d="M8.25 6.75a3.75 3.75 0 1 1 7.5 0 3.75 3.75 0 0 1-7.5 0ZM15.75 9.75a3 3 0 1 1 6 0 3 3 0 0 1-6 0ZM2.25 9.75a3 3 0 1 1 6 0 3 3 0 0 1-6 0ZM6.31 15.117A6.745 6.745 0 0 1 12 12a6.745 6.745 0 0 1 6.709 7.498.75.75 0 0 1-.372.568A12.696 12.696 0 0 1 12 21.75c-2.305 0-4.47-.612-6.337-1.684a.75.75 0 0 1-.372-.568 6.787 6.787 0 0 1 1.019-4.38Z" clip-rule="evenodd"/>
                    <path d="M5.082 14.254a8.287 8.287 0 0 0-1.308 5.135 9.687 9.687 0 0 1-1.764-.44l-.115-.04a.563.563 0 0 1-.373-.487l-.01-.121a3.75 3.75 0 0 1 3.57-4.047ZM20.226 19.389a8.287 8.287 0 0 0-1.308-5.135 3.75 3.75 0 0 1 3.57 4.047l-.01.121a.563.563 0 0 1-.373.486l-.115.04c-.567.2-1.156.349-1.764.441Z"/>
                  </svg>
                </span>
                <div>
                  <h3 class="text-white font-semibold text-[18px] leading-snug">Lokalna znajomość rynku</h3>
                  <p class="text-white/60 text-[15px] leading-relaxed mt-1">Firmy z {city.nameDopelniacz} i okolic mogą liczyć na sprawną komunikację i krótki czas reakcji.</p>
                </div>
              </div>
            </div>

            <hr class="border-white/10 mt-2" />

            <div class="flex flex-wrap items-center gap-5">
              <p class="text-white/80 text-[16px]">Dołącz do <strong class="text-white">40+ firm</strong>, które nam zaufały</p>
