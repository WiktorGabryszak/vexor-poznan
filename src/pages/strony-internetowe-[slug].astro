---
import type { GetStaticPaths } from 'astro';
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import MobileMenu from '../components/MobileMenu.astro';
import Footer from '../components/Footer.astro';
import ContactCTA from '../components/ContactCTA.astro';
import Eyebrow from '../components/ui/Eyebrow.astro';
import ButtonA from '../components/ui/ButtonA.astro';
import { Image } from 'astro:assets';
import imgCity from '../assets/images/uslugi-strony-2.jpg';
import { cities, type City } from '../data/cities.ts';

export const getStaticPaths = (() => {
  return cities.map((city) => ({
    params: { slug: city.slug },
    props: { city },
  }));
}) satisfies GetStaticPaths;

interface Props {
  city: City;
}

const { city } = Astro.props;

const canonicalURL = `https://stronyinternetowe.net/strony-internetowe-${city.slug}/`;

const localBusinessSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Vexor Designs",
  "url": canonicalURL,
  "telephone": "+48601076883",
  "email": "kontakt@stronyinternetowe.net",
  "areaServed": city.name,
  "serviceType": [
    "Tworzenie stron internetowych",
    "Projektowanie stron WWW",
    "Sklepy WooCommerce",
    "Pozycjonowanie SEO"
  ]
});

const faqSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": `Ile kosztuje strona internetowa w ${city.nameMiejscownik}?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `Każdy projekt wyceniamy indywidualnie po krótkim briefie. Opisz nam swój projekt, a wrócimy z bezpłatną wyceną w ciągu 24 godzin. Firmy z ${city.nameDopelniacz} i okolic traktujemy priorytetowo.`
      }
    },
    {
      "@type": "Question",
      "name": `Jak długo trwa realizacja strony dla firmy z ${city.name}?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Standardowy czas realizacji to 2–4 tygodnie od dostarczenia materiałów. Pierwsze makiety graficzne są gotowe zazwyczaj w ciągu kilku dni roboczych od briefu. Przy rozbudowanych projektach czas realizacji ustalamy indywidualnie."
      }
    },
    {
      "@type": "Question",
      "name": `Czy obsługujecie firmy wyłącznie z ${city.name}?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `Realizujemy projekty dla firm z całej Polski. Firmy z ${city.nameDopelniacz} i okolic traktujemy priorytetowo ze względu na znajomość lokalnego rynku i sprawną komunikację.`
      }
    }
  ]
});

const services = [
  {
    icon: `<path fill-rule="evenodd" clip-rule="evenodd" d="M2.25 5.25C2.25 3.59315 3.59315 2.25 5.25 2.25H18.75C20.4069 2.25 21.75 3.59315 21.75 5.25V15C21.75 16.6569 20.4069 18 18.75 18H15.75V18.2574C15.75 18.8541 15.9871 19.4264 16.409 19.8483L17.0303 20.4697C17.2448 20.6842 17.309 21.0068 17.1929 21.287C17.0768 21.5673 16.8033 21.75 16.5 21.75H7.5C7.19665 21.75 6.92318 21.5673 6.80709 21.287C6.691 21.0068 6.75517 20.6842 6.96967 20.4697L7.59099 19.8484C8.01295 19.4264 8.25 18.8541 8.25 18.2574V18H5.25C3.59315 18 2.25 16.6569 2.25 15V5.25ZM3.75 5.25V12.75C3.75 13.5784 4.42157 14.25 5.25 14.25H18.75C19.5784 14.25 20.25 13.5784 20.25 12.75V5.25C20.25 4.42157 19.5784 3.75 18.75 3.75H5.25C4.42157 3.75 3.75 4.42157 3.75 5.25Z"/>`,
    title: 'Strony internetowe',
    desc: 'Projektujemy strony zoptymalizowane pod konwersję i wyszukiwarki. Szybkie ładowanie, mobile-first, SSL w standardzie.',
    href: '/uslugi/projektowanie-stron-internetowych/',
  },
  {
    icon: `<path fill-rule="evenodd" clip-rule="evenodd" d="M7.5 6v.75H5.513c-.96 0-1.764.724-1.865 1.679l-1.263 12A1.875 1.875 0 0 0 4.25 22.5h15.5a1.875 1.875 0 0 0 1.865-2.071l-1.263-12a1.875 1.875 0 0 0-1.865-1.679H16.5V6a4.5 4.5 0 1 0-9 0ZM12 3a3 3 0 0 0-3 3v.75h6V6a3 3 0 0 0-3-3Zm-3 8.25a3 3 0 1 0 6 0 3 3 0 0 0-6 0Z"/>`,
    title: 'Sklepy internetowe',
    desc: 'Wdrażamy sklepy WooCommerce z integracją płatności, zarządzaniem zamówieniami i automatyzacją wysyłki.',
    href: '/uslugi/tworzenie-sklepow-internetowych/',
  },
  {
    icon: `<path fill-rule="evenodd" clip-rule="evenodd" d="M10.5 3.75a6.75 6.75 0 1 0 0 13.5 6.75 6.75 0 0 0 0-13.5ZM2.25 10.5a8.25 8.25 0 1 1 14.59 5.28l4.69 4.69a.75.75 0 1 1-1.06 1.06l-4.69-4.69A8.25 8.25 0 0 1 2.25 10.5Z"/>`,
    title: 'Pozycjonowanie SEO',
    desc: 'Audyt techniczny, optymalizacja on-page, treści i linkowanie. Budujemy widoczność w Google i mierzymy wyniki.',
    href: '/uslugi/pozycjonowanie-seo/',
  },
  {
    icon: `<path fill-rule="evenodd" clip-rule="evenodd" d="M14.447 3.026a.75.75 0 0 1 .527.921l-4.5 16.5a.75.75 0 0 1-1.448-.394l4.5-16.5a.75.75 0 0 1 .921-.527ZM16.72 6.22a.75.75 0 0 1 1.06 0l5.25 5.25a.75.75 0 0 1 0 1.06l-5.25 5.25a.75.75 0 1 1-1.06-1.06L21.44 12l-4.72-4.72a.75.75 0 0 1 0-1.06Zm-9.44 0a.75.75 0 0 1 0 1.06L2.56 12l4.72 4.72a.75.75 0 0 1-1.06 1.06L.97 12.53a.75.75 0 0 1 0-1.06l5.25-5.25a.75.75 0 0 1 1.06 0Z"/>`,
    title: 'Aplikacje webowe',
    desc: 'Tworzymy dedykowane aplikacje webowe: proste narzędzia wewnętrzne i rozbudowane platformy SaaS.',
    href: '/uslugi/aplikacje-webowe/',
  },
];

const faqItems = [
  {
    q: `Ile kosztuje strona internetowa w ${city.nameMiejscownik}?`,
    a: `Każdy projekt wyceniamy indywidualnie po krótkim briefie. Opisz nam swój projekt, a wrócimy z bezpłatną wyceną w ciągu 24 godzin. Firmy z ${city.nameDopelniacz} i okolic traktujemy priorytetowo.`,
  },
  {
    q: `Jak długo trwa realizacja strony dla firmy z ${city.name}?`,
    a: `Standardowy czas realizacji to 2–4 tygodnie od dostarczenia materiałów. Pierwsze makiety graficzne są gotowe zazwyczaj w ciągu kilku dni roboczych od briefu. Przy rozbudowanych projektach czas realizacji ustalamy indywidualnie.`,
  },
  {
    q: `Czy obsługujecie firmy wyłącznie z ${city.name}?`,
    a: `Realizujemy projekty dla firm z całej Polski. Firmy z ${city.nameDopelniacz} i okolic traktujemy priorytetowo ze względu na znajomość lokalnego rynku i sprawną komunikację.`,
  },
];
---

<Layout
  title={`Strony internetowe dla firm z ${city.name} | Vexor Designs`}
  description={city.metaDescription}
  canonicalURL={canonicalURL}
  ogImage="https://stronyinternetowe.net/og-image.jpg"
  robots="index, follow"
>
  <Navbar />
  <MobileMenu />
  <main class="bg-brand-bg-light">

    <!-- Hero -->
    <section class="min-h-[50vh] relative flex flex-col justify-center items-center text-white" style="background: linear-gradient(135deg, #1a1a3e 0%, #2d2d6b 60%, #3d3d8f 100%);">
      <div class="relative z-10 max-w-[1700px] mx-auto px-5 md:px-[47px] py-20 mt-[110px] flex flex-col justify-center items-center gap-5 text-center">
        <nav aria-label="Breadcrumb">
          <ol class="inline-flex items-center gap-2 px-4 py-2 rounded-xl backdrop-blur-md border border-white/10 text-sm text-white/70">
            <li><a href="/" class="hover:text-white transition-colors duration-150">Strona główna</a></li>
            <li aria-hidden="true">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-50"><path d="M9 18l6-6-6-6"/></svg>
            </li>
            <li class="text-white font-medium" aria-current="page">Strony internetowe {city.name}</li>
          </ol>
        </nav>

        <h1 class="text-heroSub text-white text-balance reveal" style="--stagger-i:0">
          {city.headline}
        </h1>
        <p class="text-[21px] text-white/80 max-w-[640px] text-pretty reveal font-medium" style="--stagger-i:1">
          {city.description}
        </p>
        <div class="flex flex-wrap items-center justify-center gap-4 reveal mt-2" style="--stagger-i:2">
          <ButtonA href="/kontakt/" label={city.ctaText} invert={true} />
          <a
            href="/projekty/"
            class="inline-flex items-center h-[52px] px-7 rounded-[20px] border border-white/30 text-white text-[16px] font-semibold hover:bg-white/10 transition-colors duration-200"
          >
            Zobacz projekty
          </a>
        </div>
      </div>
    </section>

    <!-- Usługi -->
    <section class="bg-brand-bg-light py-[80px] md:py-[100px]">
      <div class="max-w-[1700px] mx-auto px-5 md:px-10">
        <div class="text-center mb-14 reveal" style="--stagger-i:0">
          <Eyebrow label="Co robimy" />
          <h2 class="text-h2 text-brand-accent mt-4">Nasze usługi dla firm z {city.nameDopelniacz}</h2>
          <p class="text-brand-text text-lg mt-4 max-w-[560px] mx-auto leading-relaxed">
            Kompleksowa obsługa online: projekt, wdrożenie i pozycjonowanie.
          </p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-6">
          {services.map((s, i) => (
            <div
              class="rounded-[24px] p-8 flex flex-col gap-4 reveal border border-black/[0.06] bg-white"
              style={`--stagger-i:${i}`}
            >
              <span class="w-16 h-16 rounded-2xl flex items-center justify-center flex-shrink-0 bg-white">
                <svg class="w-8 h-8 text-primary" viewBox="0 0 24 24" fill="currentColor" set:html={s.icon}></svg>
              </span>
              <div class="flex flex-col gap-2 flex-1">
                <h3 class="text-h5 text-brand-accent leading-snug">{s.title}</h3>
                <p class="text-brand-text text-sm leading-relaxed">{s.desc}</p>
              </div>
              <div class="mt-auto pt-6">
                <a
                  class="group/btn inline-flex items-center h-12 rounded-2xl pr-6 pl-2 text-brand-accent text-[16px] font-semibold leading-[1.625] relative overflow-hidden"
                  href={s.href}
                >
                  <span class="absolute left-0 top-0 bottom-0 w-12 rounded-2xl bg-primary transition-all duration-300 ease-[ease] group-hover/btn:w-full"></span>
                  <span class="relative z-10 inline-flex w-12 h-12 items-center justify-center pr-4">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 32 32" fill="white" aria-hidden="true">
                      <path d="M15.52 4.953c-.47.155-.904.523-1.125.956-.109.213-.128.327-.128.758 0 .43.019.546.131.773.101.206.87 1.009 3.384 3.533l3.253 3.266-7.438.014-7.437.014-.267.141a2.097 2.097 0 0 0-.831.834c-.109.213-.129.328-.129.758 0 .431.02.544.129.759.165.323.523.68.845.845l.253.129 7.437.014 7.438.014-3.253 3.266c-2.514 2.524-3.283 3.327-3.384 3.533-.112.227-.131.343-.131.773 0 .594.104.858.489 1.244.386.386.65.49 1.244.49.429 0 .547-.02.773-.131.391-.191 9.972-9.772 10.163-10.163.111-.226.131-.344.131-.773 0-.429-.02-.547-.131-.773-.103-.211-1.155-1.293-4.986-5.129-5.414-5.42-5.101-5.143-5.87-5.172-.235-.009-.487.003-.56.027" />
                    </svg>
