---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import MobileMenu from '../../components/MobileMenu.astro';
import ContactCTA from '../../components/ContactCTA.astro';
import Footer from '../../components/Footer.astro';
import Eyebrow from '../../components/ui/Eyebrow.astro';

interface Project {
  slug: string;
  title: string;
  category: string;
  date: string;
  client: string;
  location: string;
  heroGradient: string;
  coverGradient: string;
  previewImage?: string;
  intro: string;
  challenge: { heading: string; text: string; items: string[] };
  process: { heading: string; text: string };
  result: { heading: string; text: string; items: string[] };
  img1Gradient: string;
  img2Gradient: string;
  prevSlug: string | null;
  prevTitle: string | null;
  nextSlug: string | null;
  nextTitle: string | null;
}

export function getStaticPaths() {
  const data: Project[] = [
    {
      slug: 'fabulatte',
      title: 'Fabulatte',
      category: 'Web Design & Development',
      date: '10 marca, 2025',
      client: 'Fabulatte',
      location: 'Londyn, UK',
      heroGradient: 'radial-gradient(ellipse at 60% 40%, rgba(18, 52, 62, 0.12) 0%, #F5F4F8 70%)',
      coverGradient: 'linear-gradient(135deg, #0a1e24 0%, #12343e 60%, #1a4a58 100%)',
      intro: 'Dla londyńskiej marki lifestyle\'owej Fabulatte zaprojektowaliśmy i wdrożyliśmy elegancką stronę internetową z wbudowanym sklepem WooCommerce oraz systemem rezerwacji stolików online. Projekt kładł nacisk na spójną identyfikację wizualną i wciągające doświadczenie użytkownika, które odzwierciedla ekskluzywny charakter marki.',
      challenge: { heading: 'Wyzwanie\ni rozwiązanie', text: 'Klient potrzebował platformy łączącej sprzedaż produktów premium z rezerwacją miejsc w kawiarni — dotychczasowa strona nie spełniała żadnej z tych funkcji i generowała wysokie wskaźniki odrzuceń. Rozwiązaniem był spójny ekosystem cyfrowy zbudowany na WooCommerce z niestandardowym motywem i zintegrowanym modułem rezerwacji.', items: ['Audyt UX i analiza konkurencji', 'Projekt identyfikacji wizualnej', 'Integracja WooCommerce + rezerwacje'] },
      process: { heading: 'Nasz\nproces', text: 'Prace rozpoczęliśmy od warsztatów brandingowych z klientem, by w pełni zrozumieć DNA marki. Następnie przeszliśmy przez etapy wireframingu, prototypowania w Figmie i iteracyjnego testowania interfejsu z grupą rzeczywistych użytkowników przed wdrożeniem produkcyjnym.' },
      result: { heading: 'Wyniki\ni efekty', text: 'Nowa strona uruchomiona w marcu 2025 roku przyniosła natychmiastowy wzrost sprzedaży online oraz znaczące skrócenie czasu potrzebnego do dokonania rezerwacji. Klient odnotował wyraźną poprawę wizerunku marki wśród swoich klientów.', items: ['Wzrost sprzedaży online o 38% w pierwszym miesiącu', 'Redukcja bounce rate z 72% do 41%', 'Średni czas rezerwacji skrócony o 60%'] },
      img1Gradient: 'linear-gradient(160deg, #0d2830 0%, #12343e 100%)',
      img2Gradient: 'linear-gradient(135deg, #12343e 0%, #1f4f60 100%)',
      prevSlug: 'padel-king', prevTitle: 'Padel King',
      nextSlug: 'fitbox', nextTitle: 'FitBox',
    },
    {
      slug: 'fitbox',
      title: 'FitBox',
      category: 'Web Design & Development',
      date: '20 stycznia, 2025',
      client: 'FitBox',
      location: 'Manchester, UK',
      heroGradient: 'radial-gradient(ellipse at 50% 50%, rgba(213, 142, 36, 0.14) 0%, #F5F4F8 65%)',
      coverGradient: 'linear-gradient(135deg, #3d2400 0%, #7a4a10 50%, #D58E24 100%)',
      intro: 'FitBox to dynamiczne studio boksu i fitnessu z Manchesteru, dla którego stworzyliśmy stronę internetową z systemem zapisu na zajęcia online, integracją płatności Stripe oraz interaktywnym planem treningów. Strona jest w pełni responsywna i zoptymalizowana pod konwersję nowych klientów.',
      challenge: { heading: 'Wyzwanie\ni rozwiązanie', text: 'Studio działało wyłącznie w oparciu o kontakt telefoniczny i media społecznościowe, tracąc potencjalnych klientów, którzy chcieli szybko i wygodnie zapisać się na zajęcia o dowolnej porze. Wdrożyliśmy dedykowaną platformę rezerwacyjną zintegrowaną z kalendarzem instruktorów i automatycznymi przypomnieniami SMS.', items: ['Analiza ścieżki klienta', 'Projekt systemu rezerwacji online', 'Integracja Stripe i powiadomień SMS'] },
      process: { heading: 'Nasz\nproces', text: 'Kluczowym elementem procesu było stworzenie intuicyjnego flow rezerwacji — przetestowanego z 15 użytkownikami przed wdrożeniem. Projekt graficzny nawiązuje do energetycznego charakteru marki: kontrastowe kolory, dynamiczna typografia i zdjęcia treningowe w roli głównej.' },
      result: { heading: 'Wyniki\ni efekty', text: 'Platforma uruchomiona w styczniu 2025 roku przyspieszyła procesy zapisu i odciążyła recepcję studia od obsługi telefonicznej. W ciągu pierwszych ośmiu tygodni FitBox pozyskał znacząco więcej nowych klientów niż w analogicznym okresie rok wcześniej.', items: ['Wzrost liczby rezerwacji online o 52%', 'Redukcja połączeń telefonicznych o 70%', 'Współczynnik konwersji strony na poziomie 6,4%'] },
      img1Gradient: 'linear-gradient(160deg, #3d2400 0%, #a06318 100%)',
      img2Gradient: 'linear-gradient(135deg, #7a4a10 0%, #D58E24 100%)',
      prevSlug: 'fabulatte', prevTitle: 'Fabulatte',
      nextSlug: 'greenwich', nextTitle: 'Just Golf Greenwich',
    },
    {
      slug: 'greenwich',
      title: 'Just Golf Greenwich',
      category: 'Web Design & Development',
      date: '5 listopada, 2024',
      client: 'Just Golf Greenwich',
      location: 'Londyn, UK',
      heroGradient: 'radial-gradient(ellipse at 55% 35%, rgba(243, 0, 148, 0.10) 0%, #F5F4F8 68%)',
      coverGradient: 'linear-gradient(135deg, #5a0037 0%, #a5005f 50%, #F30094 100%)',
      intro: 'Dla ekskluzywnego klubu golfowego Just Golf w Greenwich (Londyn) zaprojektowaliśmy i wdrożyliśmy reprezentacyjną stronę internetową z systemem rezerwacji pola online oraz modułem zarządzania subskrypcjami członkowskimi. Strona wyróżnia się minimalistycznym designem i płynnymi animacjami sekcji, oddając prestiżowy charakter marki.',
      challenge: { heading: 'Wyzwanie\ni rozwiązanie', text: 'Klub posiadał przestarzałą witrynę bez możliwości rezerwacji online, co skutkowało dużą liczbą porzuconych zapytań i brakiem danych o klientach. Rozwiązaniem był nowoczesny serwis z zintegrowanym systemem rezerwacji slotów, automatyczną pocztą potwierdzającą i bazą CRM do zarządzania członkostwem.', items: ['Przeprojektowanie architektury informacji', 'Budowa systemu rezerwacji slotów', 'Integracja CRM i e-mail automation'] },
      process: { heading: 'Nasz\nproces', text: 'Projekt realizowaliśmy metodą sprint-based: w ciągu 8 tygodni przeszliśmy przez fazy discovery, UX design, visual design i development z cotygodniowymi przeglądami z klientem. Szczególny nacisk położyliśmy na dopasowanie estetyki do oczekiwań zamożnej, brytyjskiej grupy docelowej.' },
      result: { heading: 'Wyniki\ni efekty', text: 'Od momentu uruchomienia strona stała się głównym kanałem pozyskiwania nowych członków klubu, wyprzedzając polecenia i media społecznościowe. Klient zwrócił koszty projektu w ciągu pierwszych czterech miesięcy działania serwisu.', items: ['Wzrost rezerwacji online o 44% vs. poprzedni okres', '1 200+ zapisanych użytkowników w ciągu 3 miesięcy', 'Średni czas na stronie wydłużony do 3 min 42 sek'] },
      img1Gradient: 'linear-gradient(160deg, #5a0037 0%, #c0006e 100%)',
      img2Gradient: 'linear-gradient(135deg, #a5005f 0%, #F30094 100%)',
      prevSlug: 'fitbox', prevTitle: 'FitBox',
      nextSlug: 'jennings-storage', nextTitle: 'Jennings Storage',
    },
    {
      slug: 'jennings-storage',
      title: 'Jennings Storage',
      category: 'Website Redesign',
      date: '12 września, 2024',
      client: 'Jennings Storage',
      location: 'Birmingham, UK',
      heroGradient: 'radial-gradient(ellipse at 45% 55%, rgba(0, 166, 139, 0.12) 0%, #F5F4F8 65%)',
      coverGradient: 'linear-gradient(135deg, #003830 0%, #006655 50%, #00A68B 100%)',
      intro: 'Jennings Storage to birminghamska firma self-storage, której całkowicie przeprojektowaliśmy witrynę internetową — zastępując przestarzały, nieresponsywny serwis nowoczesną platformą z interaktywną wyszukiwarką dostępnych boksów magazynowych i kalkulatorem cen online. Nowa strona jest zoptymalizowana pod wyszukiwania lokalne i generuje leady bezpośrednio z formularzy kontaktowych.',
      challenge: { heading: 'Wyzwanie\ni rozwiązanie', text: 'Stara strona Jennings Storage ładowała się ponad 8 sekund, była nieczytelna na urządzeniach mobilnych i nie pojawiała się w wynikach lokalnego Google dla kluczowych fraz. Przeprowadziliśmy kompleksowy redesign oparty na audycie technicznym, analizie konkurencji i optymalizacji SEO już na etapie projektowania.', items: ['Audyt techniczny i SEO', 'Responsywny redesign UX/UI', 'Optymalizacja Core Web Vitals'] },
      process: { heading: 'Nasz\nproces', text: 'Projekt podzieliliśmy na dwa etapy: najpierw naprawiliśmy fundamenty techniczne (migracja na szybki hosting, optymalizacja kodu), następnie przebudowaliśmy wizualną warstwę serwisu. Nowy design oparliśmy na hierarchii informacji ułatwiającej jak najszybsze dotarcie klienta do interesującego go rozmiaru boksu.' },
      result: { heading: 'Wyniki\ni efekty', text: 'Po redesignie strona Jennings Storage wskoczyła na pierwszą stronę wyników Google dla 12 lokalnych fraz kluczowych w Birmingham. Firma odnotowała istotny wzrost liczby zapytań ofertowych generowanych bezpośrednio przez stronę.', items: ['Czas ładowania skrócony z 8,2 s do 1,4 s', 'Wzrost organicznego ruchu o 67% w 6 miesięcy', 'Liczba leadów z formularzy wzrosła o 83%'] },
      img1Gradient: 'linear-gradient(160deg, #003830 0%, #008068 100%)',
      img2Gradient: 'linear-gradient(135deg, #006655 0%, #00A68B 100%)',
      prevSlug: 'greenwich', prevTitle: 'Just Golf Greenwich',
      nextSlug: 'pw-mateo', nextTitle: 'P.W. Mateo',
    },
    {
      slug: 'pw-mateo',
      title: 'P.W. Mateo',
      category: 'Web Design & Development',
      date: '8 czerwca, 2024',
      client: 'P.W. Mateo',
      location: 'Kraków, PL',
      heroGradient: 'radial-gradient(ellipse at 50% 40%, rgba(228, 54, 42, 0.11) 0%, #F5F4F8 66%)',
      coverGradient: 'linear-gradient(135deg, #5c0a06 0%, #a01c14 50%, #E4362A 100%)',
      intro: 'P.W. Mateo to krakowska firma wielobranżowa świadcząca usługi budowlane, remontowe i wykończeniowe, dla której studio Vexor Designs zaprojektowało i wdrożyło kompleksową stronę firmową. Serwis zawiera rozbudowane portfolio realizacji z galerią zdjęć, formularz wyceny online oraz moduł prezentacji usług z podziałem na branże.',
      challenge: { heading: 'Wyzwanie\ni rozwiązanie', text: 'Firma P.W. Mateo polegała wyłącznie na poleceniach i nie posiadała żadnej obecności w internecie, co ograniczało jej zasięg do klientów już znających markę. Zadaniem Vexor było stworzenie wiarygodnego, profesjonalnego serwisu wizytówkowego, który zbuduje zaufanie nowych klientów i ułatwi im szybkie zlecenie usługi.', items: ['Strategia contentu i pozycjonowanie marki', 'Projekt portfolio realizacji z galerią', 'Formularz wyceny z integracją e-mail'] },
      process: { heading: 'Nasz\nproces', text: 'Jako projekt własny studia Vexor Designs mieliśmy pełną swobodę twórczą — skupiliśmy się na budowie silnej, przejrzystej hierarchii treści prowadzącej odwiedzającego od prezentacji usług przez portfolio aż do kontaktu. Motyw graficzny nawiązuje do profesjonalizmu branży budowlanej: mocne linie, czysta typografia i stonowana paleta z akcentem głębokiej czerwieni.' },
      result: { heading: 'Wyniki\ni efekty', text: 'W ciągu sześciu miesięcy od uruchomienia firma pozyskała pierwszych klientów bezpośrednio ze strony internetowej, co potwierdziło skuteczność cyfrowej obecności nawet w tradycyjnie opartej na poleceniach branży. Klient wyraził chęć rozbudowy serwisu o moduł zamówień materiałów.', items: ['Pierwsze zlecenie z formularza po 11 dniach od startu', 'Średnio 320 sesji miesięcznie po 3 miesiącach', 'Ocena 5/5 w Google Moja Firma po 6 miesiącach'] },
      img1Gradient: 'linear-gradient(160deg, #5c0a06 0%, #c01e14 100%)',
      img2Gradient: 'linear-gradient(135deg, #a01c14 0%, #E4362A 100%)',
      prevSlug: 'jennings-storage', prevTitle: 'Jennings Storage',
      nextSlug: 'padel-king', nextTitle: 'Padel King',
    },
    {
      slug: 'padel-king',
      title: 'Padel King',
      category: 'Web Design & Development',
      date: '22 kwietnia, 2025',
      client: 'Padel King',
      location: 'Londyn, UK',
      heroGradient: 'radial-gradient(ellipse at 40% 50%, rgba(20, 33, 41, 0.15) 0%, #F5F4F8 68%)',
      coverGradient: 'linear-gradient(135deg, #0a1318 0%, #142129 60%, #1e3040 100%)',
      intro: 'Padel King to londyński klub padla oferujący nowoczesne korty i lekcje dla wszystkich poziomów zaawansowania, dla którego zaprojektowaliśmy i wdrożyliśmy stronę internetową z zintegrowanym systemem rezerwacji kortów real-time, płatnościami kartą online oraz interaktywnym harmonogramem treningów. Serwis zbudowano w modelu mobile-first — ponad 80% ruchu pochodzi z urządzeń mobilnych.',
      challenge: { heading: 'Wyzwanie\ni rozwiązanie', text: 'Klub działał bez dedykowanej strony i zarządzał rezerwacjami ręcznie przez WhatsApp, co prowadziło do podwójnych bookingów i frustracji klientów. Zaprojektowaliśmy platformę rezerwacyjną real-time z zarządzaniem dostępnością kortów, płatnościami online i automatycznymi potwierdzeniami.', items: ['Mapowanie procesu rezerwacji', 'Budowa systemu real-time availability', 'Integracja płatności online i przypomnień SMS'] },
      process: { heading: 'Nasz\nproces', text: 'Projekt realizowaliśmy w modelu mobile-first — najpierw zaprojektowaliśmy doświadczenie na smartfonie, następnie skalowaliśmy je na desktop. Ciemna kolorystyka nawiązuje do nocnych rozgrywek pod sztucznym oświetleniem, a energetyczne akcenty podkreślają dynamiczny charakter sportu.' },
      result: { heading: 'Wyniki\ni efekty', text: 'Platforma uruchomiona w kwietniu 2025 roku wyeliminowała problem podwójnych rezerwacji i znacząco zmniejszyła liczbę no-show dzięki automatycznym przypomnieniom SMS. Klub zanotował wzrost liczby rezerwacji i poszerzenie bazy klientów o osoby, które wcześniej nie wiedziały o jego istnieniu.', items: ['Wzrost rezerwacji o 61% rok do roku', 'Zero przypadków podwójnych rezerwacji od uruchomienia', 'Wskaźnik no-show obniżony z 22% do 7%'] },
      img1Gradient: 'linear-gradient(160deg, #0a1318 0%, #1a2d3a 100%)',
      img2Gradient: 'linear-gradient(135deg, #142129 0%, #1e3040 100%)',
      prevSlug: 'pw-mateo', prevTitle: 'P.W. Mateo',
      nextSlug: 'fabulatte', nextTitle: 'Fabulatte',
    },
  ];
  return data.map((p) => ({ params: { slug: p.slug }, props: { project: p } }));
}

const { project } = Astro.props as { project: Project };
---

<Layout
  title={`${project.title} – Projekt Vexor`}
  description={project.intro}
  canonicalURL={`https://vexordesigns.pl/projekty/${project.slug}/`}
>
  <Navbar dark />
  <MobileMenu />

  <main class="bg-brand-bg-light">

    <!-- ── HERO ─────────────────────────────────────────────── -->
    <section
      class="relative min-h-[88vh] flex flex-col items-center justify-center px-6 pt-[120px] pb-0 overflow-hidden"
      style={`background: ${project.heroGradient};`}
    >
      <!-- Eyebrow centred -->
      <div class="flex justify-center mb-6">
        <Eyebrow label={project.category} />
      </div>

      <!-- Giant title -->
      <h1
        class="text-center font-bold tracking-[-0.03em] text-brand-accent leading-[1.05] text-hero"
        
      >
        {project.title}
      </h1>

      <!-- Metadata row pinned to bottom of hero -->
      <div class="w-full max-w-[1100px] mx-auto pt-20 pb-14 grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-0">
        {[
          { label: 'Data', value: project.date },
          { label: 'Klient', value: project.client },
          { label: 'Kategoria', value: project.category },
          { label: 'Lokalizacja', value: project.location },
        ].map((item) => (
          <div class="flex flex-col items-center text-center md:border-r md:border-black/10 last:border-0 px-4">
            <span class="text-[13px] font-500 text-brand-muted uppercase tracking-[.08em] mb-1">{item.label}</span>
            <span class="text-xl font-500 text-brand-accent">{item.value}</span>
          </div>
        ))}
      </div>
      <!-- Cover image -->
      <div
        class="w-full max-w-[1700px] mx-auto my-12 rounded-[40px] overflow-hidden flex-shrink-0"
        style={`height: clamp(240px, 36vw, 720px); background: ${project.coverGradient};`}
        aria-hidden="true"
      >
        <div class="w-full h-full" style="background-image: repeating-linear-gradient(135deg,rgba(255,255,255,.06) 0 1px,transparent 1px 20px);"></div>
      </div>
    </section>

      

      

    <!-- ── INTRO TEXT ────────────────────────────────────────── -->
    <section class="max-w-[1700px] mx-auto px-6 md:px-10 py-16 md:py-20">
      <p class="text-xl md:text-2xl text-brand-text leading-relaxed max-w-[820px]">
        {project.intro}
      </p>
    </section>

    <!-- ── 50/50: STICKY ACCORDION + SCROLLING WEBSITE IMAGE ── -->
    <div class="max-w-[1700px] mx-auto px-6 md:px-10">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 items-start">

        <!-- Left: floating sticky accordion card -->
        <div class="md:sticky md:top-36 bg-white rounded-[32px] px-8 md:px-12 py-10 md:py-14">

          <details class="group/acc border-b border-brand-border" open>
            <summary class="flex items-center justify-between py-7 cursor-pointer list-none select-none">
              <span class="text-[clamp(20px,2vw,28px)] font-semibold tracking-[-0.02em] text-brand-accent">Wyzwanie</span>
              <span class="w-9 h-9 rounded-full border border-brand-border flex items-center justify-center text-[22px] leading-none text-brand-muted flex-shrink-0 ml-4 transition-transform duration-200 group-open/acc:rotate-45">+</span>
            </summary>
            <div class="pb-10">
              <p class="text-[17px] text-brand-text leading-relaxed">{project.challenge.text}</p>
              <ul class="mt-6 flex flex-col gap-3">
                {project.challenge.items.map((item) => (
                  <li class="flex items-center gap-3 text-[15px] font-semibold text-brand-accent">
                    <span class="w-1.5 h-1.5 rounded-full bg-primary flex-shrink-0"></span>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          </details>

          <details class="group/acc border-b border-brand-border">
            <summary class="flex items-center justify-between py-7 cursor-pointer list-none select-none">
              <span class="text-[clamp(20px,2vw,28px)] font-semibold tracking-[-0.02em] text-brand-accent">Rozwiązanie</span>
              <span class="w-9 h-9 rounded-full border border-brand-border flex items-center justify-center text-[22px] leading-none text-brand-muted flex-shrink-0 ml-4 transition-transform duration-200 group-open/acc:rotate-45">+</span>
            </summary>
            <div class="pb-10">
              <p class="text-[17px] text-brand-text leading-relaxed">{project.process.text}</p>
            </div>
          </details>


        </div>

        <!-- Right: rounded image card -->
        <div class="overflow-hidden rounded-[32px]">
          <!-- Browser chrome bar -->
          <div class="flex items-center gap-2 px-4 py-[10px] bg-[#16162a]">
            <span class="w-[11px] h-[11px] rounded-full bg-[#ff5f57]"></span>
            <span class="w-[11px] h-[11px] rounded-full bg-[#ffbd2e]"></span>
            <span class="w-[11px] h-[11px] rounded-full bg-[#28c840]"></span>
            <div class="flex-1 mx-3 h-6 rounded-full bg-white/10 flex items-center px-3">
              <span class="text-[11px] font-mono text-white/40">vexordesigns.pl/{project.slug}/</span>
            </div>
          </div>
          {project.previewImage ? (
            <img
              src={project.previewImage}
              alt={`Podgląd strony – ${project.title}`}
              class="w-full block"
              loading="eager"
            />
          ) : (
            <div style={`height: 900px; background: ${project.coverGradient};`}>
              <div class="w-full h-full" style="background-image: repeating-linear-gradient(135deg,rgba(255,255,255,.06) 0 1px,transparent 1px 20px);"></div>
            </div>
          )}
        </div>

      </div>
    </div>

    <!-- ── IMAGE GALLERY ─────────────────────────────────────── -->
    <div class="max-w-[1700px] mx-auto px-6 md:px-10 mt-6 grid grid-cols-1 md:grid-cols-2 gap-6">
      <div
        class="rounded-[32px] overflow-hidden reveal"
        style={`height: clamp(220px,28vw,420px); background: ${project.img1Gradient};`}
        aria-hidden="true"
      >
        <div class="w-full h-full" style="background-image: repeating-linear-gradient(135deg,rgba(255,255,255,.06) 0 1px,transparent 1px 18px);"></div>
      </div>
      <div
        class="rounded-[32px] overflow-hidden reveal"
        style={`height: clamp(220px,28vw,420px); background: ${project.img2Gradient}; --stagger-i:1;`}
        aria-hidden="true"
      >
        <div class="w-full h-full" style="background-image: repeating-linear-gradient(45deg,rgba(255,255,255,.06) 0 1px,transparent 1px 18px);"></div>
      </div>
    </div>

    <!-- ── RESULT ─────────────────────────────────────────────── -->
    <div class="max-w-[1700px] mx-auto px-6 md:px-10 mt-6 mb-16">
      <div class="bg-white rounded-[40px] px-8 md:px-16 py-14 md:py-20">
        <div class="grid grid-cols-1 md:grid-cols-[280px_1fr] gap-8 md:gap-16 reveal">
          <div>
            <h2 class="text-[clamp(22px,3vw,36px)] font-semibold leading-[1.2] tracking-[-0.02em] text-brand-accent whitespace-pre-line">
              {project.result.heading}
            </h2>
          </div>
          <div>
            <p class="text-[17px] text-brand-text leading-relaxed">{project.result.text}</p>
            <ul class="mt-6 flex flex-col gap-3">
              {project.result.items.map((item) => (
                <li class="flex items-center gap-3 text-[16px] font-semibold text-brand-accent">
                  <span class="w-1.5 h-1.5 rounded-full bg-primary flex-shrink-0"></span>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>

    <!-- ── PROJECT NAVIGATION ────────────────────────────────── -->
    <div class="max-w-[1700px] mx-auto px-6 md:px-10 pb-20">
      <div class="grid grid-cols-2 gap-4">
        {project.prevSlug ? (
          <a
            href={`/projekty/${project.prevSlug}/`}
            class="group flex items-center gap-3 bg-white rounded-[24px] px-6 py-5 hover:bg-primary transition-colors duration-200"
          >
            <svg class="w-5 h-5 text-brand-muted group-hover:text-white transition-colors flex-shrink-0" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 4L6 10L12 16"/>
            </svg>
            <div>
              <p class="text-[11px] uppercase tracking-[.1em] text-brand-muted group-hover:text-white/70 transition-colors font-semibold">poprzedni projekt</p>
              <p class="text-[15px] font-semibold text-brand-accent group-hover:text-white transition-colors mt-0.5">{project.prevTitle}</p>
            </div>
          </a>
        ) : <div />}

        {project.nextSlug ? (
          <a
            href={`/projekty/${project.nextSlug}/`}
            class="group flex items-center justify-end gap-3 bg-white rounded-[24px] px-6 py-5 hover:bg-primary transition-colors duration-200 text-right"
          >
            <div>
              <p class="text-[11px] uppercase tracking-[.1em] text-brand-muted group-hover:text-white/70 transition-colors font-semibold">następny projekt</p>
              <p class="text-[15px] font-semibold text-brand-accent group-hover:text-white transition-colors mt-0.5">{project.nextTitle}</p>
            </div>
            <svg class="w-5 h-5 text-brand-muted group-hover:text-white transition-colors flex-shrink-0" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M8 4L14 10L8 16"/>
            </svg>
          </a>
        ) : <div />}
      </div>
    </div>

  </main>

  <ContactCTA />
  <Footer />

</Layout>
