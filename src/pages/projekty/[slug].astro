  slug: string;
  title: string;
  category: string;
  date: string;
  client: string;
  location: string;
  siteUrl?: string;
  partner?: string;
  heroGradient: string;
  coverGradient: string;
  coverImage?: string;
  previewImage?: string;
  img1Image?: string;
  img2Image?: string;
  intro: string;
  challenge: { heading: string; text: string; items: string[] };
  process: { heading: string; text: string };
  result: { heading: string; text: string; items: string[] };
  img1Gradient: string;
  img2Gradient: string;
  prevSlug: string | null;
  prevTitle: string | null;
  nextSlug: string | null;
  nextTitle: string | null;
}

