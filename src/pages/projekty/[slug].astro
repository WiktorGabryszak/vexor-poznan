---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import MobileMenu from '../../components/MobileMenu.astro';
import ContactCTA from '../../components/ContactCTA.astro';
import Footer from '../../components/Footer.astro';
import Eyebrow from '../../components/ui/Eyebrow.astro';

interface Project {
  slug: string;
  title: string;
  category: string;
  date: string;
  client: string;
  location: string;
  heroGradient: string;
  coverGradient: string;
  previewImage?: string;
  intro: string;
  challenge: { heading: string; text: string; items: string[] };
  process: { heading: string; text: string };
  result: { heading: string; text: string; items: string[] };
  img1Gradient: string;
  img2Gradient: string;
  prevSlug: string | null;
  prevTitle: string | null;
  nextSlug: string | null;
  nextTitle: string | null;
}

export function getStaticPaths() {
  const data: Project[] = [
    {
      slug: 'ui-ux-design-platform',
      title: 'UI/UX Design Platform',
      category: 'Development',
      date: '27 sierpnia, 2024',
      client: 'Galileo Studio',
      location: 'Warszawa, PL',
      heroGradient: 'radial-gradient(ellipse 60% 80% at 10% 50%, rgba(220,230,140,.55) 0%, transparent 60%), radial-gradient(ellipse 60% 80% at 90% 50%, rgba(210,160,220,.55) 0%, transparent 60%), #F5F4F8',
      coverGradient: 'linear-gradient(135deg,#1a4a5a 0%,#0d2a35 100%)',
      previewImage: '/images/projekty/ui-ux-design-platform.jpeg',
      intro: 'Zaprojektowaliśmy i wdrożyliśmy kompleksową platformę do projektowania UI/UX, która umożliwia zespołom projektowym efektywne zarządzanie projektami, tworzenie prototypów i współpracę w czasie rzeczywistym. Narzędzie zintegrowane z popularnymi systemami zarządzania projektami.',
      challenge: { heading: 'Wyzwanie\ni rozwiązanie', text: 'Klient potrzebował zunifikowanego środowiska pracy dla rozproszonych zespołów projektowych. Dotychczasowy przepływ pracy oparty na wielu oddzielnych narzędziach powodował utratę czasu i niespójność projektu.', items: ['Badania użytkowników', 'Projektowanie konceptu', 'Implementacja'] },
      process: { heading: 'Nasz\nproces', text: 'Zaczęliśmy od szczegółowych wywiadów z użytkownikami i analizy konkurencji. Następnie przeprowadziliśmy serię warsztatów projektowych, które pozwoliły nam zdefiniować architekturę informacji i kluczowe przepływy użytkownika.' },
      result: { heading: 'Wyniki\ni efekty', text: 'Platforma skróciła czas dostarczania projektów o 40%. Zespoły raportują znacznie wyższą satysfakcję z pracy i lepszą spójność dostarczanych materiałów.', items: ['Branding i identyfikacja wizualna', 'Strony i platformy cyfrowe', 'Strategia treści dla social media'] },
      img1Gradient: 'linear-gradient(135deg,#1a4a5a,#0d2a35)',
      img2Gradient: 'linear-gradient(135deg,#2a3a5a,#0a1a35)',
      prevSlug: 'video-production-hub', prevTitle: 'Video Production Hub',
      nextSlug: 'social-media-campaigns', nextTitle: 'Social Media Campaigns',
    },
    {
      slug: 'social-media-campaigns',
      title: 'Social Media Campaigns',
      category: 'Design',
      date: '12 marca, 2024',
      client: 'Interlock Fashion',
      location: 'Kraków, PL',
      heroGradient: 'radial-gradient(ellipse 60% 80% at 10% 50%, rgba(240,180,200,.55) 0%, transparent 60%), radial-gradient(ellipse 60% 80% at 90% 50%, rgba(180,160,240,.55) 0%, transparent 60%), #F5F4F8',
      coverGradient: 'linear-gradient(135deg,#5a1a45 0%,#2a0a1f 100%)',
      intro: 'Kompleksowa kampania social media dla marki fashion. Stworzyliśmy spójną identyfikację wizualną, szablony postów, strategię contentu i harmonogram publikacji na 6 miesięcy.',
      challenge: { heading: 'Wyzwanie\ni rozwiązanie', text: 'Marka istniała od lat, ale nie miała spójnej obecności w mediach społecznościowych. Brak strategii powodował niskie zaangażowanie i brak rozpoznawalności.', items: ['Audyt obecnych kanałów', 'Strategia contentu', 'Produkcja materiałów'] },
      process: { heading: 'Nasz\nproces', text: 'Po audycie istniejących kanałów i analizie grupy docelowej zdefiniowaliśmy tone of voice marki. Przygotowaliśmy bank treści na 3 miesiące i wdrożyliśmy system zarządzania publikacjami.' },
      result: { heading: 'Wyniki\ni efekty', text: 'W ciągu 3 miesięcy zaangażowanie wzrosło o 280%. Liczba obserwujących podwoiła się, a sprzedaż z kanałów social media wzrosła o 60%.', items: ['Identyfikacja wizualna', 'Bank 200+ szablonów', 'Wzrost zasięgu o 300%'] },
      img1Gradient: 'linear-gradient(135deg,#5a1a45,#2a0a1f)',
      img2Gradient: 'linear-gradient(135deg,#3a0a35,#1a0015)',
      prevSlug: 'ui-ux-design-platform', prevTitle: 'UI/UX Design Platform',
      nextSlug: 'content-marketing-suite', nextTitle: 'Content Marketing Suite',
    },
    {
      slug: 'content-marketing-suite',
      title: 'Content Marketing Suite',
      category: 'Development',
      date: '5 czerwca, 2024',
      client: 'Segment Agency',
      location: 'Wrocław, PL',
      heroGradient: 'radial-gradient(ellipse 60% 80% at 10% 50%, rgba(160,220,180,.55) 0%, transparent 60%), radial-gradient(ellipse 60% 80% at 90% 50%, rgba(140,200,240,.55) 0%, transparent 60%), #F5F4F8',
      coverGradient: 'linear-gradient(135deg,#6a8060 0%,#3a5030 100%)',
      intro: 'Zbudowaliśmy dedykowane narzędzie do zarządzania content marketingiem — od planowania, przez produkcję, po dystrybucję i analizę wyników. Integracja z CMS, SEO i analytics.',
      challenge: { heading: 'Wyzwanie\ni rozwiązanie', text: 'Agencja contentowa obsługująca 30+ klientów potrzebowała centralnego miejsca do zarządzania całym procesem tworzenia treści i raportowania wyników.', items: ['Mapowanie procesów', 'Architektura systemu', 'Wdrożenie i szkolenie'] },
      process: { heading: 'Nasz\nproces', text: 'Przez dwa tygodnie przeprowadziliśmy szczegółowe warsztaty z teamem agencji, dokumentując każdy krok istniejącego procesu. Na tej podstawie zaprojektowaliśmy przepływ pracy w nowym narzędziu.' },
      result: { heading: 'Wyniki\ni efekty', text: 'Czas raportowania skrócił się z 8h do 45 minut tygodniowo. Agencja mogła przyjąć 10 nowych klientów bez powiększania zespołu.', items: ['Automatyzacja raportów', 'Integracja z 12 narzędziami', 'ROI 380% w 6 miesięcy'] },
      img1Gradient: 'linear-gradient(135deg,#6a8060,#3a5030)',
      img2Gradient: 'linear-gradient(135deg,#5a7050,#2a4020)',
      prevSlug: 'social-media-campaigns', prevTitle: 'Social Media Campaigns',
      nextSlug: 'seo-marketing-tools', nextTitle: 'SEO & Marketing Tools',
    },
    {
      slug: 'seo-marketing-tools',
      title: 'SEO & Marketing Tools',
      category: 'Advanced Analytics',
      date: '18 stycznia, 2024',
      client: 'Alt+Shift Commerce',
      location: 'Gdańsk, PL',
      heroGradient: 'radial-gradient(ellipse 60% 80% at 10% 50%, rgba(240,210,140,.55) 0%, transparent 60%), radial-gradient(ellipse 60% 80% at 90% 50%, rgba(140,200,160,.55) 0%, transparent 60%), #F5F4F8',
      coverGradient: 'linear-gradient(135deg,#5a5040 0%,#2a2018 100%)',
      intro: 'Rozbudowane narzędzie SEO i marketing analytics dla e-commerce. Dashboard w czasie rzeczywistym, śledzenie pozycji, analiza konkurencji i rekomendacje AI.',
      challenge: { heading: 'Wyzwanie\ni rozwiązanie', text: 'Sklep internetowy z 50 000 produktów nie miał możliwości efektywnego monitorowania pozycji SEO i wyników kampanii marketingowych z jednego miejsca.', items: ['Analiza techniczna SEO', 'Integracja danych', 'Automatyczne raporty'] },
      process: { heading: 'Nasz\nproces', text: 'Zintegrowaliśmy dane z Google Search Console, Analytics, Ads i narzędzi SEO w jednym dashboardzie. Stworzyliśmy moduł rekomendacji oparty na danych historycznych.' },
      result: { heading: 'Wyniki\ni efekty', text: 'Organiczny ruch wzrósł o 145% w ciągu roku. Koszt pozyskania klienta z SEO spadł o 60% w porównaniu z płatną reklamą.', items: ['Wzrost ruchu organicznego o 145%', 'Monitoring 50k+ słów kluczowych', 'Automatyczne alerty SEO'] },
      img1Gradient: 'linear-gradient(135deg,#5a5040,#2a2018)',
      img2Gradient: 'linear-gradient(135deg,#4a4030,#1a1008)',
      prevSlug: 'content-marketing-suite', prevTitle: 'Content Marketing Suite',
      nextSlug: 'creative-branding-agency', nextTitle: 'Creative Branding Agency',
    },
    {
      slug: 'creative-branding-agency',
      title: 'Creative Branding Agency',
      category: 'Marketing Strategy',
      date: '3 września, 2023',
      client: 'Boltshift Brand',
      location: 'Poznań, PL',
      heroGradient: 'radial-gradient(ellipse 60% 80% at 10% 50%, rgba(200,180,240,.55) 0%, transparent 60%), radial-gradient(ellipse 60% 80% at 90% 50%, rgba(240,200,160,.55) 0%, transparent 60%), #F5F4F8',
      coverGradient: 'linear-gradient(135deg,#3d3548 0%,#1d1525 100%)',
      intro: 'Kompleksowy rebranding agencji kreatywnej — nowe logo, identyfikacja wizualna, strona internetowa i materiały marketingowe. Od strategii po wdrożenie w 6 tygodni.',
      challenge: { heading: 'Wyzwanie\ni rozwiązanie', text: 'Agencja po 10 latach działalności chciała odświeżyć wizerunek i lepiej komunikować swoje unikalne podejście do projektowania. Stary brand nie oddawał obecnych kompetencji.', items: ['Strategia marki', 'Projektowanie identyfikacji', 'Wdrożenie systemu'] },
      process: { heading: 'Nasz\nproces', text: 'Warsztat brandingowy z zarządem ujawnił wartości i pozycjonowanie marki. Na tej bazie zbudowaliśmy system identyfikacji wizualnej — od logo przez typografię po system ikonograficzny.' },
      result: { heading: 'Wyniki\ni efekty', text: 'Nowy brand spotkał się z bardzo pozytywnym odbiorem zarówno wśród dotychczasowych, jak i potencjalnych klientów. Pozyskiwanie nowych zleceń wzrosło o 90%.', items: ['Nowy system identyfikacji', 'Brand book 80 stron', 'Wzrost konwersji o 90%'] },
      img1Gradient: 'linear-gradient(135deg,#3d3548,#1d1525)',
      img2Gradient: 'linear-gradient(135deg,#2d2538,#0d0515)',
      prevSlug: 'seo-marketing-tools', prevTitle: 'SEO & Marketing Tools',
      nextSlug: 'video-production-hub', nextTitle: 'Video Production Hub',
    },
    {
      slug: 'video-production-hub',
      title: 'Video Production Hub',
      category: 'Technology',
      date: '22 listopada, 2023',
      client: 'Lightbox Studio',
      location: 'Łódź, PL',
      heroGradient: 'radial-gradient(ellipse 60% 80% at 10% 50%, rgba(240,160,140,.55) 0%, transparent 60%), radial-gradient(ellipse 60% 80% at 90% 50%, rgba(160,180,240,.55) 0%, transparent 60%), #F5F4F8',
      coverGradient: 'linear-gradient(135deg,#6a1e20 0%,#2a0808 100%)',
      intro: 'Platforma do zarządzania produkcją wideo — od briefu przez pre-produkcję, realizację, postprodukcję po dystrybucję. Dedykowane narzędzie dla studia produkcyjnego.',
      challenge: { heading: 'Wyzwanie\ni rozwiązanie', text: 'Studio produkcyjne realizujące 200+ projektów rocznie potrzebowało systemu, który połączyłby wszystkich uczestników produkcji i zautomatyzował powtarzalne czynności administracyjne.', items: ['Mapowanie procesu produkcji', 'Projektowanie przepływu pracy', 'Integracja z Adobe Suite'] },
      process: { heading: 'Nasz\nproces', text: 'Przez miesiąc obserwowaliśmy pracę studia i dokumentowaliśmy każdy etap produkcji. Prototyp platformy był testowany przez 3 miesiące w trybie pilotażowym przed pełnym wdrożeniem.' },
      result: { heading: 'Wyniki\ni efekty', text: 'Czas administracji projektu spadł o 70%. Studio może teraz obsługiwać o 35% więcej projektów z tym samym zespołem.', items: ['Redukcja czasu admin o 70%', 'Integracja z Adobe Creative Suite', 'Wzrost pojemności o 35%'] },
      img1Gradient: 'linear-gradient(135deg,#6a1e20,#2a0808)',
      img2Gradient: 'linear-gradient(135deg,#5a0e10,#1a0000)',
      prevSlug: 'creative-branding-agency', prevTitle: 'Creative Branding Agency',
      nextSlug: 'ui-ux-design-platform', nextTitle: 'UI/UX Design Platform',
    },
  ];
  return data.map((p) => ({ params: { slug: p.slug }, props: { project: p } }));
}

const { project } = Astro.props as { project: Project };
---

<Layout
  title={`${project.title} – Projekt Vexor`}
  description={project.intro}
  canonicalURL={`https://vexordesigns.pl/projekty/${project.slug}/`}
>
  <Navbar />
  <MobileMenu />

  <main class="bg-brand-bg-light">

    <!-- ── HERO ─────────────────────────────────────────────── -->
    <section
      class="relative min-h-[88vh] flex flex-col items-center justify-center px-6 pt-[120px] pb-0 overflow-hidden"
      style={`background: ${project.heroGradient};`}
    >
      <!-- Eyebrow centred -->
      <div class="flex justify-center mb-6">
        <Eyebrow label={project.category} />
      </div>

      <!-- Giant title -->
      <h1
        class="text-center font-bold tracking-[-0.03em] text-brand-accent leading-[1.05] text-hero"
        
      >
        {project.title}
      </h1>

      <!-- Metadata row pinned to bottom of hero -->
      <div class="w-full max-w-[1100px] mx-auto pt-20 pb-14 grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-0">
        {[
          { label: 'Data', value: project.date },
          { label: 'Klient', value: project.client },
          { label: 'Kategoria', value: project.category },
          { label: 'Lokalizacja', value: project.location },
        ].map((item) => (
          <div class="flex flex-col items-center text-center md:border-r md:border-black/10 last:border-0 px-4">
            <span class="text-[13px] font-500 text-brand-muted uppercase tracking-[.08em] mb-1">{item.label}</span>
            <span class="text-xl font-500 text-brand-accent">{item.value}</span>
          </div>
        ))}
      </div>
      <!-- Cover image -->
      <div
        class="w-full max-w-[1700px] mx-auto my-12 rounded-[40px] overflow-hidden flex-shrink-0"
        style={`height: clamp(240px, 36vw, 720px); background: ${project.coverGradient};`}
        aria-hidden="true"
      >
        <div class="w-full h-full" style="background-image: repeating-linear-gradient(135deg,rgba(255,255,255,.06) 0 1px,transparent 1px 20px);"></div>
      </div>
    </section>

      

      

    <!-- ── INTRO TEXT ────────────────────────────────────────── -->
    <section class="max-w-[1700px] mx-auto px-6 md:px-10 py-16 md:py-20">
      <p class="text-xl md:text-2xl text-brand-text leading-relaxed max-w-[820px]">
        {project.intro}
      </p>
    </section>

    <!-- ── 50/50: STICKY ACCORDION + SCROLLING WEBSITE IMAGE ── -->
    <div class="max-w-[1700px] mx-auto px-6 md:px-10">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 items-start">

        <!-- Left: floating sticky accordion card -->
        <div class="md:sticky md:top-36 bg-white rounded-[32px] px-8 md:px-12 py-10 md:py-14">

          <details class="group/acc border-b border-brand-border" open>
            <summary class="flex items-center justify-between py-7 cursor-pointer list-none select-none">
              <span class="text-[clamp(20px,2vw,28px)] font-semibold tracking-[-0.02em] text-brand-accent">Wyzwanie</span>
              <span class="w-9 h-9 rounded-full border border-brand-border flex items-center justify-center text-[22px] leading-none text-brand-muted flex-shrink-0 ml-4 transition-transform duration-200 group-open/acc:rotate-45">+</span>
            </summary>
            <div class="pb-10">
              <p class="text-[17px] text-brand-text leading-relaxed">{project.challenge.text}</p>
              <ul class="mt-6 flex flex-col gap-3">
                {project.challenge.items.map((item) => (
                  <li class="flex items-center gap-3 text-[15px] font-semibold text-brand-accent">
                    <span class="w-1.5 h-1.5 rounded-full bg-primary flex-shrink-0"></span>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          </details>

          <details class="group/acc border-b border-brand-border">
            <summary class="flex items-center justify-between py-7 cursor-pointer list-none select-none">
              <span class="text-[clamp(20px,2vw,28px)] font-semibold tracking-[-0.02em] text-brand-accent">Rozwiązanie</span>
              <span class="w-9 h-9 rounded-full border border-brand-border flex items-center justify-center text-[22px] leading-none text-brand-muted flex-shrink-0 ml-4 transition-transform duration-200 group-open/acc:rotate-45">+</span>
            </summary>
            <div class="pb-10">
              <p class="text-[17px] text-brand-text leading-relaxed">{project.process.text}</p>
            </div>
          </details>


        </div>

        <!-- Right: rounded image card -->
        <div class="overflow-hidden rounded-[32px]">
          <!-- Browser chrome bar -->
          <div class="flex items-center gap-2 px-4 py-[10px] bg-[#16162a]">
            <span class="w-[11px] h-[11px] rounded-full bg-[#ff5f57]"></span>
            <span class="w-[11px] h-[11px] rounded-full bg-[#ffbd2e]"></span>
            <span class="w-[11px] h-[11px] rounded-full bg-[#28c840]"></span>
            <div class="flex-1 mx-3 h-6 rounded-full bg-white/10 flex items-center px-3">
              <span class="text-[11px] font-mono text-white/40">vexordesigns.pl/{project.slug}/</span>
            </div>
          </div>
          {project.previewImage ? (
            <img
              src={project.previewImage}
              alt={`Podgląd strony – ${project.title}`}
              class="w-full block"
              loading="eager"
            />
          ) : (
            <div style={`height: 900px; background: ${project.coverGradient};`}>
              <div class="w-full h-full" style="background-image: repeating-linear-gradient(135deg,rgba(255,255,255,.06) 0 1px,transparent 1px 20px);"></div>
            </div>
          )}
        </div>

      </div>
    </div>

    <!-- ── IMAGE GALLERY ─────────────────────────────────────── -->
    <div class="max-w-[1700px] mx-auto px-6 md:px-10 mt-6 grid grid-cols-1 md:grid-cols-2 gap-6">
      <div
        class="rounded-[32px] overflow-hidden reveal"
        style={`height: clamp(220px,28vw,420px); background: ${project.img1Gradient};`}
        aria-hidden="true"
      >
        <div class="w-full h-full" style="background-image: repeating-linear-gradient(135deg,rgba(255,255,255,.06) 0 1px,transparent 1px 18px);"></div>
      </div>
      <div
        class="rounded-[32px] overflow-hidden reveal"
        style={`height: clamp(220px,28vw,420px); background: ${project.img2Gradient}; --stagger-i:1;`}
        aria-hidden="true"
      >
        <div class="w-full h-full" style="background-image: repeating-linear-gradient(45deg,rgba(255,255,255,.06) 0 1px,transparent 1px 18px);"></div>
      </div>
    </div>

    <!-- ── RESULT ─────────────────────────────────────────────── -->
    <div class="max-w-[1700px] mx-auto px-6 md:px-10 mt-6 mb-16">
      <div class="bg-white rounded-[40px] px-8 md:px-16 py-14 md:py-20">
        <div class="grid grid-cols-1 md:grid-cols-[280px_1fr] gap-8 md:gap-16 reveal">
          <div>
            <h2 class="text-[clamp(22px,3vw,36px)] font-semibold leading-[1.2] tracking-[-0.02em] text-brand-accent whitespace-pre-line">
              {project.result.heading}
            </h2>
          </div>
          <div>
            <p class="text-[17px] text-brand-text leading-relaxed">{project.result.text}</p>
            <ul class="mt-6 flex flex-col gap-3">
              {project.result.items.map((item) => (
                <li class="flex items-center gap-3 text-[16px] font-semibold text-brand-accent">
                  <span class="w-1.5 h-1.5 rounded-full bg-primary flex-shrink-0"></span>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>

    <!-- ── PROJECT NAVIGATION ────────────────────────────────── -->
    <div class="max-w-[1700px] mx-auto px-6 md:px-10 pb-20">
      <div class="grid grid-cols-2 gap-4">
        {project.prevSlug ? (
          <a
            href={`/projekty/${project.prevSlug}/`}
            class="group flex items-center gap-3 bg-white rounded-[24px] px-6 py-5 hover:bg-primary transition-colors duration-200"
          >
            <svg class="w-5 h-5 text-brand-muted group-hover:text-white transition-colors flex-shrink-0" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 4L6 10L12 16"/>
            </svg>
            <div>
              <p class="text-[11px] uppercase tracking-[.1em] text-brand-muted group-hover:text-white/70 transition-colors font-semibold">poprzedni projekt</p>
              <p class="text-[15px] font-semibold text-brand-accent group-hover:text-white transition-colors mt-0.5">{project.prevTitle}</p>
            </div>
          </a>
        ) : <div />}

        {project.nextSlug ? (
          <a
            href={`/projekty/${project.nextSlug}/`}
            class="group flex items-center justify-end gap-3 bg-white rounded-[24px] px-6 py-5 hover:bg-primary transition-colors duration-200 text-right"
          >
            <div>
              <p class="text-[11px] uppercase tracking-[.1em] text-brand-muted group-hover:text-white/70 transition-colors font-semibold">następny projekt</p>
              <p class="text-[15px] font-semibold text-brand-accent group-hover:text-white transition-colors mt-0.5">{project.nextTitle}</p>
            </div>
            <svg class="w-5 h-5 text-brand-muted group-hover:text-white transition-colors flex-shrink-0" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M8 4L14 10L8 16"/>
            </svg>
          </a>
        ) : <div />}
      </div>
    </div>

  </main>

  <ContactCTA />
  <Footer />

</Layout>
