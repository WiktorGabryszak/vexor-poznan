---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import MobileMenu from '../components/MobileMenu.astro';
import Footer from '../components/Footer.astro';
import ContactCTA from '../components/ContactCTA.astro';
import Eyebrow from '../components/ui/Eyebrow.astro';
import ButtonA from '../components/ui/ButtonA.astro';
import { Image } from 'astro:assets';
import imgVexor1 from '../assets/images/vexor-1.jpg';
import imgVexor2 from '../assets/images/vexor-2.jpg';
---

<Layout
  title="O nas – Vexor Designs | Agencja tworzenia stron internetowych"
  description="Poznaj Vexor – agencję webową z Polski. Tworzymy szybkie strony, sklepy i aplikacje. Sprawdź nasz zespół, wartości i dotychczasowe projekty."
  canonicalURL="https://stronyinternetowe.net/o-nas/"
  ogImage="https://stronyinternetowe.net/og-image.jpg"
>
  <Navbar />
  <MobileMenu />
  <main>

    <!-- Hero -->
    <section class="min-h-[50vh] relative flex flex-col justify-center items-center bg-hero-image bg-cover bg-no-repeat text-white">
      <div class="relative z-10 max-w-[1700px] mx-auto px-5 md:px-[47px] py-16 mt-[110px] flex flex-col justify-center items-center gap-5">
        <nav aria-label="Breadcrumb">
          <ol class="inline-flex items-center gap-2 px-4 py-2 rounded-xl backdrop-blur-md border border-white/10 text-sm text-white/70">
            <li><a href="/" class="hover:text-white transition-colors duration-150">Strona główna</a></li>
            <li aria-hidden="true">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-50"><path d="M9 18l6-6-6-6"/></svg>
            </li>
            <li class="text-white font-medium" aria-current="page">O nas</li>
          </ol>
        </nav>
        <h1 class="text-heroSub text-white text-balance reveal text-center" style="--stagger-i:0">
          Agencja webowa z Polski
        </h1>
        <p class="text-[21px] text-white/80 max-w-[560px] text-pretty reveal font-medium text-center" style="--stagger-i:1">
          Budujemy strony, sklepy i aplikacje, które pomagają firmom rosnąć. Obsługujemy klientów w Polsce oraz na całym świecie.
        </p>
      </div>
    </section>

    <!-- Kim jesteśmy -->
    <section class="bg-brand-bg-light py-[80px] md:py-[100px]">
      <div class="max-w-[1700px] mx-auto px-5 md:px-10">
        <div class="grid grid-cols-1 lg:grid-cols-[2fr_3fr] gap-[60px] items-center">
          <Image src={imgVexor1} alt="Vexor Designs – zespół przy pracy" class="reveal rounded-card lg:aspect-[4/5] object-cover w-full" style="--stagger-i:0" loading="lazy" decoding="async" format="webp" quality={82} width={800} height={1000} />
          <div class="flex flex-col gap-6 items-start reveal" style="--stagger-i:1">
            <Eyebrow label="Kim jesteśmy" />
            <h2 class="text-h2 text-brand-accent">
              Tworzymy strony, które pracują na Twój biznes
            </h2>
            <p class="text-brand-text text-lg leading-relaxed">
              Vexor to agencja webowa założona przez pasjonatów technologii i projektowania. Naszą siedzibą jest Strzelno w województwie kujawsko-pomorskim, ale nasze projekty trafiają do firm w całej Polsce i do klientów w Wielkiej Brytanii.
            </p>
            <p class="text-brand-text text-lg leading-relaxed">
              Nie jesteśmy jednorazowym freelancerem. Każdy projekt traktujemy jak długofalową współpracę, dlatego zależy nam, żeby strona, którą oddajemy, faktycznie generowała zapytania, sprzedaż i widoczność w Google.
            </p>
            <p class="text-brand-text text-lg leading-relaxed">
              Nasze projekty to przede wszystkim strony firmowe, sklepy WooCommerce i dedykowane aplikacje webowe. Pracujemy w oparciu o Astro, WordPress, React i Next.js, dobierając technologię do rzeczywistych potrzeb klienta, a nie do aktualnych mód technologicznych.
            </p>
            <p class="text-brand-text text-lg leading-relaxed">
              Zależy nam na tym, żeby klient rozumiał co dostaje i dlaczego podejmujemy konkretne decyzje projektowe. Dlatego zawsze zaczynamy od rozmowy o celach, a nie od prezentacji portfolio.
            </p>
            <div class="mt-2">
              <ButtonA href="/kontakt/" label="Zamów stronę" invert={false} />
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- Liczby -->
    <section class="bg-brand-bg-light py-[80px] md:py-[100px]">
      <div class="max-w-[1700px] mx-auto px-5 md:px-10">

        <!-- Nagłówek asymetryczny -->
        <div class="flex flex-col lg:flex-row lg:items-end justify-between gap-6 mb-10 reveal" style="--stagger-i:0">
          <div>
            <Eyebrow label="W liczbach" />
            <h2 class="text-h2 text-brand-accent mt-4 max-w-[520px]">Efekty mierzone w projektach</h2>
          </div>
          <p class="text-brand-text text-lg max-w-[360px] lg:text-right leading-relaxed lg:pb-1">
            Liczby zebrane podczas pracy z klientami z różnych branż przez ostatnie lata.
          </p>
        </div>

        <!-- Bento grid -->
        <div class="team-stats grid grid-cols-1 md:grid-cols-3 gap-5 md:[grid-template-rows:1fr_1fr]">

          <!-- Zdjęcie lewe (1 wiersz) -->
          <div class="rounded-[24px] overflow-hidden h-[300px] md:h-auto reveal hidden md:block" style="--stagger-i:1">
            <Image src={imgVexor1} alt="Vexor Designs – praca nad projektem" class="w-full h-full object-cover" width={550} height={350} format="webp" quality={82} loading="lazy" decoding="async" />
          </div>

          <!-- Stat: projekty -->
          <div class="bg-white rounded-[24px] px-16 py-14 flex flex-col justify-between reveal gap-20" style="--stagger-i:2">
            <span class="inline-flex items-center gap-2 text-[21px] text-text font-semibold">
              <span class="w-1.5 h-1.5 rounded-full bg-primary flex-shrink-0"></span>
              zrealizowanych projektów
            </span>
            <div><span class="block text-hero text-brand-accent"><span data-count="40">0</span>+</span>
            <p class="text-text text-[20px] font-400 leading-relaxed">Strony firmowe, sklepy, aplikacje i landing page dla firm z Polski i UK</p></div>
            
          </div>

          <!-- Zdjęcie prawe (2 wiersze) -->
          <div class="rounded-[24px] overflow-hidden h-[240px] md:h-auto md:row-span-2 reveal hidden md:block" style="--stagger-i:3">
            <Image src={imgVexor2} alt="Vexor Designs – realizacje" class="w-full h-full object-cover" width={550} height={700} format="webp" quality={82} loading="lazy" decoding="async" />
          </div>

          <!-- Stat: doświadczenie -->
          <div class="bg-white rounded-[24px] px-16 py-14 flex flex-col justify-between reveal gap-20" style="--stagger-i:4">
            <span class="inline-flex items-center gap-2 text-[21px] text-text font-semibold">
              <span class="w-1.5 h-1.5 rounded-full bg-primary flex-shrink-0"></span>
              lata doświadczenia
            </span>
            <div>
              <span class="block text-hero text-brand-accent"><span data-count="5">0</span>+</span>
              <p class="text-text text-[20px] font-400 leading-relaxed">Projektujemy i wdrażamy strony od 2021 roku, stale rozwijając kompetencje</p>
            </div>
          </div>

          <!-- Stat: klienci -->
          <div class="bg-white rounded-[24px] px-16 py-14 flex flex-col justify-between reveal gap-20" style="--stagger-i:5">
            <span class="inline-flex items-center gap-2 text-[21px] text-text font-semibold">
              <span class="w-1.5 h-1.5 rounded-full bg-primary flex-shrink-0"></span>
              zadowolonych klientów
            </span>
            <div>
              <span class="block text-hero text-brand-accent"><span data-count="98">0</span>%</span>
              <p class="text-text text-[20px] font-400 leading-relaxed">Większość naszych projektów pochodzi z poleceń od istniejących klientów</p>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- Nasze wartości -->
    <section class="bg-brand-bg-light py-[80px] md:py-[100px]">
      <div class="max-w-[1700px] mx-auto px-5 md:px-10">
        <div class="text-center mb-14 reveal" style="--stagger-i:0">
          <Eyebrow label="Nasze wartości" />
          <h2 class="text-h2 text-brand-accent mt-4">Na czym nam zależy</h2>
          <p class="text-brand-text text-lg mt-4 max-w-[540px] mx-auto leading-relaxed">
            Te cztery zasady kierują naszą pracą przy każdym projekcie, niezależnie od jego wielkości.
          </p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">

          <div class="bg-white rounded-card p-8 flex flex-col gap-4 reveal" style="--stagger-i:0">
            <span class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center text-primary">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
              </svg>
            </span>
            <h3 class="text-h5 text-brand-accent font-medium">Przejrzystość</h3>
            <p class="text-brand-text leading-relaxed">
              Zawsze wiesz, na jakim etapie jest Twój projekt, ile kosztuje i dlaczego podejmujemy konkretne decyzje techniczne. Żadnych ukrytych opłat ani zaskoczeń przy fakturze.
            </p>
          </div>

          <div class="bg-white rounded-card p-8 flex flex-col gap-4 reveal" style="--stagger-i:1">
            <span class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center text-primary">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
              </svg>
            </span>
            <h3 class="text-h5 text-brand-accent font-medium">Terminowość</h3>
            <p class="text-brand-text leading-relaxed">
              Ustalamy realistyczne terminy i ich dotrzymujemy. Jeśli po drodze coś się zmienia, informujemy Cię z wyprzedzeniem, a nie w dniu planowanego odbioru.
            </p>
          </div>

          <div class="bg-white rounded-card p-8 flex flex-col gap-4 reveal" style="--stagger-i:2">
            <span class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center text-primary">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>
              </svg>
            </span>
            <h3 class="text-h5 text-brand-accent font-medium">Jakość kodu</h3>
            <p class="text-brand-text leading-relaxed">
              Piszemy czysty, dobrze zorganizowany kod. Strona ładuje się szybko, działa na każdym urządzeniu i jest gotowa na dalszy rozwój bez przebudowy od podstaw.
            </p>
          </div>

          <div class="bg-white rounded-card p-8 flex flex-col gap-4 reveal" style="--stagger-i:3">
            <span class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center text-primary">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 18v-6a9 9 0 0 1 18 0v6"/>
                <path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3z"/>
                <path d="M3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"/>
              </svg>
            </span>
            <h3 class="text-h5 text-brand-accent font-medium">Wsparcie po wdrożeniu</h3>
            <p class="text-brand-text leading-relaxed">
              Nie znikamy po oddaniu projektu. Oferujemy pakiety opieki technicznej obejmujące aktualizacje, kopie zapasowe i pomoc przy każdej zmianie treści lub funkcjonalności.
            </p>
          </div>

        </div>
      </div>
    </section>

    <!-- Link wewnętrzny do projektów -->
    <section class="bg-brand-bg-light py-[60px]">
      <div class="max-w-[1700px] mx-auto px-5 md:px-10 text-center reveal" style="--stagger-i:0">
        <p class="text-brand-text text-lg mb-4">Chcesz zobaczyć efekty naszej pracy?</p>
        <a href="/projekty/" class="text-primary font-semibold text-xl hover:underline transition-colors">
          Sprawdź nasze realizacje
        </a>
      </div>
    </section>

    <ContactCTA />
  </main>
  <Footer />
</Layout>

<script type="application/ld+json" is:inline>
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Strona główna",
      "item": "https://stronyinternetowe.net/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "O nas",
      "item": "https://stronyinternetowe.net/o-nas/"
    }
  ]
}
</script>
